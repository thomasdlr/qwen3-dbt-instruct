{
  "sources": [
    "raw.fault_log",
    "raw.engineer_visits"
  ],
  "staging_models": [
    "stg_fault_log",
    "stg_engineer_visits"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_fault_log_visits",
    "type": "fact",
    "grain": "1 row per fault_log_entry_id"
  },
  "ctes": [
    "stg_fault_log",
    "stg_engineer_visits"
  ],
  "joins": [
    {
      "left": "stg_fault_log",
      "right": "stg_engineer_visits",
      "on": "stg_fault_log.fault_log_entry_id = stg_engineer_visits.fault_log_entry_id"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ],
    "fault_log_entry_id": [
      "not_null",
      "unique"
    ]
  }
}