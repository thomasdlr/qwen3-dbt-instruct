{
  "sources": [
    "raw.item",
    "raw.review"
  ],
  "staging_models": [
    "stg_item",
    "stg_review"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_item_review_analysis",
    "type": "report",
    "grain": "1 row per item title"
  },
  "ctes": [
    "stg_item",
    "stg_review"
  ],
  "joins": [
    {
      "left": "stg_item",
      "right": "stg_review",
      "on": "stg_item.i_id = stg_review.i_id"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ],
    "avg_rating": [
      "not_null"
    ]
  }
}