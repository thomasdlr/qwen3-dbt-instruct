{
  "sources": [
    "raw.products",
    "raw.ref_colors",
    "raw.product_characteristics"
  ],
  "staging_models": [
    "stg_products",
    "stg_ref_colors",
    "stg_product_characteristics"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_color_counts",
    "type": "report",
    "grain": "1 row per product_id"
  },
  "ctes": [
    "stg_products",
    "stg_ref_colors",
    "stg_product_characteristics"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_ref_colors",
      "on": "products.color_code = ref_colors.color_code"
    },
    {
      "left": "stg_products",
      "right": "stg_product_characteristics",
      "on": "products.product_id = product_characteristics.product_id"
    }
  ],
  "tests": {
    "product_id": [
      "not_null"
    ],
    "color_description": [
      "not_null"
    ]
  }
}