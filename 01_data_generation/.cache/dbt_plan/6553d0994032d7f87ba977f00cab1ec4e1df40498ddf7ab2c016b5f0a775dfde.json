{
  "sources": [
    "raw.Addresses",
    "raw.Student_Addresses"
  ],
  "staging_models": [
    "stg_Addresses",
    "stg_Student_Addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_address_rental_metrics",
    "type": "fact",
    "grain": "1 row per address_id"
  },
  "ctes": [
    "stg_Addresses",
    "stg_Student_Addresses"
  ],
  "joins": [
    {
      "left": "stg_Addresses",
      "right": "stg_Student_Addresses",
      "on": "stg_Addresses.address_id = stg_Student_Addresses.address_id"
    }
  ],
  "tests": {
    "line_1": [
      "not_null"
    ],
    "address_id": [
      "not_null",
      "unique"
    ],
    "monthly_rental_avg": [
      "not_null"
    ]
  }
}