{
  "sources": [
    "raw.membership_register_branch",
    "raw.branch",
    "raw.member"
  ],
  "staging_models": [
    "stg_membership_register_branch",
    "stg_branch",
    "stg_member"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_branch_member_ky_ga",
    "type": "report",
    "grain": "1 row per branch.name"
  },
  "ctes": [
    "stg_membership_register_branch",
    "stg_branch",
    "stg_member"
  ],
  "joins": [
    {
      "left": "stg_membership_register_branch",
      "right": "stg_branch",
      "on": "branch_id = branch_id"
    },
    {
      "left": "stg_membership_register_branch",
      "right": "stg_member",
      "on": "member_id = member_id"
    }
  ],
  "tests": {
    "branch.name": [
      "not_null",
      "unique"
    ]
  }
}