{
  "sources": [
    "raw.financial_transactions",
    "raw.customers_cards"
  ],
  "staging_models": [
    "stg_financial_transactions",
    "stg_customers_cards"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_card_type_transactions",
    "type": "fact",
    "grain": "1 row per card_type_code"
  },
  "ctes": [
    "stg_financial_transactions",
    "stg_customers_cards"
  ],
  "joins": [
    {
      "left": "stg_financial_transactions",
      "right": "stg_customers_cards",
      "on": "card_id = card_id"
    }
  ],
  "tests": {
    "card_type_code": [
      "not_null",
      "unique"
    ],
    "count_star": [
      "not_null"
    ]
  }
}