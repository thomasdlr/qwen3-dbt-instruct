{
  "sources": [
    "raw.endowment",
    "raw.school"
  ],
  "staging_models": [
    "stg_endowment",
    "stg_school"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_school_endowment_summary",
    "type": "report",
    "grain": "1 row per school_id"
  },
  "ctes": [
    "stg_endowment",
    "stg_school"
  ],
  "joins": [
    {
      "left": "stg_endowment",
      "right": "stg_school",
      "on": "stg_endowment.school_id = stg_school.school_id"
    }
  ],
  "tests": {
    "school_name": [
      "not_null"
    ],
    "school_id": [
      "not_null"
    ]
  }
}