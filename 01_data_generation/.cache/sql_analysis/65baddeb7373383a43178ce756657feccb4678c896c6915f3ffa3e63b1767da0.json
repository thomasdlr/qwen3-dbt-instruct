{
  "tables": [
    "club",
    "member_of_club",
    "student"
  ],
  "joins": [
    {
      "left_table": "club",
      "right_table": "member_of_club",
      "condition": "t1.clubid = t2.clubid"
    },
    {
      "left_table": "member_of_club",
      "right_table": "student",
      "condition": "t2.stuid = t3.stuid"
    }
  ],
  "filters": [
    "t3.fname = \"Tracy\"",
    "t3.lname = \"Kim\""
  ]
}