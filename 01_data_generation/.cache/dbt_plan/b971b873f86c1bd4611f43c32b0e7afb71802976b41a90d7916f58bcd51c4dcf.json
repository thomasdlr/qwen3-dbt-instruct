{
  "sources": [
    "raw.research_outcomes",
    "raw.project_outcomes",
    "raw.projects"
  ],
  "staging_models": [
    "stg_research_outcomes",
    "stg_project_outcomes",
    "stg_projects"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_sint_project_outcomes",
    "type": "report",
    "grain": "1 row per outcome_description"
  },
  "ctes": [
    "stg_research_outcomes",
    "stg_project_outcomes",
    "stg_projects"
  ],
  "joins": [
    {
      "left": "stg_research_outcomes",
      "right": "stg_project_outcomes",
      "on": "outcome_code = outcome_code"
    },
    {
      "left": "stg_project_outcomes",
      "right": "stg_projects",
      "on": "project_id = project_id"
    }
  ],
  "tests": {
    "outcome_description": [
      "not_null"
    ]
  }
}