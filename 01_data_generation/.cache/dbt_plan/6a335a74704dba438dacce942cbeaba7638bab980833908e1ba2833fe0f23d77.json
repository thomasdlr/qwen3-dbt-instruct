{
  "sources": [
    "raw.Staff",
    "raw.Engineer_Visits",
    "raw.Maintenance_Engineers"
  ],
  "staging_models": [
    "stg_Staff",
    "stg_Engineer_Visits",
    "stg_Maintenance_Engineers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_Staff_Engineer_Visits",
    "type": "report",
    "grain": "1 row per Staff.staff_id, Maintenance_Engineers.engineer_id"
  },
  "ctes": [
    "stg_Staff",
    "stg_Engineer_Visits",
    "stg_Maintenance_Engineers"
  ],
  "joins": [
    {
      "left": "stg_Staff",
      "right": "stg_Engineer_Visits",
      "on": "staff.staff_id = engineer_visits.contact_staff_id"
    },
    {
      "left": "stg_Engineer_Visits",
      "right": "stg_Maintenance_Engineers",
      "on": "engineer_visits.engineer_id = maintenance_engineers.engineer_id"
    }
  ],
  "tests": {
    "staff_name": [
      "not_null"
    ],
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ]
  }
}