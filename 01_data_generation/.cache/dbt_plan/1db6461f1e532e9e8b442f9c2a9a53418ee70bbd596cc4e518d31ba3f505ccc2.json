{
  "sources": [
    "raw.country",
    "raw.match_season"
  ],
  "staging_models": [
    "stg_country",
    "stg_match_season"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_country_forward_defender_intersect",
    "type": "report",
    "grain": "1 row per Country_name"
  },
  "ctes": [
    "stg_country",
    "stg_match_season"
  ],
  "joins": [
    {
      "left": "stg_country",
      "right": "stg_match_season",
      "on": "country.Country_id = match_season.Country"
    },
    {
      "left": "stg_country",
      "right": "stg_match_season",
      "on": "country.Country_id = match_season.Country"
    }
  ],
  "tests": {
    "Country_name": [
      "not_null",
      "unique"
    ]
  }
}