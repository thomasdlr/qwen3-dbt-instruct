{
  "sources": [
    "raw.products",
    "raw.CHARACTERISTICS",
    "raw.product_characteristics"
  ],
  "staging_models": [
    "stg_products",
    "stg_CHARACTERISTICS",
    "stg_product_characteristics"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_characteristic_counts",
    "type": "dimension",
    "grain": "1 row per characteristic_name"
  },
  "ctes": [
    "stg_products",
    "stg_product_characteristics",
    "stg_CHARACTERISTICS"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_product_characteristics",
      "on": "product_id = product_id"
    },
    {
      "left": "stg_product_characteristics",
      "right": "stg_CHARACTERISTICS",
      "on": "characteristic_id = characteristic_id"
    }
  ],
  "tests": {
    "characteristic_name": [
      "not_null",
      "unique"
    ]
  }
}