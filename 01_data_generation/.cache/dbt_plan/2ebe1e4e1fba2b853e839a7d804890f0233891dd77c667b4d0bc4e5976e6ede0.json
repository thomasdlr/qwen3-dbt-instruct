{
  "sources": [
    "raw.countries",
    "raw.car_makers"
  ],
  "staging_models": [
    "stg_countries",
    "stg_car_makers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_country_makers",
    "type": "fact",
    "grain": "1 row per countryid"
  },
  "ctes": [
    "stg_countries",
    "stg_car_makers"
  ],
  "joins": [
    {
      "left": "stg_countries",
      "right": "stg_car_makers",
      "on": "t1.countryid = t2.country"
    }
  ],
  "tests": {
    "countryid": [
      "not_null",
      "unique"
    ],
    "count_star": [
      "not_null"
    ]
  }
}