{
  "sources": [
    "raw.products",
    "raw.product_characteristics",
    "raw.CHARACTERISTICS",
    "raw.ref_colors"
  ],
  "staging_models": [
    "stg_products",
    "stg_product_characteristics",
    "stg_CHARACTERISTICS",
    "stg_ref_colors"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_red_slow_products",
    "type": "report",
    "grain": "1 row per red slow product"
  },
  "ctes": [
    "stg_products",
    "stg_product_characteristics",
    "stg_CHARACTERISTICS",
    "stg_ref_colors"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_product_characteristics",
      "on": "product_id = product_id"
    },
    {
      "left": "stg_product_characteristics",
      "right": "stg_CHARACTERISTICS",
      "on": "characteristic_id = characteristic_id"
    },
    {
      "left": "stg_products",
      "right": "stg_ref_colors",
      "on": "color_code = color_code"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ]
  }
}