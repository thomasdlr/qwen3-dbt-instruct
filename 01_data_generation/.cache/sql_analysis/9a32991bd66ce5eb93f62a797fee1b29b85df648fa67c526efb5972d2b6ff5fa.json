{
  "tables": [
    "products",
    "ref_product_categories",
    "ref_colors"
  ],
  "joins": [
    {
      "left_table": "products",
      "right_table": "ref_product_categories",
      "condition": "t1.product_category_code = t2.product_category_code"
    },
    {
      "left_table": "products",
      "right_table": "ref_colors",
      "condition": "t1.color_code = t3.color_code"
    }
  ],
  "filters": [
    "t3.color_description = \"white\"",
    "t2.unit_of_measure <> \"Handful\""
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "t1.product_name"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "products.product_name",
  "model_type": "dimension"
}