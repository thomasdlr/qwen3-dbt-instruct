{
  "sources": [
    "raw.assignedto",
    "raw.projects",
    "raw.scientists"
  ],
  "staging_models": [
    "stg_assignedto",
    "stg_projects",
    "stg_scientists"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_projects_with_smith_scientists",
    "type": "report",
    "grain": "1 row per projects.code"
  },
  "ctes": [
    "stg_assignedto",
    "stg_projects",
    "stg_scientists"
  ],
  "joins": [
    {
      "left": "stg_assignedto",
      "right": "stg_projects",
      "on": "assignedto.project = projects.code"
    },
    {
      "left": "stg_assignedto",
      "right": "stg_scientists",
      "on": "assignedto.scientist = scientists.SSN"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}