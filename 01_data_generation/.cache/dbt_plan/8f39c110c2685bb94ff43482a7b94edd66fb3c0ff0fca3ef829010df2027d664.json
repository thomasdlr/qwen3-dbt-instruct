{
  "sources": [
    "raw.useracct",
    "raw.trust"
  ],
  "staging_models": [
    "stg_useracct",
    "stg_trust"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_avg_trust_by_user",
    "type": "report",
    "grain": "1 row per source_u_id"
  },
  "ctes": [
    "stg_useracct",
    "stg_trust"
  ],
  "joins": [
    {
      "left": "stg_useracct",
      "right": "stg_trust",
      "on": "u_id = source_u_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "source_u_id": [
      "not_null"
    ]
  }
}