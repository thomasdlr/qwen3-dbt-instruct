{
  "sources": [
    "raw.customers",
    "raw.customer_addresses",
    "raw.addresses"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customer_addresses",
    "stg_addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_lake_geovannyton_customers",
    "type": "report",
    "grain": "1 row per customer"
  },
  "ctes": [
    "stg_customers",
    "stg_customer_addresses",
    "stg_addresses"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customer_addresses",
      "on": "customer_id = customer_id"
    },
    {
      "left": "stg_customer_addresses",
      "right": "stg_addresses",
      "on": "address_id = address_id"
    }
  ],
  "tests": {
    "count": [
      "not_null"
    ]
  }
}