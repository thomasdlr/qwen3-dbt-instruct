{
  "sources": [
    "raw.ENROLLED_IN",
    "raw.GRADECONVERSION",
    "raw.STUDENT"
  ],
  "staging_models": [
    "stg_ENROLLED_IN",
    "stg_GRADECONVERSION",
    "stg_STUDENT"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_smith_avg_grade",
    "type": "report",
    "grain": "1 row per Student"
  },
  "ctes": [
    "stg_ENROLLED_IN",
    "stg_GRADECONVERSION",
    "stg_STUDENT"
  ],
  "joins": [
    {
      "left": "stg_ENROLLED_IN",
      "right": "stg_GRADECONVERSION",
      "on": "stg_ENROLLED_IN.Grade = stg_GRADECONVERSION.lettergrade"
    },
    {
      "left": "stg_ENROLLED_IN",
      "right": "stg_STUDENT",
      "on": "stg_ENROLLED_IN.StuID = stg_STUDENT.StuID"
    }
  ],
  "tests": {
    "avg_gradepoint": [
      "not_null"
    ]
  }
}