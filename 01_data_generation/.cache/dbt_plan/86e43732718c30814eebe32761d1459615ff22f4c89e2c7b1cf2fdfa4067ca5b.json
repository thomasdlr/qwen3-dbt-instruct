{
  "sources": [
    "raw.people",
    "raw.candidate"
  ],
  "staging_models": [
    "stg_people",
    "stg_candidate"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_people_candidate_stats",
    "type": "dimension",
    "grain": "1 row per sex"
  },
  "ctes": [
    "stg_people",
    "stg_candidate"
  ],
  "joins": [
    {
      "left": "stg_people",
      "right": "stg_candidate",
      "on": "stg_people.people_id = stg_candidate.people_id"
    }
  ],
  "tests": {
    "sex": [
      "not_null",
      "unique"
    ]
  }
}