{
  "sources": [
    "raw.claims",
    "raw.settlements"
  ],
  "staging_models": [
    "stg_claims",
    "stg_settlements"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_claims_with_settlements",
    "type": "report",
    "grain": "1 row per claim_id"
  },
  "ctes": [
    "stg_claims",
    "stg_settlements"
  ],
  "joins": [
    {
      "left": "stg_claims",
      "right": "stg_settlements",
      "on": "claim_id"
    }
  ],
  "tests": {
    "claim_id": [
      "not_null",
      "unique"
    ],
    "Effective_Date": [
      "not_null"
    ]
  }
}