{
  "sources": [
    "raw.city",
    "raw.county_public_safety"
  ],
  "staging_models": [
    "stg_city",
    "stg_county_public_safety"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_cities_high_white_population",
    "type": "report",
    "grain": "1 row per County_ID"
  },
  "ctes": [
    "stg_city",
    "stg_county_public_safety"
  ],
  "joins": [
    {
      "left": "stg_city",
      "right": "stg_county_public_safety",
      "on": "city.County_ID = county_public_safety.County_ID"
    }
  ],
  "tests": {
    "Crime_rate": [
      "not_null"
    ]
  }
}