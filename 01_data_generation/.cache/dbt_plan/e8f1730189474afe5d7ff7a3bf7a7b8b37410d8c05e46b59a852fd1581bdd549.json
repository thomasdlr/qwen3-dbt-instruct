{
  "sources": [
    "raw.acceptance",
    "raw.submission"
  ],
  "staging_models": [
    "stg_acceptance",
    "stg_submission"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_acceptance_results",
    "type": "report",
    "grain": "1 row per T1.Result"
  },
  "ctes": [
    "stg_acceptance",
    "stg_submission"
  ],
  "joins": [
    {
      "left": "stg_acceptance",
      "right": "stg_submission",
      "on": "stg_acceptance.Submission_ID = stg_submission.Submission_ID"
    }
  ],
  "tests": {
    "Result": [
      "not_null"
    ]
  }
}