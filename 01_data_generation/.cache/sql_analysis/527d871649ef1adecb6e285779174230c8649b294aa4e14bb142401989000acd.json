{
  "tables": [
    "staff",
    "address"
  ],
  "joins": [
    {
      "left_table": "staff",
      "right_table": "address",
      "condition": "T1.address_id = T2.address_id"
    }
  ],
  "filters": [
    "T1.first_name = 'Elsa'"
  ],
  "select_columns": [
    "T2.address"
  ],
  "grain": "address_id",
  "model_type": "report"
}