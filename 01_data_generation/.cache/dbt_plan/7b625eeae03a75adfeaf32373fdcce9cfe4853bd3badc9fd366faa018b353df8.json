{
  "sources": [
    "raw.Staff",
    "raw.Fault_Log",
    "raw.Engineer_Visits"
  ],
  "staging_models": [
    "stg_Staff",
    "stg_Fault_Log",
    "stg_Engineer_Visits"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_staff_activity",
    "type": "report",
    "grain": "1 row per Staff.staff_id"
  },
  "ctes": [
    "stg_Staff",
    "stg_Fault_Log",
    "stg_Engineer_Visits"
  ],
  "joins": [
    {
      "left": "stg_Staff",
      "right": "stg_Fault_Log",
      "on": "staff_id = recorded_by_staff_id"
    },
    {
      "left": "stg_Staff",
      "right": "stg_Engineer_Visits",
      "on": "staff_id = contact_staff_id"
    }
  ],
  "tests": {
    "staff_name": [
      "not_null"
    ],
    "staff_id": [
      "not_null",
      "unique"
    ]
  }
}