{
  "tables": [
    "professor",
    "department",
    "employee"
  ],
  "joins": [
    {
      "left_table": "professor",
      "right_table": "department",
      "condition": "T1.dept_code = T2.dept_code"
    },
    {
      "left_table": "professor",
      "right_table": "employee",
      "condition": "T1.EMP_NUM = T3.EMP_NUM"
    }
  ],
  "filters": [
    "DEPT_NAME = \"Biology\""
  ],
  "select_columns": [
    "T3.EMP_FNAME",
    "T3.EMP_LNAME"
  ],
  "grain": "employee.EMP_NUM",
  "model_type": "report"
}