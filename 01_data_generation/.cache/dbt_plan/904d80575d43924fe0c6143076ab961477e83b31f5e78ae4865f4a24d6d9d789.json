{
  "sources": [
    "raw.rating",
    "raw.movie"
  ],
  "staging_models": [
    "stg_rating",
    "stg_movie"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_top_rated_movies_by_director",
    "type": "report",
    "grain": "1 row per director"
  },
  "ctes": [
    "stg_rating",
    "stg_movie"
  ],
  "joins": [
    {
      "left": "stg_rating",
      "right": "stg_movie",
      "on": "stg_rating.mID = stg_movie.mID"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ],
    "stars": [
      "not_null"
    ],
    "director": [
      "not_null",
      "unique"
    ]
  }
}