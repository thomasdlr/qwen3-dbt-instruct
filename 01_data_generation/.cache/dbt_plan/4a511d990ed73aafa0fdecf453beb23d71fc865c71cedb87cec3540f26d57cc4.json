{
  "sources": [
    "raw.parties",
    "raw.party_services"
  ],
  "staging_models": [
    "stg_parties",
    "stg_party_services"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_party_email_distinct",
    "type": "report",
    "grain": "1 row per party_email"
  },
  "ctes": [
    "stg_parties",
    "stg_party_services"
  ],
  "joins": [
    {
      "left": "stg_parties",
      "right": "stg_party_services",
      "on": "party_id = customer_id"
    }
  ],
  "tests": {
    "party_email": [
      "not_null"
    ]
  }
}