{
  "sources": [
    "raw.student_course_registrations",
    "raw.students"
  ],
  "staging_models": [
    "stg_student_course_registrations",
    "stg_students"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_registrations",
    "type": "report",
    "grain": "1 row per registration_date (descending)"
  },
  "ctes": [
    "stg_student_course_registrations",
    "stg_students"
  ],
  "joins": [
    {
      "left": "stg_student_course_registrations",
      "right": "stg_students",
      "on": "student_id"
    }
  ],
  "tests": {
    "registration_date": [
      "not_null"
    ],
    "student_details": [
      "not_null"
    ]
  }
}