{
  "sources": [
    "raw.order_items",
    "raw.products",
    "raw.orders"
  ],
  "staging_models": [
    "stg_order_items",
    "stg_products",
    "stg_orders"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_product_order_count",
    "type": "fact",
    "grain": "1 row per product_name"
  },
  "ctes": [
    "stg_order_items",
    "stg_products",
    "stg_orders"
  ],
  "joins": [
    {
      "left": "stg_order_items",
      "right": "stg_products",
      "on": "order_items.product_id = products.product_id"
    },
    {
      "left": "stg_order_items",
      "right": "stg_orders",
      "on": "order_items.order_id = orders.order_id"
    }
  ],
  "tests": {
    "product_name": [
      "not_null"
    ],
    "count_star": [
      "not_null"
    ]
  }
}