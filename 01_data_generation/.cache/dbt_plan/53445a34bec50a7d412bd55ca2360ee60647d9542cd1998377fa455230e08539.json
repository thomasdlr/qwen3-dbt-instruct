{
  "sources": [
    "raw.membership_register_branch",
    "raw.branch",
    "raw.member"
  ],
  "staging_models": [
    "stg_membership_register_branch",
    "stg_branch",
    "stg_member"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_member_branch_names",
    "type": "report",
    "grain": "1 row per membership_register_branch.member_id, membership_register_branch.branch_id"
  },
  "ctes": [
    "stg_membership_register_branch",
    "stg_branch",
    "stg_member"
  ],
  "joins": [
    {
      "left": "stg_membership_register_branch",
      "right": "stg_branch",
      "on": "stg_membership_register_branch.branch_id = stg_branch.branch_id"
    },
    {
      "left": "stg_membership_register_branch",
      "right": "stg_member",
      "on": "stg_membership_register_branch.member_id = stg_member.member_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "branch_id": [
      "not_null"
    ]
  }
}