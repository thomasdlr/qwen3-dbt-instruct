{
  "sources": [
    "raw.Addresses",
    "raw.Student_Addresses"
  ],
  "staging_models": [
    "stg_Addresses",
    "stg_Student_Addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_address_rentals",
    "type": "fact",
    "grain": "1 row per address_id"
  },
  "ctes": [
    "stg_Addresses",
    "stg_Student_Addresses"
  ],
  "joins": [
    {
      "left": "stg_Student_Addresses",
      "right": "stg_Addresses",
      "on": "T1.address_id = T2.address_id"
    }
  ],
  "tests": {
    "address_id": [
      "not_null",
      "unique"
    ],
    "city": [
      "not_null"
    ]
  }
}