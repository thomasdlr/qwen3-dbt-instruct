{
  "sources": [
    "raw.country",
    "raw.match_season"
  ],
  "staging_models": [
    "stg_country",
    "stg_match_season"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_player_country",
    "type": "dimension",
    "grain": "1 row per Player, Country_name"
  },
  "ctes": [
    "stg_match_season",
    "stg_country"
  ],
  "joins": [
    {
      "left": "stg_match_season",
      "right": "stg_country",
      "on": "T1.Country_id = T2.Country"
    }
  ],
  "tests": {
    "Season": [
      "not_null"
    ],
    "Player": [
      "not_null",
      "unique"
    ],
    "Country_name": [
      "not_null"
    ]
  }
}