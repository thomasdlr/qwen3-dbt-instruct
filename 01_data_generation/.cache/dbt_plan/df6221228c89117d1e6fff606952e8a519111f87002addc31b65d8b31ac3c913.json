{
  "sources": [
    "raw.accounts",
    "raw.checking",
    "raw.savings"
  ],
  "staging_models": [
    "stg_accounts",
    "stg_checking",
    "stg_savings"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_customer_balances",
    "type": "report",
    "grain": "1 row per customer name"
  },
  "ctes": [
    "stg_accounts",
    "stg_checking",
    "stg_savings"
  ],
  "joins": [
    {
      "left": "stg_accounts",
      "right": "stg_checking",
      "on": "custid"
    },
    {
      "left": "stg_accounts",
      "right": "stg_savings",
      "on": "custid"
    }
  ],
  "tests": {
    "balance_checking": [
      "not_null"
    ],
    "balance_savings": [
      "not_null"
    ],
    "customer_name": [
      "not_null"
    ]
  }
}