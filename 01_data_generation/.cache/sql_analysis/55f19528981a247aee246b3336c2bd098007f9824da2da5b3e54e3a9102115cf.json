{
  "tables": [
    "CAR_NAMES",
    "MODEL_LIST",
    "CAR_MAKERS",
    "CARS_DATA"
  ],
  "joins": [
    {
      "left_table": "CAR_NAMES",
      "right_table": "MODEL_LIST",
      "condition": "T1.Model = T2.Model"
    },
    {
      "left_table": "MODEL_LIST",
      "right_table": "CAR_MAKERS",
      "condition": "T2.Maker = T3.Id"
    },
    {
      "left_table": "CAR_NAMES",
      "right_table": "CARS_DATA",
      "condition": "T1.MakeId = T4.Id"
    }
  ],
  "filters": [
    "T3.FullName = 'General Motors'",
    "T4.weight > 3500"
  ],
  "select_columns": [
    "DISTINCT T2.Model"
  ],
  "has_distinct": true,
  "grain": "T2.Model",
  "model_type": "report"
}