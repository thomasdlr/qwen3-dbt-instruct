{
  "tables": [
    "salary",
    "player",
    "team"
  ],
  "joins": [
    {
      "left_table": "salary",
      "right_table": "player",
      "condition": "T1.player_id = T2.player_id"
    },
    {
      "left_table": "team",
      "right_table": "salary",
      "condition": "T3.team_id_br = T1.team_id"
    }
  ],
  "filters": [
    "T1.year = 2005",
    "T3.name = 'Washington Nationals'",
    "T1.year = 2007",
    "T3.name = 'Washington Nationals'"
  ],
  "select_columns": [
    "T2.name_first",
    "T2.name_last"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "grain": "T2.name_first, T2.name_last",
  "model_type": "report"
}