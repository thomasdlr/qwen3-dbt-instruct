{
  "tables": [
    "customers",
    "customer_orders",
    "order_items",
    "products"
  ],
  "joins": [
    {
      "left_table": "customers",
      "right_table": "customer_orders",
      "condition": "t1.customer_id = t2.customer_id"
    },
    {
      "left_table": "customer_orders",
      "right_table": "order_items",
      "condition": "t2.order_id = t3.order_id"
    },
    {
      "left_table": "order_items",
      "right_table": "products",
      "condition": "t3.product_id = t4.product_id"
    }
  ],
  "filters": [
    "t4.product_details = 'Latte'",
    "t4.product_details = 'Americano'"
  ],
  "select_columns": [
    "t1.customer_name",
    "t1.customer_name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_subquery": false,
  "grain": "customer_name",
  "model_type": "report"
}