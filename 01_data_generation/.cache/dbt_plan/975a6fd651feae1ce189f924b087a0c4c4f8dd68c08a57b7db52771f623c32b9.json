{
  "sources": [
    "raw.Invoices",
    "raw.Orders"
  ],
  "staging_models": [
    "stg_Invoices",
    "stg_Orders"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_order_invoices",
    "type": "fact",
    "grain": "1 row per order_id"
  },
  "ctes": [
    "stg_Orders",
    "stg_Invoices"
  ],
  "joins": [
    {
      "left": "stg_Orders",
      "right": "stg_Invoices",
      "on": "order_id = order_id"
    }
  ],
  "tests": {
    "order_id": [
      "not_null",
      "unique"
    ],
    "order_details": [
      "not_null"
    ]
  }
}