{
  "sources": [
    "raw.department",
    "raw.management",
    "raw.head"
  ],
  "staging_models": [
    "stg_department",
    "stg_management",
    "stg_head"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_alabama_managers",
    "type": "report",
    "grain": "1 row per T1.creation"
  },
  "ctes": [
    "stg_department",
    "stg_management",
    "stg_head"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_management",
      "on": "T1.department_id = T2.department_id"
    },
    {
      "left": "stg_management",
      "right": "stg_head",
      "on": "T2.head_id = T3.head_id"
    }
  ],
  "tests": {
    "creation": [
      "not_null"
    ]
  }
}