{
  "sources": [
    "raw.customers",
    "raw.customers_policies"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customers_policies"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_customers_with_policies",
    "type": "report",
    "grain": "1 row per customer policy where customer name contains 'Diana'"
  },
  "ctes": [
    "stg_customers",
    "stg_customers_policies"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customers_policies",
      "on": "customer_id"
    }
  ],
  "tests": {
    "customer_id": [
      "not_null"
    ],
    "customer_name": [
      "not_null"
    ],
    "policy_id": [
      "not_null"
    ]
  }
}