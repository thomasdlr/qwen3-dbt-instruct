{
  "sources": [
    "raw.Products",
    "raw.Events"
  ],
  "staging_models": [
    "stg_Products",
    "stg_Events"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_events_count",
    "type": "report",
    "grain": "1 row per Product_Name"
  },
  "ctes": [
    "stg_Products",
    "stg_Events"
  ],
  "joins": [
    {
      "left": "stg_Products",
      "right": "stg_Events",
      "on": "Product_ID = Events.Product_ID"
    }
  ],
  "tests": {
    "Product_Name": [
      "not_null"
    ]
  }
}