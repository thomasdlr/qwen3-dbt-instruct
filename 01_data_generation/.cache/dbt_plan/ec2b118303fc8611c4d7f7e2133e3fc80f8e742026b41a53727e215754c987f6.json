{
  "sources": [
    "raw.claims",
    "raw.settlements"
  ],
  "staging_models": [
    "stg_claims",
    "stg_settlements"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_claim_settlement_metrics",
    "type": "fact",
    "grain": "1 row per claim_id"
  },
  "ctes": [
    "stg_claims",
    "stg_settlements"
  ],
  "joins": [
    {
      "left": "stg_claims",
      "right": "stg_settlements",
      "on": "stg_claims.claim_id = stg_settlements.claim_id"
    }
  ],
  "tests": {
    "claim_id": [
      "not_null"
    ],
    "date_claim_made": [
      "not_null"
    ],
    "count_star": [
      "not_null"
    ]
  }
}