{
  "tables": [
    "races",
    "results",
    "drivers"
  ],
  "joins": [
    {
      "left_table": "races",
      "right_table": "results",
      "condition": "T1.raceid = T2.raceid"
    },
    {
      "left_table": "results",
      "right_table": "drivers",
      "condition": "T2.driverid = T3.driverid"
    }
  ],
  "filters": [
    "T1.name = \"Australian Grand Prix\"",
    "T1.name = \"Chinese Grand Prix\""
  ]
}