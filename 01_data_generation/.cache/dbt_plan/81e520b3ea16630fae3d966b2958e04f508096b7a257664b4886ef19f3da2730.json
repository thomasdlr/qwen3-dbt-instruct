{
  "sources": [
    "raw.countries",
    "raw.car_makers"
  ],
  "staging_models": [
    "stg_countries",
    "stg_car_makers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_country_car_makers",
    "type": "report",
    "grain": "1 row per countryid"
  },
  "ctes": [
    "stg_countries",
    "stg_car_makers"
  ],
  "joins": [
    {
      "left": "stg_countries",
      "right": "stg_car_makers",
      "on": "countryid = country"
    }
  ],
  "tests": {
    "countryid": [
      "not_null"
    ],
    "countryname": [
      "not_null"
    ]
  }
}