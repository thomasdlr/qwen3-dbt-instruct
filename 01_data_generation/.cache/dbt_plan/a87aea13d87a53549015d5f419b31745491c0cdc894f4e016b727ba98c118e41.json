{
  "sources": [
    "raw.railway",
    "raw.train"
  ],
  "staging_models": [
    "stg_railway",
    "stg_train"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_railway_train_counts",
    "type": "report",
    "grain": "1 row per Railway_ID"
  },
  "ctes": [
    "stg_railway",
    "stg_train"
  ],
  "joins": [
    {
      "left": "stg_railway",
      "right": "stg_train",
      "on": "stg_railway.Railway_ID = stg_train.Railway_ID"
    }
  ],
  "tests": {
    "Railway_ID": [
      "not_null",
      "unique"
    ],
    "Builder": [
      "not_null"
    ]
  }
}