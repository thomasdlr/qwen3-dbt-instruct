{
  "sources": [
    "raw.Sportsinfo",
    "raw.Student"
  ],
  "staging_models": [
    "stg_Sportsinfo",
    "stg_Student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_students_on_scholarship",
    "type": "report",
    "grain": "1 row per Lname"
  },
  "ctes": [
    "stg_Sportsinfo",
    "stg_Student"
  ],
  "joins": [
    {
      "left": "stg_Sportsinfo",
      "right": "stg_Student",
      "on": "T1.StuID = T2.StuID"
    }
  ],
  "tests": {
    "Lname": [
      "not_null"
    ]
  }
}