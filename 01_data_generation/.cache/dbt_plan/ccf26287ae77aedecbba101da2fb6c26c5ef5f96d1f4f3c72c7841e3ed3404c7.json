{
  "sources": [
    "raw.class",
    "raw.enroll",
    "raw.student",
    "raw.course"
  ],
  "staging_models": [
    "stg_class",
    "stg_enroll",
    "stg_student",
    "stg_course"
  ],
  "intermediate_models": [
    "int_class_enrollment"
  ],
  "mart_model": {
    "name": "rpt_smithson_class_course",
    "type": "report",
    "grain": "1 row per class_code, crs_code"
  },
  "ctes": [
    "stg_class",
    "stg_enroll",
    "stg_student",
    "stg_course"
  ],
  "joins": [
    {
      "left": "stg_class",
      "right": "stg_enroll",
      "on": "class.class_code = enroll.class_code"
    },
    {
      "left": "stg_enroll",
      "right": "stg_student",
      "on": "student.stu_num = enroll.stu_num"
    },
    {
      "left": "stg_class",
      "right": "stg_course",
      "on": "course.crs_code = class.crs_code"
    }
  ],
  "tests": {
    "crs_description": [
      "not_null"
    ],
    "crs_credit": [
      "not_null"
    ]
  }
}