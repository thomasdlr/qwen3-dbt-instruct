{
  "sources": [
    "raw.accounts",
    "raw.savings"
  ],
  "staging_models": [
    "stg_accounts",
    "stg_savings"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_customer_savings",
    "type": "report",
    "grain": "1 row per T1.custid"
  },
  "ctes": [
    "stg_accounts",
    "stg_savings"
  ],
  "joins": [
    {
      "left": "stg_accounts",
      "right": "stg_savings",
      "on": "stg_accounts.custid = stg_savings.custid"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "balance": [
      "not_null"
    ]
  }
}