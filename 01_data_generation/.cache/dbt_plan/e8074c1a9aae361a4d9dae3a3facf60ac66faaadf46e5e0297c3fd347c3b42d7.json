{
  "sources": [
    "raw.vocals",
    "raw.songs"
  ],
  "staging_models": [
    "stg_vocals",
    "stg_songs"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_shared_song_titles",
    "type": "report",
    "grain": "1 row per shared song title"
  },
  "ctes": [
    "stg_vocals",
    "stg_songs"
  ],
  "joins": [
    {
      "left": "stg_vocals",
