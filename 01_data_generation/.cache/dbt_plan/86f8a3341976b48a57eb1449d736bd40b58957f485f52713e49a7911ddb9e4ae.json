{
  "sources": [
    "raw.students",
    "raw.student_course_registrations"
  ],
  "staging_models": [
    "stg_students",
    "stg_student_course_registrations"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_student_course_registrations",
    "type": "fact",
    "grain": "1 row per student_id"
  },
  "ctes": [
    "stg_students",
    "stg_student_course_registrations"
  ],
  "joins": [
    {
      "left": "stg_students",
      "right": "stg_student_course_registrations",
      "on": "student_id = student_id"
    }
  ],
  "tests": {
    "student_id": [
      "not_null",
      "unique"
    ],
    "student_details": [
      "not_null"
    ]
  }
}