{
  "tables": [
    "aircraft",
    "airport_aircraft",
    "airport"
  ],
  "joins": [
    {
      "left_table": "T1",
      "right_table": "T2",
      "condition": "T1.Aircraft_ID = T2.Aircraft_ID"
    },
    {
      "left_table": "T2",
      "right_table": "T3",
      "condition": "T2.Airport_ID = T3.Airport_ID"
    }
  ],
  "filters": [
    "T3.Airport_Name = \"London Gatwick\""
  ],
  "select_columns": [
    "T1.Aircraft"
  ],
  "grain": "aircraft.Aircraft",
  "model_type": "report"
}