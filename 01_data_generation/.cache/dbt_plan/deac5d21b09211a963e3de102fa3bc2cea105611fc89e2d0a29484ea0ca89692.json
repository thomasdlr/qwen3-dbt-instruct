{
  "sources": [
    "raw.station_company",
    "raw.company",
    "raw.gas_station"
  ],
  "staging_models": [
    "stg_station_company",
    "stg_company",
    "stg_gas_station"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_exxonmobil_manager_by_station",
    "type": "report",
    "grain": "1 row per station_id"
  },
  "ctes": [
    "stg_station_company",
    "stg_company",
    "stg_gas_station"
  ],
  "joins": [
    {
      "left": "stg_station_company",
      "right": "stg_company",
      "on": "station_company.company_id = company.company_id"
    },
    {
      "left": "stg_station_company",
      "right": "stg_gas_station",
      "on": "station_company.station_id = gas_station.station_id"
    }
  ],
  "tests": {
    "manager_name": [
      "not_null"
    ]
  }
}