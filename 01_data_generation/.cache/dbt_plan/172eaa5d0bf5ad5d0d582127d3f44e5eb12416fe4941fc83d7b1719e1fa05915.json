{
  "sources": [
    "raw.record",
    "raw.event",
    "raw.stadium"
  ],
  "staging_models": [
    "stg_record",
    "stg_event",
    "stg_stadium"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_stadium_event_count",
    "type": "report",
    "grain": "1 row per stadium"
  },
  "ctes": [
    "stg_record",
    "stg_event",
    "stg_stadium"
  ],
  "joins": [
    {
      "left": "stg_record",
      "right": "stg_event",
      "on": "event_id = id"
    },
    {
      "left": "stg_event",
      "right": "stg_stadium",
      "on": "stadium_id = id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}