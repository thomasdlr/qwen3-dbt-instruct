{
  "tables": [
    "employee",
    "professor",
    "department"
  ],
  "joins": [
    {
      "left_table": "employee",
      "right_table": "professor",
      "condition": "T1.emp_num = T2.emp_num"
    },
    {
      "left_table": "professor",
      "right_table": "department",
      "condition": "T2.dept_code = T3.dept_code"
    }
  ],
  "filters": [
    "T3.dept_name = 'History'"
  ],
  "select_columns": [
    "T1.emp_fname"
  ],
  "set_operations": [
    "EXCEPT"
  ],
  "has_distinct": false,
  "has_subquery": true,
  "has_window_fn": false,
  "grain": "T1.emp_fname",
  "model_type": "report"
}