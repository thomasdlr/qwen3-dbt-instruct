{
  "tables": [
    "Person",
    "PersonFriend"
  ],
  "joins": [
    {
      "left_table": "T1 (Person)",
      "right_table": "T2 (PersonFriend)",
      "condition": "T1.name = T2.friend"
    }
  ],
  "filters": [
    "T2.name = 'Alice'",
    "T1.gender = 'female'"
  ],
  "select_columns": [
    "T2.friend"
  ],
  "grain": "Person.name",
  "model_type": "report"
}