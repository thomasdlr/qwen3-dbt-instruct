{
  "sources": [
    "raw.customers",
    "raw.customer_orders",
    "raw.order_items"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_customer_orders",
    "type": "dimension",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customer_orders",
      "on": "customers.customer_id = customer_orders.customer_id"
    },
    {
      "left": "stg_customer_orders",
      "right": "stg_order_items",
      "on": "customer_orders.order_id = order_items.order_id"
    }
  ],
  "tests": {
    "customer_name": [
      "not_null"
    ],
    "customer_phone": [
      "not_null"
    ]
  }
}