{
  "sources": [
    "raw.product_suppliers",
    "raw.products"
  ],
  "staging_models": [
    "stg_product_suppliers",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_product_suppliers",
    "type": "dimension",
    "grain": "1 row per products.product_id"
  },
  "ctes": [
    "stg_product_suppliers",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_product_suppliers",
      "right": "stg_products",
      "on": "T1.product_id = T2.product_id"
    }
  ],
  "tests": {
    "product_type_code": [
      "not_null"
    ],
    "product_name": [
      "not_null"
    ],
    "product_price": [
      "not_null"
    ]
  }
}