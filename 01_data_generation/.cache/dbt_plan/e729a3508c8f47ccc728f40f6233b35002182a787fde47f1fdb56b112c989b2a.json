    "stg_Customers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_customers_with_multiple_cards",
    "type": "dimension",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_Customers_cards",
    "stg_Customers"
  ],
  "joins": [
    {
      "left": "stg_Customers_cards",
      "right": "stg_Customers",
      "on": "stg_Customers_cards.customer_id = stg_Customers.customer_id"
    }
  ],
  "tests": {
    "customer_id": [
      "not_null",
      "unique"
    ],
    "customer_first_name": [
      "not_null"
    ],
    "customer_last_name": [
      "not_null"
    ]
  }
}