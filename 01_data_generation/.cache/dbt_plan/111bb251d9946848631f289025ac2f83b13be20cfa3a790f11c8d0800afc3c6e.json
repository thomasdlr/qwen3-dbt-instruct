{
  "sources": [
    "raw.semesters",
    "raw.student_enrolment"
  ],
  "staging_models": [
    "stg_semesters",
    "stg_student_enrolment"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_semester_enrolment_counts",
    "type": "fact",
    "grain": "1 row per semester_id"
  },
  "ctes": [
    "stg_semesters",
    "stg_student_enrolment"
  ],
  "joins": [
    {
      "left": "stg_semesters",
      "right": "stg_student_enrolment",
      "on": "stg_semesters.semester_id = stg_student_enrolment.semester_id"
    }
  ],
  "tests": {
    "semester_name": [
      "not_null"
    ],
    "semester_id": [
      "not_null"
    ]
  }
}