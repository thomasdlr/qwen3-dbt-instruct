{
  "sources": [
    "raw.advisor",
    "raw.student"
  ],
  "staging_models": [
    "stg_advisor",
    "stg_student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_student",
    "type": "dimension",
    "grain": "1 row per student"
  },
  "ctes": [
    "stg_advisor",
    "stg_student"
  ],
  "joins": [
    {
      "left": "stg_advisor",
      "right": "stg_student",
      "on": "stg_advisor.s_id = stg_student.id"
    }
  ],
  "tests": {
    "i_id": [
      "not_null"
    ]
  }
}