{
  "sources": [
    "raw.budget",
    "raw.school"
  ],
  "staging_models": [
    "stg_budget",
    "stg_school"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_school_budget",
    "type": "fact",
    "grain": "1 row per school_id"
  },
  "ctes": [
    "stg_budget",
    "stg_school"
  ],
  "joins": [
    {
      "left": "stg_budget",
      "right": "stg_school",
      "on": "stg_budget.school_id = stg_school.school_id"
    }
  ],
  "tests": {
    "SUM(budgeted)": [
      "not_null"
    ]
  }
}