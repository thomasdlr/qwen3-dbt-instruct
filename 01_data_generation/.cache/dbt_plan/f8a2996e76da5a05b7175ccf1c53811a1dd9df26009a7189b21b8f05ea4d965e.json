{
  "sources": [
    "raw.physician",
    "raw.trained_in",
    "raw.procedures"
  ],
  "staging_models": [
    "stg_physician",
    "stg_trained_in",
    "stg_procedures"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_physician_procedures",
    "type": "report",
    "grain": "1 row per physician.employeeid, trained_in.treatment"
  },
  "ctes": [
    "stg_physician",
    "stg_trained_in",
    "stg_procedures"
  ],
  "joins": [
    {
      "left": "stg_physician",
      "right": "stg_trained_in",
      "on": "employeeid = physician"
    },
    {
      "left": "stg_procedures",
      "right": "stg_trained_in",
      "on": "code = treatment"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}