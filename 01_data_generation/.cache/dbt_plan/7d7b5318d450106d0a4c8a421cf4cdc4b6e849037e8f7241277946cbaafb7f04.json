{
  "sources": [
    "raw.Employee",
    "raw.Certificate",
    "raw.Aircraft"
  ],
  "staging_models": [
    "stg_Employee",
    "stg_Certificate",
    "stg_Aircraft"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_employee_certificate_count",
    "type": "report",
    "grain": "1 row per Employee"
  },
  "ctes": [
    "stg_Employee",
    "stg_Certificate",
    "stg_Aircraft"
  ],
  "joins": [
    {
      "left": "stg_Employee",
      "right": "stg_Certificate",
      "on": "eid = eid"
    },
    {
      "left": "stg_Aircraft",
      "right": null,
      "on": "aid = aid"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "eid": [
      "not_null",
      "unique"
    ]
  }
}