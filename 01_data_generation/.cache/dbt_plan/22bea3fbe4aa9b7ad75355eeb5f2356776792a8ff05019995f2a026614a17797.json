{
  "sources": [
    "raw.students",
    "raw.student_addresses"
  ],
  "staging_models": [
    "stg_students",
    "stg_student_addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_mobile_numbers",
    "type": "report",
    "grain": "1 row per student"
  },
  "ctes": [
    "stg_student_addresses",
    "stg_students"
  ],
  "joins": [
    {
      "left": "stg_student_addresses",
      "right": "stg_students",
      "on": "student_id = student_id"
    }
  ],
  "tests": {
    "cell_mobile_number": [
      "not_null"
    ]
  }
}