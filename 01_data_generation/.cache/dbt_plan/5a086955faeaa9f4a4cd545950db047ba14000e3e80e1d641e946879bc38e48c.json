{
  "sources": [
    "raw.addresses",
    "raw.people_addresses",
    "raw.students"
  ],
  "staging_models": [
    "stg_addresses",
    "stg_people_addresses",
    "stg_students"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_addresses_city",
    "type": "dimension",
    "grain": "1 row per addresses.city"
  },
  "ctes": [
    "stg_addresses",
    "stg_people_addresses",
    "stg_students"
  ],
  "joins": [
    {
      "left": "stg_addresses",
      "right": "stg_people_addresses",
      "on": "address_id = address_id"
    },
    {
      "left": "stg_people_addresses",
      "right": "stg_students",
      "on": "person_id = student_id"
    }
  ],
  "tests": {
    "city": [
      "not_null"
    ]
  }
}