{
  "sources": [
    "raw.course",
    "raw.enrolled_in"
  ],
  "staging_models": [
    "stg_course",
    "stg_enrolled_in"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_course_enrollment_count",
    "type": "fact",
    "grain": "1 row per course"
  },
  "ctes": [
    "stg_course",
    "stg_enrolled_in"
  ],
  "joins": [
    {
      "left": "stg_course",
      "right": "stg_enrolled_in",
      "on": "stg_course.cid = stg_enrolled_in.cid"
    }
  ],
  "tests": {
    "cid": [
      "not_null",
      "unique"
    ],
    "cname": [
      "not_null"
    ]
  }
}