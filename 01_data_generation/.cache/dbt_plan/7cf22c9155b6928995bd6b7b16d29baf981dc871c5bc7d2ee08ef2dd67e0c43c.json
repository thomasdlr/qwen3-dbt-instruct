{
  "sources": [
    "raw.CLASS",
    "raw.enroll",
    "raw.course",
    "raw.department"
  ],
  "staging_models": [
    "stg_CLASS",
    "stg_enroll",
    "stg_course",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_department_class_summary",
    "type": "report",
    "grain": "1 row per department"
  },
  "ctes": [
    "stg_CLASS",
    "stg_enroll",
    "stg_course",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_CLASS",
      "right": "stg_enroll",
      "on": "class.class_code = enroll.class_code"
    },
    {
      "left": "stg_CLASS",
      "right": "stg_course",
      "on": "class.crs_code = course.crs_code"
    },
    {
      "left": "stg_course",
      "right": "stg_department",
      "on": "course.dept_code = department.dept_code"
    }
  ],
  "tests": {
    "dept_name": [
      "not_null"
    ]
  }
}