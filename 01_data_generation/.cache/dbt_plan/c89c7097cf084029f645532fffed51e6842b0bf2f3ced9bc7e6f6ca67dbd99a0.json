{
  "sources": [
    "raw.city",
    "raw.temperature"
  ],
  "staging_models": [
    "stg_city",
    "stg_temperature"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_city_temperature_diff",
    "type": "report",
    "grain": "1 row per city.city_id"
  },
  "ctes": [
    "stg_city",
    "stg_temperature"
  ],
  "joins": [
    {
      "left": "stg_city",
      "right": "stg_temperature",
      "on": "city.city_id = temperature.city_id"
    }
  ],
  "tests": {
    "city": [
      "not_null"
    ]
  }
}