{
  "tables": [
    "authors",
    "authorship",
    "papers"
  ],
  "joins": [
    {
      "left_table": "authors",
      "right_table": "authorship",
      "condition": "t1.authid = t2.authid"
    },
    {
      "left_table": "authorship",
      "right_table": "papers",
      "condition": "t2.paperid = t3.paperid"
    }
  ],
  "filters": [
    "t1.fname = \"Atsushi\"",
    "t1.lname = \"Ohori\""
  ]
}