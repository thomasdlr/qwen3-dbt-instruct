{
  "sources": [
    "raw.employees",
    "raw.circulation_history"
  ],
  "staging_models": [
    "stg_employees",
    "stg_circulation_history"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_circulation_employee",
    "type": "fact",
    "grain": "1 row per Circulation_History.document_id, Circulation_History.draft_number, Circulation_History.copy_number"
  },
  "ctes": [
    "stg_circulation_history",
    "stg_employees"
  ],
  "joins": [
    {
      "left": "stg_circulation_history",
      "right": "stg_employees",
      "on": "stg_circulation_history.employee_id = stg_employees.employee_id"
    }
  ],
  "tests": {
    "employee_name": [
      "not_null"
    ],
    "count_star": [
      "not_null"
    ]
  }
}