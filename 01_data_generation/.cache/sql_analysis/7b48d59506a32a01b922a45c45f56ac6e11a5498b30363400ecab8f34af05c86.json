{
  "tables": [
    "problems",
    "product",
    "staff"
  ],
  "joins": [
    {
      "left_table": "problems",
      "right_table": "product",
      "condition": "T1.product_id = T2.product_id"
    },
    {
      "left_table": "problems",
      "right_table": "staff",
      "condition": "T1.reported_by_staff_id = T3.staff_id"
    }
  ],
  "filters": [
    "T3.staff_first_name = \"Lacey\"",
    "T3.staff_last_name = \"Bosco\""
  ],
  "select_columns": [
    "T2.product_name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T2.product_name",
  "model_type": "report"
}