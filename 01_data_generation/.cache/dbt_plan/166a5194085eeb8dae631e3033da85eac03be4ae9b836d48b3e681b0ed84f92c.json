{
  "sources": [
    "raw.suppliers",
    "raw.supplier_addresses",
    "raw.addresses"
  ],
  "staging_models": [
    "stg_suppliers",
    "stg_supplier_addresses",
    "stg_addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_supplier_addresses",
    "type": "dimension",
    "grain": "1 row per supplier_id, address_id"
  },
  "ctes": [
    "stg_suppliers",
    "stg_supplier_addresses",
    "stg_addresses"
  ],
  "joins": [
    {
      "left": "stg_suppliers",
      "right": "stg_supplier_addresses",
      "on": "supplier_id = supplier_id"
    },
    {
      "left": "stg_supplier_addresses",
      "right": "stg_addresses",
      "on": "address_id = address_id"
    }
  ],
  "tests": {
    "supplier_name": [
      "not_null"
    ],
    "supplier_phone": [
      "not_null"
    ]
  }
}