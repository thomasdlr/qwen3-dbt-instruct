{
  "sources": [
    "raw.department",
    "raw.professor"
  ],
  "staging_models": [
    "stg_department",
    "stg_professor"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_school_professor_count",
    "type": "fact",
    "grain": "1 row per school_code"
  },
  "ctes": [
    "stg_department",
    "stg_professor"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_professor",
      "on": "stg_department.dept_code = stg_professor.dept_code"
    }
  ],
  "tests": {
    "school_code": [
      "not_null"
    ]
  }
}