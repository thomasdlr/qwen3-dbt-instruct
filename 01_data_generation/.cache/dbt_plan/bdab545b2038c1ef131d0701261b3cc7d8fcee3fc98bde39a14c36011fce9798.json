{
  "sources": [
    "raw.museum",
    "raw.visit"
  ],
  "staging_models": [
    "stg_museum",
    "stg_visit"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_museum_visits",
    "type": "report",
    "grain": "1 row per Museum_ID"
  },
  "ctes": [
    "stg_museum",
    "stg_visit"
  ],
  "joins": [
    {
      "left": "stg_museum",
      "right": "stg_visit",
      "on": "stg_museum.Museum_ID = stg_visit.Museum_ID"
    }
  ],
  "tests": {
    "Museum_ID": [
      "not_null",
      "unique"
    ],
    "name": [
      "not_null"
    ]
  }
}