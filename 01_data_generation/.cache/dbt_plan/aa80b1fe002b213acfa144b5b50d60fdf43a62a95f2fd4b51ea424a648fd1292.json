{
  "sources": [
    "raw.student",
    "raw.voting_record"
  ],
  "staging_models": [
    "stg_student",
    "stg_voting_record"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_presidential_votes",
    "type": "report",
    "grain": "1 row per student last name"
  },
  "ctes": [
    "stg_student",
    "stg_voting_record"
  ],
  "joins": [
    {
      "left": "stg_student",
      "right": "stg_voting_record",
      "on": "stg_student.StuID = stg_voting_record.CLASS_President_VOTE"
    }
  ],
  "tests": {
    "LName": [
      "not_null"
    ]
  }
}