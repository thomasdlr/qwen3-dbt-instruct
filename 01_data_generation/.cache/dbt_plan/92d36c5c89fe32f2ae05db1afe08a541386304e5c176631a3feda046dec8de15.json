{
  "sources": [
    "raw.country",
    "raw.countrylanguage"
  ],
  "staging_models": [
    "stg_country",
    "stg_countrylanguage"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_languages_by_beatrix",
    "type": "report",
    "grain": "1 row per Language"
  },
  "ctes": [
    "stg_country",
    "stg_countrylanguage"
  ],
  "joins": [
    {
      "left": "stg_country",
      "right": "stg_countrylanguage",
      "on": "T1.Code = T2.CountryCode"
    }
  ],
  "tests": {
    "Language": [
      "not_null"
    ]
  }
}