{
  "sources": [
    "raw.first_notification_of_loss",
    "raw.services"
  ],
  "staging_models": [
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_service_loss_counts",
    "type": "report",
    "grain": "1 row per service_id"
  },
  "ctes": [
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "joins": [
    {
      "left": "stg_first_notification_of_loss",
      "right": "stg_services",
      "on": "t1.service_id = t2.service_id"
    }
  ],
  "tests": {
    "service_name": [
      "not_null"
    ],
    "service_id": [
      "not_null"
    ]
  }
}