{
  "tables": [
    "member_attendance",
    "member",
    "performance"
  ],
  "joins": [
    {
      "left_table": "member_attendance",
      "right_table": "member",
      "condition": "T1.Member_ID = T2.Member_ID"
    },
    {
      "left_table": "member_attendance",
      "right_table": "performance",
      "condition": "T1.Performance_ID = T3.Performance_ID"
    }
  ],
  "filters": [
    "T2.Role = \"Violin\""
  ],
  "select_columns": [
    "T3.Date"
  ],
  "has_subquery": false,
  "grain": "performance.Date",
  "model_type": "report"
}