{
  "sources": [
    "raw.region",
    "raw.party",
    "raw.party_events"
  ],
  "staging_models": [
    "stg_region",
    "stg_party",
    "stg_party_events"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_uk_annual_meeting_count",
    "type": "report",
    "grain": "1 row per region.region_id"
  },
  "ctes": [
    "stg_region",
    "stg_party",
    "stg_party_events"
  ],
  "joins": [
    {
      "left": "stg_region",
      "right": "stg_party",
      "on": "region_id = party.region_id"
    },
    {
      "left": "stg_party",
      "right": "stg_party_events",
      "on": "party.party_id = party_events.party_id"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ]
  }
}