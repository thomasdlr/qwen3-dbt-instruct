{
  "sources": [
    "raw.budget",
    "raw.school",
    "raw.endowment"
  ],
  "staging_models": [
    "stg_budget",
    "stg_school",
    "stg_endowment"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_school_budget_endowment",
    "type": "report",
    "grain": "1 row per school_name"
  },
  "ctes": [
    "stg_budget",
    "stg_school",
    "stg_endowment"
  ],
  "joins": [
    {
      "left": "stg_budget",
      "right": "stg_school",
      "on": "budget.school_id = school.school_id"
    },
    {
      "left": "stg_school",
      "right": "stg_endowment",
      "on": "school.school_id = endowment.school_id"
    }
  ],
  "tests": {
    "school_name": [
      "not_null"
    ]
  }
}