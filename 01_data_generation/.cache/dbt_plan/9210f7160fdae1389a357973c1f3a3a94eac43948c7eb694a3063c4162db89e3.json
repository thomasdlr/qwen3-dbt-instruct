{
  "sources": [
    "raw.countries",
    "raw.continents",
    "raw.car_makers"
  ],
  "staging_models": [
    "stg_countries",
    "stg_continents",
    "stg_car_makers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_european_car_makers",
    "type": "fact",
    "grain": "1 row per country"
  },
  "ctes": [
    "stg_countries",
    "stg_continents",
    "stg_car_makers"
  ],
  "joins": [
    {
      "left": "stg_countries",
      "right": "stg_continents",
      "on": "stg_countries.Continent = stg_continents.ContId"
    },
    {
      "left": "stg_countries",
      "right": "stg_car_makers",
      "on": "stg_countries.CountryId = stg_car_makers.Country"
    }
  ],
  "tests": {
    "CountryName": [
      "not_null"
    ]
  }
}