{
  "sources": [
    "raw.investors",
    "raw.transactions"
  ],
  "staging_models": [
    "stg_investors",
    "stg_transactions"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_investor_transactions",
    "type": "dimension",
    "grain": "1 row per investor_id"
  },
  "ctes": [
    "stg_investors",
    "stg_transactions"
  ],
  "joins": [
    {
      "left": "stg_investors",
      "right": "stg_transactions",
      "on": "investor_id = investor_id"
    }
  ],
  "tests": {
    "investor_details": [
      "not_null"
    ]
  }
}