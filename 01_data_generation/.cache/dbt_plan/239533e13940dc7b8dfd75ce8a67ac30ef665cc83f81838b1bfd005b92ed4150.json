{
  "sources": [
    "raw.products",
    "raw.ref_colors"
  ],
  "staging_models": [
    "stg_products",
    "stg_ref_colors"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_white_products",
    "type": "fact",
    "grain": "1 row per product with white color"
  },
  "ctes": [
    "stg_products",
    "stg_ref_colors"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_ref_colors",
      "on": "stg_products.color_code = stg_ref_colors.color_code"
    }
  ],
  "tests": {
    "<all_columns>": [
      "not_null"
    ]
  }
}