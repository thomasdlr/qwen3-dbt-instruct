{
  "tables": [
    "tryout",
    "player"
  ],
  "joins": [
    {
      "left_table": "tryout",
      "right_table": "player",
      "condition": "T1.pID = T2.pID"
    }
  ],
  "filters": [
    "T1.cName = (SELECT cName FROM college ORDER BY enr DESC LIMIT 1)"
  ],
  "select_columns": [
    "T2.pName"
  ],
  "grain": "player.pID",
  "model_type": "report"
}