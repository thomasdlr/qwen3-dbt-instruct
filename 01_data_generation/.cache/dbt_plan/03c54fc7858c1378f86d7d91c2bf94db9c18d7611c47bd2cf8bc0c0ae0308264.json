{
  "sources": [
    "raw.book",
    "raw.publication"
  ],
  "staging_models": [
    "stg_book",
    "stg_publication"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_book_publication",
    "type": "fact",
    "grain": "1 row per book"
  },
  "ctes": [
    "stg_book",
    "stg_publication"
  ],
  "joins": [
    {
      "left": "stg_book",
      "right": "stg_publication",
      "on": "stg_book.book_id = stg_publication.book_id"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ],
    "publication_date": [
      "not_null"
    ]
  }
}