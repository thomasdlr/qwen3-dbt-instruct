{
  "sources": [
    "raw.MODEL_LIST",
    "raw.CAR_NAMES",
    "raw.CARS_DATA"
  ],
  "staging_models": [
    "stg_MODEL_LIST",
    "stg_CAR_NAMES",
    "stg_CARS_DATA"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_model_catalog",
    "type": "dimension",
    "grain": "1 row per model"
  },
  "ctes": [
    "stg_MODEL_LIST",
    "stg_CAR_NAMES",
    "stg_CARS_DATA"
  ],
  "joins": [
    {
      "left": "stg_MODEL_LIST",
      "right": "stg_CAR_NAMES",
      "on": "model = model"
    },
    {
      "left": "stg_CAR_NAMES",
      "right": "stg_CARS_DATA",
      "on": "MakeId = id"
    }
  ],
  "tests": {
    "model": [
      "not_null",
      "unique"
    ]
  }
}