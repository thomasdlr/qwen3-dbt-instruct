{
  "sources": [
    "raw.department",
    "raw.management",
    "raw.head"
  ],
  "staging_models": [
    "stg_department",
    "stg_management",
    "stg_head"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_treasury_heads_by_state",
    "type": "report",
    "grain": "1 row per head's birth state"
  },
  "ctes": [
    "stg_department",
    "stg_management",
    "stg_head"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_management",
      "on": "department_id = department_id"
    },
    {
      "left": "stg_management",
      "right": "stg_head",
      "on": "head_id = head_id"
    }
  ],
  "tests": {
    "born_state": [
      "not_null"
    ]
  }
}