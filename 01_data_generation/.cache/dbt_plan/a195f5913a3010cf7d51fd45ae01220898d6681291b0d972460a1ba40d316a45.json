{
  "sources": [
    "raw.problems",
    "raw.product",
    "raw.staff"
  ],
  "staging_models": [
    "stg_problems",
    "stg_product",
    "stg_staff"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_lacey_bosco_products",
    "type": "report",
    "grain": "1 row per product_name"
  },
  "ctes": [
    "stg_product",
    "stg_staff"
  ],
  "joins": [
    {
      "left": "stg_product",
      "right": "stg_staff",
      "on": "product_id = staff_id"
    },
    {
      "left": "problems",
      "right": "stg_product",
      "on": "product_id = product_id"
    },
    {
      "left": "problems",
      "right": "stg_staff",
      "on": "reported_by_staff_id = staff_id"
    }
  ],
  "tests": {
    "product_name": [
      "not_null"
    ]
  }
}