{
  "sources": [
    "raw.tasks",
    "raw.projects",
    "raw.project_outcomes"
  ],
  "staging_models": [
    "stg_tasks",
    "stg_projects",
    "stg_project_outcomes"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_projects_with_tasks",
    "type": "report",
    "grain": "1 row per project_id"
  },
  "ctes": [
    "stg_tasks",
    "stg_projects"
  ],
  "joins": [
    {
      "left": "stg_tasks",
      "right": "stg_projects",
      "on": "stg_tasks.project_id = stg_projects.project_id"
    },
    {
      "left": "stg_projects",
      "right": "stg_project_outcomes",
      "on": "stg_projects.project_id = stg_project_outcomes.project_id"
    }
  ],
  "tests": {
    "task_details": [
      "not_null"
    ],
    "task_id": [
      "not_null"
    ],
    "project_id": [
      "not_null"
    ]
  }
}