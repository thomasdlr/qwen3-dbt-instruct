{
  "sources": [
    "raw.Country",
    "raw.League"
  ],
  "staging_models": [
    "stg_Country",
    "stg_League"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_Country_League",
    "type": "report",
    "grain": "1 row per Country.name, League.name"
  },
  "ctes": [
    "stg_Country",
    "stg_League"
  ],
  "joins": [
    {
      "left": "stg_Country",
      "right": "stg_League",
      "on": "Country.id = League.country_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "League.name": [
      "not_null"
    ]
  }
}