{
  "sources": [
    "raw.albums",
    "raw.artists"
  ],
  "staging_models": [
    "stg_albums",
    "stg_artists"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_aerosmith_albums",
    "type": "report",
    "grain": "1 row per album.title"
  },
  "ctes": [
    "stg_albums",
    "stg_artists"
  ],
  "joins": [
    {
      "left": "stg_albums",
      "right": "stg_artists",
      "on": "stg_albums.artist_id = stg_artists.id"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ]
  }
}