{
  "sources": [
    "raw.user_profiles",
    "raw.tweets"
  ],
  "staging_models": [
    "stg_user_profiles",
    "stg_tweets"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_tweets_by_user",
    "type": "report",
    "grain": "1 row per user"
  },
  "ctes": [
    "stg_user_profiles",
    "stg_tweets"
  ],
  "joins": [
    {
      "left": "stg_user_profiles",
      "right": "stg_tweets",
      "on": "stg_user_profiles.uid = stg_tweets.uid"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "uid": [
      "not_null",
      "unique"
    ]
  }
}