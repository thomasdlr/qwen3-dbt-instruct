{
  "tables": [
    "Grants",
    "Documents",
    "Document_Types"
  ],
  "joins": [
    {
      "left_table": "Grants",
      "right_table": "Documents",
      "condition": "T1.grant_id = T2.grant_id"
    },
    {
      "left_table": "Documents",
      "right_table": "Document_Types",
      "condition": "T2.document_type_code = T3.document_type_code"
    }
  ],
  "filters": [
    "T3.document_description = 'Regular'",
    "T3.document_description = 'Initial Application'"
  ],
  "select_columns": [
    "T1.grant_start_date",
    "T1.grant_start_date"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "grain": "T1.grant_start_date",
  "model_type": "report"
}