{
  "sources": [
    "raw.department",
    "raw.management"
  ],
  "staging_models": [
    "stg_department",
    "stg_management"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_acting_management_departments",
    "type": "report",
    "grain": "1 row per department_id"
  },
  "ctes": [
    "stg_department",
    "stg_management"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_management",
      "on": "stg_department.department_id = stg_management.department_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "num_employees": [
      "not_null"
    ]
  }
}