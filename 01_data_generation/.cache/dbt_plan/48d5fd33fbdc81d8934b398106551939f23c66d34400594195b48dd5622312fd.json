{
  "sources": [
    "raw.products",
    "raw.product_characteristics"
  ],
  "staging_models": [
    "stg_products",
    "stg_product_characteristics"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_characteristics_count",
    "type": "report",
    "grain": ""
  },
  "ctes": [
    "stg_products",
    "stg_product_characteristics"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_product_characteristics",
      "on": "product_id = product_id"
    },
    {
      "left": "stg_product_characteristics",
      "right": "CHARACTERISTICS",
      "on": "characteristic_id = characteristic_id"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ]
  }
}