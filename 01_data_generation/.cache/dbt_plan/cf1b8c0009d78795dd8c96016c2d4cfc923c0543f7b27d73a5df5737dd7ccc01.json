{
  "sources": [
    "raw.region",
    "raw.affected_region"
  ],
  "staging_models": [
    "stg_region",
    "stg_affected_region"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_region_affected",
    "type": "report",
    "grain": "1 row per region_id"
  },
  "ctes": [
    "stg_region",
    "stg_affected_region"
  ],
  "joins": [
    {
      "left": "stg_region",
      "right": "stg_affected_region",
      "on": "stg_region.region_id = stg_affected_region.region_id"
    }
  ],
  "tests": {
    "region_name": [
      "not_null"
    ]
  }
}