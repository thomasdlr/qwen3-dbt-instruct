{
  "sources": [
    "raw.contestants",
    "raw.votes"
  ],
  "staging_models": [
    "stg_contestants",
    "stg_votes"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_contestant_votes",
    "type": "fact",
    "grain": "1 row per contestant_number"
  },
  "ctes": [
    "stg_contestants",
    "stg_votes"
  ],
  "joins": [
    {
      "left": "stg_contestants",
      "right": "stg_votes",
      "on": "contestant_number = contestant_number"
    }
  ],
  "tests": {
    "contestant_number": [
      "not_null",
      "unique"
    ],
    "contestant_name": [
      "not_null"
    ]
  }
}