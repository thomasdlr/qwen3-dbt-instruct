{
  "sources": [
    "raw.rating",
    "raw.reviewer"
  ],
  "staging_models": [
    "stg_rating",
    "stg_reviewer"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_reviewer_avg_rating",
    "type": "report",
    "grain": "1 row per reviewer"
  },
  "ctes": [
    "stg_rating",
    "stg_reviewer"
  ],
  "joins": [
    {
      "left": "stg_rating",
      "right": "stg_reviewer",
      "on": "stg_rating.rID = stg_reviewer.rID"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "avg_stars": [
      "not_null"
    ]
  }
}