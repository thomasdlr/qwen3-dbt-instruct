{
  "sources": [
    "raw.Student",
    "raw.Has_allergy"
  ],
  "staging_models": [
    "stg_Student",
    "stg_Has_allergy"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_students_milk_and_cat_allergy",
    "type": "report",
    "grain": "1 row per student with milk and cat allergies"
  },
  "ctes": [
    "stg_Has_allergy_milk",
    "stg_Has_allergy_cat"
  ],
  "joins": [
    {
      "left": "stg_Student",
      "right": "stg_Has_allergy_milk",
      "on": "Student.StuID = stg_Has_allergy_milk.StuID"
    },
    {
      "left": "stg_Student",
      "right": "stg_Has_allergy_cat",
      "on": "Student.StuID = stg_Has_allergy_cat.StuID"
    }
  ],
  "tests": {
    "lname": [
      "not_null"
    ],
    "age": [
      "not_null"
    ]
  }
}