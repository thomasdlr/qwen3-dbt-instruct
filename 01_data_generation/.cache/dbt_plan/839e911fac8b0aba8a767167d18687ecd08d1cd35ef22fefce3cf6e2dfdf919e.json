{
  "sources": [
    "raw.electoral_register",
    "raw.cmi_cross_references"
  ],
  "staging_models": [
    "stg_electoral_register",
    "stg_cmi_cross_references"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_electoral_register",
    "type": "dimension",
    "grain": "1 row per electoral_register_id"
  },
  "ctes": [
    "stg_electoral_register",
    "stg_cmi_cross_references"
  ],
  "joins": [
    {
      "left": "stg_electoral_register",
      "right": "stg_cmi_cross_references",
      "on": "electoral_register_id = cmi_cross_ref_id"
    }
  ],
  "tests": {
    "electoral_register_id": [
      "not_null"
    ]
  }
}