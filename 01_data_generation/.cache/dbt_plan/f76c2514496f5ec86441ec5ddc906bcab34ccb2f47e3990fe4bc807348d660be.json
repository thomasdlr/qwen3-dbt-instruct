{
  "sources": [
    "raw.Player",
    "raw.Player_Attributes"
  ],
  "staging_models": [
    "stg_player",
    "stg_player_attributes"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_player_birthdays",
    "type": "report",
    "grain": "1 row per Player.player_name, Player.birthday"
  },
  "ctes": [
    "stg_player",
    "stg_player_attributes"
  ],
  "joins": [
    {
      "left": "stg_player",
      "right": "stg_player_attributes",
      "on": "stg_player.player_api_id = stg_player_attributes.player_api_id"
    }
  ],
  "tests": {
    "player_name": [
      "not_null"
    ],
    "birthday": [
      "not_null"
    ]
  }
}