{
  "sources": [
    "raw.accounts",
    "raw.checking",
    "raw.savings"
  ],
  "staging_models": [
    "stg_accounts",
    "stg_checking",
    "stg_savings"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_savings_balance_by_customer",
    "type": "report",
    "grain": "1 row per accounts.custid"
  },
  "ctes": [
    "stg_accounts",
    "stg_savings"
  ],
  "joins": [
    {
      "left": "stg_accounts",
      "right": "stg_savings",
      "on": "custid = custid"
    }
  ],
  "tests": {
    "balance": [
      "not_null"
    ]
  }
}