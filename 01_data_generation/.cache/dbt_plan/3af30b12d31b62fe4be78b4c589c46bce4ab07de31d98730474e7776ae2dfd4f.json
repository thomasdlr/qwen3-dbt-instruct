{
  "sources": [
    "raw.accounts",
    "raw.savings"
  ],
  "staging_models": [
    "stg_accounts",
    "stg_savings"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_account_savings_balance",
    "type": "fact",
    "grain": "1 row per custid"
  },
  "ctes": [
    "stg_accounts",
    "stg_savings"
  ],
  "joins": [
    {
      "left": "stg_accounts",
      "right": "stg_savings",
      "on": "stg_accounts.custid = stg_savings.custid"
    }
  ],
  "tests": {
    "sum_balance": [
      "not_null"
    ]
  }
}