{
  "tables": [
    "customers",
    "orders"
  ],
  "joins": [
    {
      "left_table": "T1 (customers)",
      "right_table": "T2 (orders)",
      "condition": "T1.customer_id = T2.customer_id"
    }
  ],
  "filters": [
    "T2.date_order_placed >= \"2009-01-01\"",
    "T2.date_order_placed <= \"2010-01-01\""
  ],
  "select_columns": [
    "T1.customer_name"
  ],
  "grain": "customers.customer_id",
  "model_type": "dimension"
}