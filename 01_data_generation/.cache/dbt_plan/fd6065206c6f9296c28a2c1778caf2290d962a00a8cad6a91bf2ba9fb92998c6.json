{
  "sources": [
    "raw.wedding",
    "raw.people",
    "raw.church"
  ],
  "staging_models": [
    "stg_wedding",
    "stg_people",
    "stg_church"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_churches_with_eligible_couples",
    "type": "report",
    "grain": "1 row per wedding.church_id"
  },
  "ctes": [
    "stg_wedding",
    "stg_people",
    "stg_church"
  ],
  "joins": [
    {
      "left": "stg_wedding",
      "right": "stg_people",
      "on": "male_id = people_id"
    },
    {
      "left": "stg_wedding",
      "right": "stg_people",
      "on": "female_id = people_id"
    },
    {
      "left": "stg_church",
      "right": "stg_wedding",
      "on": "church_id = church_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}