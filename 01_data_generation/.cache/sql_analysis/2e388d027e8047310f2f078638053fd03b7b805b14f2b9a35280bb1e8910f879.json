{
  "tables": [
    "trip",
    "weather"
  ],
  "joins": [
    {
      "left_table": "T1",
      "right_table": "T2",
      "condition": "T1.zip_code = T2.zip_code"
    }
  ],
  "filters": [],
  "aggregations": [
    {
      "function": "AVG",
      "column": "T2.mean_temperature_f",
      "alias": ""
    }
  ],
  "group_by": [
    "T2.zip_code"
  ],
  "having": [
    "AVG(T2.mean_temperature_f) > 60"
  ],
  "select_columns": [
    "T1.id"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T2.zip_code",
  "model_type": "report"
}