    "raw.orders"
  ],
  "staging_models": [
    "stg_customers",
    "stg_orders"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_customer_orders",
    "type": "fact",
    "grain": "1 row per customer_id"
  },
