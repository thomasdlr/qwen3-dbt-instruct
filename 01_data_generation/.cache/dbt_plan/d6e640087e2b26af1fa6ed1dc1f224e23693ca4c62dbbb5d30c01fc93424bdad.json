{
  "sources": [
    "raw.film",
    "raw.inventory",
    "raw.rental"
  ],
  "staging_models": [
    "stg_film",
    "stg_inventory",
    "stg_rental"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_inventory_rentals",
    "type": "report",
    "grain": "1 row per inventory_id"
  },
  "ctes": [
    "stg_film",
    "stg_inventory",
    "stg_rental"
  ],
  "joins": [
    {
      "left": "stg_film",
      "right": "stg_inventory",
      "on": "film.film_id = inventory.film_id"
    },
    {
      "left": "stg_inventory",
      "right": "stg_rental",
      "on": "inventory.inventory_id = rental.inventory_id"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ],
    "inventory_id": [
      "not_null",
      "unique"
    ]
  }
}