{
  "sources": [
    "raw.department",
    "raw.dept_locations"
  ],
  "staging_models": [
    "stg_department",
    "stg_dept_locations"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_department_houston",
    "type": "dimension",
    "grain": "1 row per dname"
  },
  "ctes": [
    "stg_department",
    "stg_dept_locations"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_dept_locations",
      "on": "stg_department.dnumber = stg_dept_locations.dnumber"
    }
  ],
  "tests": {
    "dname": [
      "not_null"
    ]
  }
}