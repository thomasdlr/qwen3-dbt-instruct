{
  "sources": [
    "raw.bank",
    "raw.loan"
  ],
  "staging_models": [
    "stg_bank",
    "stg_loan"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_ny_branch_loans",
    "type": "fact",
    "grain": "1 row per bank.branch_id"
  },
  "ctes": [
    "stg_bank",
    "stg_loan"
  ],
  "joins": [
    {
      "left": "stg_bank",
      "right": "stg_loan",
      "on": "stg_bank.branch_id = stg_loan.branch_id"
    }
  ],
  "tests": {
    "sum_amount": [
      "not_null"
    ]
  }
}