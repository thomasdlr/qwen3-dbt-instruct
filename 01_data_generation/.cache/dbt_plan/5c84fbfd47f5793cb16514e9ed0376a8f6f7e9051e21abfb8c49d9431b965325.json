{
  "sources": [
    "raw.Parts",
    "raw.Part_Faults"
  ],
  "staging_models": [
    "stg_parts",
    "stg_part_faults"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_part_faults",
    "type": "fact",
    "grain": "1 row per part_id"
  },
  "ctes": [
    "stg_parts",
    "stg_part_faults"
  ],
  "joins": [
    {
      "left": "stg_parts",
      "right": "stg_part_faults",
      "on": "stg_parts.part_id = stg_part_faults.part_id"
    }
  ],
  "tests": {
    "part_name": [
      "not_null"
    ],
    "part_id": [
      "not_null",
      "unique"
    ]
  }
}