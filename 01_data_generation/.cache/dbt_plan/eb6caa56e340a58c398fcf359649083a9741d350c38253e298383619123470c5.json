{
  "sources": [
    "raw.Addresses",
    "raw.Stores"
  ],
  "staging_models": [
    "stg_Addresses",
    "stg_Stores"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_StoreAddresses",
    "type": "dimension",
    "grain": "1 row per Store Address"
  },
  "ctes": [
    "stg_Addresses",
    "stg_Stores"
  ],
  "joins": [
    {
      "left": "stg_Addresses",
      "right": "stg_Stores",
      "on": "Address_ID = Address_ID"
    }
  ],
  "tests": {
    "Address_ID": [
      "not_null",
      "unique"
    ],
    "Store_ID": [
      "not_null"
    ],
    "Marketing_Region_Code": [
      "not_null"
    ]
  }
}