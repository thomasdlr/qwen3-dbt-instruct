{
  "sources": [
    "raw.Customers",
    "raw.Customer_Events"
  ],
  "staging_models": [
    "stg_Customers",
    "stg_Customer_Events"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_customer_events",
    "type": "fact",
    "grain": "1 row per customer"
  },
  "ctes": [
    "stg_Customers",
    "stg_Customer_Events"
  ],
  "joins": [
    {
      "left": "stg_Customers",
      "right": "stg_Customer_Events",
      "on": "stg_Customers.customer_id = stg_Customer_Events.customer_id"
    }
  ],
  "tests": {
    "customer_id": [
      "not_null"
    ],
    "customer_details": [
      "not_null"
    ]
  }
}