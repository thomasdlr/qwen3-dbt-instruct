{
  "sources": [
    "raw.course",
    "raw.CLASS",
    "raw.department"
  ],
  "staging_models": [
    "stg_course",
    "stg_CLASS",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_department_course_count",
    "type": "report",
    "grain": "1 row per dept_code"
  },
  "ctes": [
    "stg_course",
    "stg_CLASS",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_course",
      "right": "stg_CLASS",
      "on": "crs_code = crs_code"
    },
    {
      "left": "stg_course",
      "right": "stg_department",
      "on": "dept_code = dept_code"
    }
  ],
  "tests": {
    "dept_name": [
      "not_null"
    ]
  }
}