{
  "sources": [
    "raw.Apartment_Bookings",
    "raw.Apartments"
  ],
  "staging_models": [
    "stg_Apartment_Bookings",
    "stg_Apartments"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_Apartment_Bookings",
    "type": "fact",
    "grain": "1 row per apt_id"
  },
  "ctes": [
    "stg_Apartment_Bookings",
    "stg_Apartments"
  ],
  "joins": [
    {
      "left": "stg_Apartment_Bookings",
      "right": "stg_Apartments",
      "on": "apt_id = apt_id"
    }
  ],
  "tests": {
    "apt_number": [
      "not_null"
    ],
    "booking_start_date": [
      "not_null"
    ]
  }
}