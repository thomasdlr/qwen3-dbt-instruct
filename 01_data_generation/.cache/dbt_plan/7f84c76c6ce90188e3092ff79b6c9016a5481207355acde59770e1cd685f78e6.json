{
  "sources": [
    "raw.customers",
    "raw.invoices"
  ],
  "staging_models": [
    "stg_customers",
    "stg_invoices"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_customer_total",
    "type": "fact",
    "grain": "1 row per customer"
  },
  "ctes": [
    "stg_customers",
    "stg_invoices"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_invoices",
      "on": "stg_invoices.customer_id = stg_customers.id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ],
    "total": [
      "not_null"
    ]
  }
}