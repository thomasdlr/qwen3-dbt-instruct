{
  "tables": [
    "Album",
    "Track",
    "Genre"
  ],
  "joins": [
    {
      "left_table": "Album",
      "right_table": "Track",
      "condition": "T1.AlbumId = T2.AlbumId"
    },
    {
      "left_table": "Track",
      "right_table": "Genre",
      "condition": "T2.GenreID = T3.GenreID"
    }
  ],
  "filters": [
    "T3.Name = 'Reggae'"
  ],
  "select_columns": [
    "T1.Title"
  ],
  "set_operations": [
    "INTERSECT",
    "UNION"
  ],
  "has_subquery": true,
  "grain": "T1.Title",
  "model_type": "report"
}