{
  "sources": [
    "raw.staff",
    "raw.complaints",
    "raw.products"
  ],
  "staging_models": [
    "stg_staff",
    "stg_complaints",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_staff_last_names",
    "type": "report",
    "grain": "1 row per staff last_name"
  },
  "ctes": [
    "stg_staff",
    "stg_complaints",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_staff",
      "right": "stg_complaints",
      "on": "staff.staff_id = complaints.staff_id"
    },
    {
      "left": "stg_complaints",
      "right": "stg_products",
      "on": "complaints.product_id = products.product_id"
    }
  ],
  "tests": {
    "last_name": [
      "not_null"
    ]
  }
}