{
  "sources": [
    "raw.entrepreneur",
    "raw.people"
  ],
  "staging_models": [
    "stg_entrepreneur",
    "stg_people"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_simon_peter_investor_dates",
    "type": "report",
    "grain": "1 row per People_ID"
  },
  "ctes": [
    "stg_entrepreneur",
    "stg_people"
  ],
  "joins": [
    {
      "left": "stg_entrepreneur",
      "right": "stg_people",
      "on": "stg_entrepreneur.People_ID = stg_people.People_ID"
    }
  ],
  "tests": {
    "Date_of_Birth": [
      "not_null"
    ]
  }
}