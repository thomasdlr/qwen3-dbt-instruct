{
  "sources": [
    "raw.Rent_Arrears",
    "raw.CMI_Cross_References",
    "raw.Customer_Master_Index"
  ],
  "staging_models": [
    "stg_Rent_Arrears",
    "stg_CMI_Cross_References",
    "stg_Customer_Master_Index"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_council_tax",
    "type": "dimension",
    "grain": "1 row per council_tax_id"
  },
  "ctes": [
    "stg_Rent_Arrears",
    "stg_CMI_Cross_References",
    "stg_Customer_Master_Index"
  ],
  "joins": [
    {
      "left": "stg_Rent_Arrears",
      "right": "stg_CMI_Cross_References",
      "on": "cmi_cross_ref_id = cmi_cross_ref_id"
    },
    {
      "left": "stg_Customer_Master_Index",
      "right": "stg_CMI_Cross_References",
      "on": "master_customer_id = master_customer_id"
    }
  ],
  "tests": {
    "council_tax_id": [
      "not_null",
      "unique"
    ]
  }
}