{
  "sources": [
    "raw.Owners",
    "raw.Dogs"
  ],
  "staging_models": [
    "stg_Owners",
    "stg_Dogs"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_owner_dog_sizes",
    "type": "report",
    "grain": "1 row per owner_id"
  },
  "ctes": [
    "stg_Owners",
    "stg_Dogs"
  ],
  "joins": [
    {
      "left": "stg_Owners",
      "right": "stg_Dogs",
      "on": "stg_Owners.owner_id = stg_Dogs.owner_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ],
    "size_code": [
      "not_null"
    ]
  }
}