{
  "sources": [
    "raw.people",
    "raw.poker_player"
  ],
  "staging_models": [
    "stg_people",
    "stg_poker_player"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_poker_money_rank",
    "type": "report",
    "grain": "1 row per Money_Rank"
  },
  "ctes": [
    "stg_poker_player"
  ],
  "joins": [
    {
      "left": "stg_people",
      "right": "stg_poker_player",
      "on": "People_ID = People_ID"
    }
  ],
  "tests": {
    "Money_Rank": [
      "not_null"
    ]
  }
}