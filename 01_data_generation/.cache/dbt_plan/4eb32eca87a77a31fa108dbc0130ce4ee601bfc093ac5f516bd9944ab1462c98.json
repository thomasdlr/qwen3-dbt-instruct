{
  "sources": [
    "raw.candidates",
    "raw.candidate_assessments",
    "raw.people"
  ],
  "staging_models": [
    "stg_candidates",
    "stg_candidate_assessments",
    "stg_people"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_failed_candidate_mobile_numbers",
    "type": "report",
    "grain": "1 row per cell_mobile_number"
  },
  "ctes": [
    "stg_candidates",
    "stg_candidate_assessments",
    "stg_people"
  ],
  "joins": [
    {
      "left": "stg_candidates",
      "right": "stg_candidate_assessments",
      "on": "candidate_id = candidate_id"
    },
    {
      "left": "stg_candidates",
      "right": "stg_people",
      "on": "candidate_id = person_id"
    }
  ],
  "tests": {
    "cell_mobile_number": [
      "not_null"
    ]
  }
}