# ─── LM Studio server ────────────────────────────────────────────────────────
LOCAL_LM_BASE_URL=http://localhost:1234/v1
LM_API_KEY=lm-studio

# ─── Generation parameters ───────────────────────────────────────────────────
# Concurrency: 2 for M1 Pro, 4–8 for M-Max/Ultra
MAX_CONCURRENT_REQUESTS=4
DEFAULT_VARIATIONS=3
MAX_RETRIES=3
MAX_TOKENS=1500

# ─── Sampling parameters ─────────────────────────────────────────────────────
# temperature        – randomness scale; lower = more deterministic SQL output
# top_p              – nucleus sampling; only tokens summing to this probability are considered
# top_k              – hard cap on candidate tokens per step; keeps SQL syntax tight (LM Studio ext)
# min_p              – drops tokens below this fraction of the best-token probability (LM Studio ext)
# presence_penalty   – discourages tokens already present (0.0 = off, safe for SQL keywords)
# repetition_penalty – llama.cpp multiplicative repeat penalty; 1.0 = neutral (LM Studio ext)
TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20
MIN_P=0.0
PRESENCE_PENALTY=0.0
REPETITION_PENALTY=1.0

# ─── Output ──────────────────────────────────────────────────────────────────
OUTPUT_FILE=01_data_generation/data/dbt_synthetic_dataset.jsonl
