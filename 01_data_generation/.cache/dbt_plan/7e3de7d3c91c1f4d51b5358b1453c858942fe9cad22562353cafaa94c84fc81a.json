{
  "sources": [
    "raw.inst",
    "raw.authorship",
    "raw.papers"
  ],
  "staging_models": [
    "stg_inst",
    "stg_authorship",
    "stg_papers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_inst_paper_counts",
    "type": "report",
    "grain": "1 row per inst.name"
  },
  "ctes": [
    "stg_inst",
    "stg_authorship",
    "stg_papers"
  ],
  "joins": [
    {
      "left": "stg_inst",
      "right": "stg_authorship",
      "on": "stg_inst.instid = stg_authorship.instid"
    },
    {
      "left": "stg_authorship",
      "right": "stg_papers",
      "on": "stg_authorship.paperid = stg_papers.paperid"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}