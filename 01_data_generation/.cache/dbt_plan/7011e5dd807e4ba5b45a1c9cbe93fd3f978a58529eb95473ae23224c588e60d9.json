{
  "sources": [
    "raw.faculty",
    "raw.student"
  ],
  "staging_models": [
    "stg_faculty",
    "stg_student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_faculty_advisee_count",
    "type": "fact",
    "grain": "1 row per faculty member"
  },
  "ctes": [
    "stg_faculty",
    "stg_student"
  ],
  "joins": [
    {
      "left": "stg_faculty",
      "right": "stg_student",
      "on": "stg_faculty.fac_id = stg_student.advisor"
    }
  ],
  "tests": {
    "fac_id": [
      "not_null",
      "unique"
    ],
    "count_star": [
      "not_null"
    ]
  }
}