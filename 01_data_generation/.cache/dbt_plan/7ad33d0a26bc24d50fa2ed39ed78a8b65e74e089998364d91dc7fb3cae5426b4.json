{
  "sources": [
    "raw.student",
    "raw.lives_in",
    "raw.dorm"
  ],
  "staging_models": [
    "stg_student",
    "stg_lives_in",
    "stg_dorm"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_student_dorm_count",
    "type": "fact",
    "grain": "1 row per dorm_name"
  },
  "ctes": [
    "stg_student",
    "stg_lives_in",
    "stg_dorm"
  ],
  "joins": [
    {
      "left": "stg_student",
      "right": "stg_lives_in",
      "on": "stg_student.stuid = stg_lives_in.stuid"
    },
    {
      "left": "stg_dorm",
      "right": "stg_lives_in",
      "on": "stg_dorm.dormid = stg_lives_in.dormid"
    }
  ],
  "tests": {
    "count": [
      "not_null"
    ],
    "dorm_name": [
      "not_null"
    ]
  }
}