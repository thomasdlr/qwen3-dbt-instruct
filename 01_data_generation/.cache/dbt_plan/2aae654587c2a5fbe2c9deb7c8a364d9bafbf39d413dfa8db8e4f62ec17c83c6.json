{
  "sources": [
    "raw.architect",
    "raw.bridge",
    "raw.mill"
  ],
  "staging_models": [
    "stg_architect",
    "stg_bridge",
    "stg_mill"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_architect_projects",
    "type": "report",
    "grain": "1 row per architect"
  },
  "ctes": [
    "stg_architect",
    "stg_bridge",
    "stg_mill"
  ],
  "joins": [
    {
      "left": "stg_architect",
      "right": "stg_bridge",
      "on": "stg_architect.id = stg_bridge.architect_id"
    },
    {
      "left": "stg_architect",
      "right": "stg_mill",
      "on": "stg_architect.id = stg_mill.architect_id"
    }
  ],
  "tests": {
    "id": [
      "not_null"
    ],
    "name": [
      "not_null"
    ],
    "gender": [
      "not_null"
    ]
  }
}