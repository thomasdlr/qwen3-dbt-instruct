{
  "sources": [
    "raw.country",
    "raw.countrylanguage"
  ],
  "staging_models": [
    "stg_country",
    "stg_countrylanguage"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_country_languages",
    "type": "fact",
    "grain": "1 row per T1.Name"
  },
  "ctes": [
    "stg_country",
    "stg_countrylanguage"
  ],
  "joins": [
    {
      "left": "stg_country",
      "right": "stg_countrylanguage",
      "on": "stg_country.Code = stg_countrylanguage.CountryCode"
    }
  ],
  "tests": {
    "COUNT(T2.Language)": [
      "not_null"
    ],
    "T1.Name": [
      "not_null",
      "unique"
    ]
  }
}