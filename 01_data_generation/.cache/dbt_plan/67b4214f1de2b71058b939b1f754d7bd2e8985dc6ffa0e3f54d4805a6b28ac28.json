{
  "sources": [
    "raw.order_items",
    "raw.products"
  ],
  "staging_models": [
    "stg_order_items",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_photo_orders",
    "type": "fact",
    "grain": "1 row per photo product order"
  },
  "ctes": [
    "stg_order_items",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_order_items",
      "right": "stg_products",
      "on": "stg_order_items.Product_ID = stg_products.Product_ID"
    }
  ],
  "tests": {
    "SUM_Order_Quantity": [
      "not_null"
    ]
  }
}