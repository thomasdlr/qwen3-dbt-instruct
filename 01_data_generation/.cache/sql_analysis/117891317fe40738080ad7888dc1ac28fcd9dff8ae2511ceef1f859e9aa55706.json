{
  "tables": [
    "student",
    "enroll",
    "CLASS",
    "course"
  ],
  "joins": [
    {
      "left_table": "student AS T1",
      "right_table": "enroll AS T2",
      "condition": "T1.stu_num = T2.stu_num"
    },
    {
      "left_table": "enroll AS T2",
      "right_table": "CLASS AS T3",
      "condition": "T2.class_code = T3.class_code"
    },
    {
      "left_table": "CLASS AS T3",
      "right_table": "course AS T4",
      "condition": "T3.crs_code = T4.crs_code"
    }
  ],
  "filters": [],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T1.stu_fname",
    "T1.stu_lname",
    "T4.crs_description"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T1.stu_fname, T1.stu_lname, T4.crs_description",
  "model_type": "report"
}