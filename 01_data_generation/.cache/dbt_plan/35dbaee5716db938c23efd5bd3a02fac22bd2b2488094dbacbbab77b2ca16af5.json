{
  "sources": [
    "raw.owners",
    "raw.dogs",
    "raw.treatments"
  ],
  "staging_models": [
    "stg_owners",
    "stg_dogs",
    "stg_treatments"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_owner_treatment_costs",
    "type": "fact",
    "grain": "1 row per owner_id"
  },
  "ctes": [
    "stg_owners",
    "stg_dogs",
    "stg_treatments"
  ],
  "joins": [
    {
      "left": "stg_owners",
      "right": "stg_dogs",
      "on": "owner_id = owner_id"
    },
    {
      "left": "stg_dogs",
      "right": "stg_treatments",
      "on": "dog_id = dog_id"
    }
  ],
  "tests": {
    "owner_id": [
      "not_null",
      "unique"
    ],
    "zip_code": [
      "not_null"
    ]
  }
}