{
  "sources": [
    "raw.candidates",
    "raw.people"
  ],
  "staging_models": [
    "stg_candidates",
    "stg_people"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_person",
    "type": "dimension",
    "grain": "1 row per person"
  },
  "ctes": [
    "stg_people",
    "stg_candidates"
  ],
  "joins": [
    {
      "left": "stg_people",
      "right": "stg_candidates",
      "on": "candidate_id = person_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ]
  }
}