{
  "sources": [
    "raw.documents_with_expenses",
    "raw.ref_budget_codes"
  ],
  "staging_models": [
    "stg_documents_with_expenses",
    "stg_ref_budget_codes"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_document_budget_codes",
    "type": "report",
    "grain": "1 row per document_id"
  },
  "ctes": [
    "stg_documents_with_expenses",
    "stg_ref_budget_codes"
  ],
  "joins": [
    {
      "left": "stg_documents_with_expenses",
      "right": "stg_ref_budget_codes",
      "on": "T1.budget_type_code = T2.budget_type_code"
    }
  ],
  "tests": {
    "budget_type_code": [
      "not_null"
    ],
    "budget_type_description": [
      "not_null"
    ],
    "document_id": [
      "not_null"
    ]
  }
}