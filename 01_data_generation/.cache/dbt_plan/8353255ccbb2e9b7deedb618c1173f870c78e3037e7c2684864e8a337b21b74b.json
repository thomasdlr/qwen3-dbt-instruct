{
  "sources": [
    "raw.faculty",
    "raw.faculty_participates_in",
    "raw.activity"
  ],
  "staging_models": [
    "stg_faculty",
    "stg_faculty_participates_in",
    "stg_activity"
  ],
  "intermediate_models": [
    "int_faculty_activities"
  ],
  "mart_model": {
    "name": "rpt_canoeing_kayaking_faculty",
    "type": "report",
    "grain": "1 row per faculty last name"
  },
  "ctes": [
    "stg_faculty",
    "stg_faculty_participates_in",
    "stg_activity"
  ],
  "joins": [
    {
      "left": "stg_faculty",
      "right": "stg_faculty_participates_in",
      "on": "faculty.facID = faculty_participates_in.facID"
    },
    {
      "left": "stg_faculty_participates_in",
      "right": "stg_activity",
      "on": "faculty_participates_in.actid = activity.actid"
    }
  ],
  "tests": {
    "lname": [
      "not_null"
    ]
  }
}