{
  "sources": [
    "raw.inst",
    "raw.authorship",
    "raw.papers"
  ],
  "staging_models": [
    "stg_inst",
    "stg_authorship",
    "stg_papers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_country_paper_counts",
    "type": "report",
    "grain": "1 row per country"
  },
  "ctes": [
    "stg_inst",
    "stg_authorship",
    "stg_papers"
  ],
  "joins": [
    {
      "left": "stg_inst",
      "right": "stg_authorship",
      "on": "instid = instid"
    },
    {
      "left": "stg_authorship",
      "right": "stg_papers",
      "on": "paperid = paperid"
    }
  ],
  "tests": {
    "country": [
      "not_null",
      "unique"
    ]
  }
}