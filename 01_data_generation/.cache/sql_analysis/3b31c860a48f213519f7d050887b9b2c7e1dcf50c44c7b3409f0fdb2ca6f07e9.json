{
  "tables": [
    "papers",
    "authorship",
    "inst"
  ],
  "joins": [
    {
      "left_table": "papers AS t1",
      "right_table": "authorship AS t2",
      "condition": "t1.paperid = t2.paperid"
    },
    {
      "left_table": "authorship AS t2",
      "right_table": "inst AS t3",
      "condition": "t2.instid = t3.instid"
    }
  ],
  "filters": [
    "t3.name = \"Google\""
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "t1.title"
  ],
  "set_operations": [],
  "has_distinct": true,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "t1.title",
  "model_type": "report"
}