{
  "sources": [
    "raw.customers",
    "raw.orders"
  ],
  "staging_models": [
    "stg_customers",
    "stg_orders"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_packing_customers",
    "type": "report",
    "grain": "1 row per customers.customer_name"
  },
  "ctes": [
    "stg_customers",
    "stg_orders"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_orders",
      "on": "stg_customers.customer_id = stg_orders.customer_id"
    }
  ],
  "tests": {
    "customer_name": [
      "not_null"
    ]
  }
}