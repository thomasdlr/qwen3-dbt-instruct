{
  "sources": [
    "raw.Rating",
    "raw.Movie",
    "raw.Reviewer"
  ],
  "staging_models": [
    "stg_Rating",
    "stg_Movie",
    "stg_Reviewer"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_gone_with_the_wind_reviewers",
    "type": "report",
    "grain": "1 row per Reviewer.name"
  },
  "ctes": [
    "stg_Rating",
    "stg_Movie",
    "stg_Reviewer"
  ],
  "joins": [
    {
      "left": "stg_Rating",
      "right": "stg_Movie",
      "on": "stg_Rating.mID = stg_Movie.mID"
    },
    {
      "left": "stg_Rating",
      "right": "stg_Reviewer",
      "on": "stg_Rating.rID = stg_Reviewer.rID"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}