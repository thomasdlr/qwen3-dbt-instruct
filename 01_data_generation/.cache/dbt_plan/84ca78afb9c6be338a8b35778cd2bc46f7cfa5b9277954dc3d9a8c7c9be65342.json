{
  "sources": [
    "raw.faculty",
    "raw.student"
  ],
  "staging_models": [
    "stg_faculty",
    "stg_student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_faculty_student_count",
    "type": "dimension",
    "grain": "1 row per faculty ID"
  },
  "ctes": [
    "stg_faculty",
    "stg_student"
  ],
  "joins": [
    {
      "left": "stg_faculty",
      "right": "stg_student",
      "on": "stg_faculty.facid = stg_student.advisor"
    }
  ],
  "tests": {
    "facid": [
      "not_null",
      "unique"
    ]
  }
}