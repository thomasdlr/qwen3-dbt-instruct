{
  "sources": [
    "raw.concert",
    "raw.stadium"
  ],
  "staging_models": [
    "stg_concert",
    "stg_stadium"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_stadium_concerts",
    "type": "report",
    "grain": "1 row per stadium_id"
  },
  "ctes": [
    "stg_concert",
    "stg_stadium"
  ],
  "joins": [
    {
      "left": "stg_concert",
      "right": "stg_stadium",
      "on": "stg_concert.stadium_id = stg_stadium.stadium_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "capacity": [
      "not_null"
    ]
  }
}