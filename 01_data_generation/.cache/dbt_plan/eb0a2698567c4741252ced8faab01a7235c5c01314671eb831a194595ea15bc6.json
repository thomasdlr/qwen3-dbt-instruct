{
  "sources": [
    "raw.Things",
    "raw.Organizations"
  ],
  "staging_models": [
    "stg_Things",
    "stg_Organizations"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_Things",
    "type": "dimension",
    "grain": "1 row per thing_id"
  },
  "ctes": [
    "stg_Things",
    "stg_Organizations"
  ],
  "joins": [
    {
      "left": "stg_Things",
      "right": "stg_Organizations",
      "on": "T1.organization_id = T2.organization_id"
    }
  ],
  "tests": {
    "thing_id": [
      "not_null",
      "unique"
    ],
    "type_of_Thing_Code": [
      "not_null"
    ],
    "organization_details": [
      "not_null"
    ]
  }
}