{
  "sources": [
    "raw.products",
    "raw.product_characteristics",
    "raw.characteristics"
  ],
  "staging_models": [
    "stg_products",
    "stg_product_characteristics",
    "stg_characteristics"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_warm_products",
    "type": "report",
    "grain": "1 row per product_name"
  },
  "ctes": [
    "stg_products",
    "stg_product_characteristics",
    "stg_characteristics"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_product_characteristics",
      "on": "product_id = product_id"
    },
    {
      "left": "stg_product_characteristics",
      "right": "stg_characteristics",
      "on": "characteristic_id = characteristic_id"
    }
  ],
  "tests": {
    "product_name": [
      "not_null"
    ]
  }
}