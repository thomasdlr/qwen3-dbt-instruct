{
  "sources": [
    "raw.bank",
    "raw.loan"
  ],
  "staging_models": [
    "stg_bank",
    "stg_loan"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_branch_loan_summaries",
    "type": "report",
    "grain": "1 row per branch"
  },
  "ctes": [
    "stg_bank",
    "stg_loan"
  ],
  "joins": [
    {
      "left": "stg_bank",
      "right": "stg_loan",
      "on": "stg_bank.branch_id = stg_loan.branch_id"
    }
  ],
  "tests": {
    "bname": [
      "not_null"
    ],
    "SUM_amount": [
      "not_null"
    ]
  }
}