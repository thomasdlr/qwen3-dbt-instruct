{
  "tables": [
    "artists",
    "albums"
  ],
  "joins": [
    {
      "left_table": "artists",
      "right_table": "albums",
      "condition": "T1.id = T2.artist_id"
    }
  ],
  "filters": [
    "T1.name LIKE '%Led%'"
  ],
  "select_columns": [
    "T2.title"
  ],
  "grain": "T1.id",
  "model_type": "report"
}