{
  "sources": [
    "raw.addresses",
    "raw.staff"
  ],
  "staging_models": [
    "stg_addresses",
    "stg_staff"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_staff_by_address",
    "type": "dimension",
    "grain": "1 row per staff_address_id"
  },
  "ctes": [
    "stg_addresses",
    "stg_staff"
  ],
  "joins": [
    {
      "left": "stg_addresses",
      "right": "stg_staff",
      "on": "address_id = staff_address_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ]
  }
}