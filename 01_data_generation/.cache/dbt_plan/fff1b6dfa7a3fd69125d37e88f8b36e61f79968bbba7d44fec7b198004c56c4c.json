{
  "sources": [
    "raw.authors",
    "raw.authorship",
    "raw.papers",
    "raw.inst"
  ],
  "staging_models": [
    "stg_authors",
    "stg_authorship",
    "stg_papers",
    "stg_inst"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_japanese_ohori_papers",
    "type": "report",
    "grain": "1 row per paperid"
  },
  "ctes": [
    "stg_authorship",
    "stg_papers",
    "stg_inst"
  ],
  "joins": [
    {
      "left": "stg_authorship",
      "right": "stg_papers",
      "on": "authorship.paperid = papers.paperid"
    },
    {
      "left": "stg_authorship",
      "right": "stg_inst",
      "on": "authorship.instid = inst.instid"
    }
  ],
  "tests": {
    "title": [
      "not_null"
    ]
  }
}