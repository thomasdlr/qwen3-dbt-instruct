{
  "sources": [
    "raw.Grants",
    "raw.Organisations",
    "raw.organisation_Types"
  ],
  "staging_models": [
    "stg_Grants",
    "stg_Organisations",
    "stg_organisation_Types"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_grants_by_research_organisation",
    "type": "fact",
    "grain": "1 row per organisation_id"
  },
  "ctes": [
    "stg_Grants",
    "stg_Organisations",
    "stg_organisation_Types"
  ],
  "joins": [
    {
      "left": "stg_Grants",
      "right": "stg_Organisations",
      "on": "stg_Grants.organisation_id = stg_Organisations.organisation_id"
    },
    {
      "left": "stg_Organisations",
      "right": "stg_organisation_Types",
      "on": "stg_Organisations.organisation_type = stg_organisation_Types.organisation_type"
    }
  ],
  "tests": {
    "grant_amount_total": [
      "not_null"
    ]
  }
}