    {
      "left": "stg_city",
      "right": "stg_hosting_city",
      "on": "city.city_id = hosting_city.host_city"
    }
  ],
  "tests": {
    "city": [
      "not_null"
    ],
    "hosting_city": [
      "not_null"
    ]
  }
}