{
  "sources": [
    "raw.grants",
    "raw.documents",
    "raw.document_types"
  ],
  "staging_models": [
    "stg_grants",
    "stg_documents",
    "stg_document_types"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_regular_initial_grant_dates",
    "type": "report",
    "grain": "1 row per grant_start_date"
  },
  "ctes": [
    "stg_grants",
    "stg_documents",
    "stg_document_types"
  ],
  "joins": [
    {
      "left": "stg_grants",
      "right": "stg_documents",
      "on": "grant_id"
    },
    {
      "left": "stg_documents",
      "right": "stg_document_types",
      "on": "document_type_code"
    }
  ],
  "tests": {
    "grant_start_date": [
      "not_null"
    ]
  }
}