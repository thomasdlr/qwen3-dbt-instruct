{
  "sources": [
    "raw.department",
    "raw.student",
    "raw.instructor"
  ],
  "staging_models": [
    "stg_department",
    "stg_student",
    "stg_instructor"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_department_stats",
    "type": "report",
    "grain": "1 row per dept_name"
  },
  "ctes": [
    "stg_department",
    "stg_student",
    "stg_instructor"
  ],
  "joins": [
    {
      "left": "stg_department",
      "right": "stg_student",
      "on": "dept_name = dept_name"
    },
    {
      "left": "stg_department",
      "right": "stg_instructor",
      "on": "dept_name = dept_name"
    }
  ],
  "tests": {
    "count_student": [
      "not_null"
    ],
    "count_instructor": [
      "not_null"
    ],
    "dept_name": [
      "not_null",
      "unique"
    ]
  }
}