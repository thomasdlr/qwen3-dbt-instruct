{
  "sources": [
    "raw.CLASS",
    "raw.employee",
    "raw.professor",
    "raw.department"
  ],
  "staging_models": [
    "stg_CLASS",
    "stg_employee",
    "stg_professor",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_compsci_professor_degrees",
    "type": "report",
    "grain": "1 row per professor first name and highest degree"
  },
  "ctes": [
    "stg_CLASS",
    "stg_employee",
    "stg_professor",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_CLASS",
      "right": "stg_employee",
      "on": "T1.prof_num = T2.emp_num"
    },
    {
      "left": "stg_employee",
      "right": "stg_professor",
      "on": "T2.emp_num = T3.emp_num"
    },
    {
      "left": "stg_department",
      "right": "stg_professor",
      "on": "T4.dept_code = T3.dept_code"
    }
  ],
  "tests": {
    "emp_fname": [
      "not_null"
    ],
    "prof_high_degree": [
      "not_null"
    ]
  }
}