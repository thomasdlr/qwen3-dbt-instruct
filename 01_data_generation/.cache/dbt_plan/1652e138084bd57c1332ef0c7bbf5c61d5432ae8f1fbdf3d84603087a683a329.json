{
  "sources": [
    "raw.student",
    "raw.takes",
    "raw.course"
  ],
  "staging_models": [
    "stg_student",
    "stg_takes",
    "stg_course"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_courses",
    "type": "report",
    "grain": "1 row per student.name"
  },
  "ctes": [
    "stg_student",
    "stg_takes",
    "stg_course"
  ],
  "joins": [
    {
      "left": "stg_takes",
      "right": "stg_course",
      "on": "stg_takes.course_id = stg_course.course_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}