{
  "sources": [
    "raw.student",
    "raw.enroll",
    "raw.CLASS",
    "raw.course"
  ],
  "staging_models": [
    "stg_student",
    "stg_enroll",
    "stg_CLASS",
    "stg_course"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_course_enrollment",
    "type": "report",
    "grain": "1 row per student name and course description"
  },
  "ctes": [
    "stg_student",
    "stg_enroll",
    "stg_CLASS",
    "stg_course"
  ],
  "joins": [
    {
      "left": "stg_student",
      "right": "stg_enroll",
      "on": "stu_num = stu_num"
    },
    {
      "left": "stg_enroll",
      "right": "stg_CLASS",
      "on": "class_code = class_code"
    },
    {
      "left": "stg_CLASS",
      "right": "stg_course",
      "on": "crs_code = crs_code"
    }
  ],
  "tests": {
    "stu_fname": [
      "not_null"
    ],
    "stu_lname": [
      "not_null"
    ],
    "crs_description": [
      "not_null"
    ]
  }
}