{
  "sources": [
    "raw.county",
    "raw.election"
  ],
  "staging_models": [
    "stg_county",
    "stg_election"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_election_by_county",
    "type": "fact",
    "grain": "1 row per County_id"
  },
  "ctes": [
    "stg_county",
    "stg_election"
  ],
  "joins": [
    {
      "left": "stg_county",
      "right": "stg_election",
      "on": "stg_county.County_id = stg_election.District"
    }
  ],
  "tests": {
    "County_name": [
      "not_null"
    ],
    "COUNT(*)": [
      "not_null"
    ]
  }
}