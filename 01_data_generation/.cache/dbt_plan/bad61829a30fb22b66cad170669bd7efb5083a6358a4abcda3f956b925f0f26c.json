    "raw.hosting_city"
  ],
  "staging_models": [
    "stg_city",
    "stg_temperature",
    "stg_hosting_city"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_city_temperature_exception",
    "type": "report",
    "grain": "1 row per city.city_id"
  },
  "ctes": [
    "stg_city",
    "stg_temperature",
    "stg_hosting_city"
  ],
