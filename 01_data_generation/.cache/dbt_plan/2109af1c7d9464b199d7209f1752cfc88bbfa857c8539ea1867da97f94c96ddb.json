{
  "sources": [
    "raw.Accounts",
    "raw.Customers"
  ],
  "staging_models": [
    "stg_Accounts",
    "stg_Customers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_accounts_for_meaghan",
    "type": "report",
    "grain": "1 row per Accounts.account_id"
  },
  "ctes": [
    "stg_Accounts",
    "stg_Customers"
  ],
  "joins": [
    {
      "left": "stg_Accounts",
      "right": "stg_Customers",
      "on": "stg_Accounts.customer_id = stg_Customers.customer_id"
    }
  ],
  "tests": {
    "account_id": [
      "not_null"
    ],
    "date_account_opened": [
      "not_null"
    ],
    "account_name": [
      "not_null"
    ],
    "other_account_details": [
      "not_null"
    ]
  }
}