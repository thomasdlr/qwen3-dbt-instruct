{
  "tables": [
    "Apartment_Bookings",
    "Apartments"
  ],
  "joins": [
    {
      "left_table": "Apartment_Bookings",
      "right_table": "Apartments",
      "condition": "T1.apt_id = T2.apt_id"
    }
  ],
  "filters": [
    "T1.booking_status_code = \"Confirmed\"",
    "T1.booking_status_code = \"Provisional\""
  ],
  "select_columns": [
    "T2.apt_number",
    "T2.apt_number"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "grain": "T2.apt_number",
  "model_type": "report"
}