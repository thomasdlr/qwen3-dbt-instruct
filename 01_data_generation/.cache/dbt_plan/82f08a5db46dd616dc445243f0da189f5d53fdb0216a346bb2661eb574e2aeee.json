{
  "sources": [
    "raw.city",
    "raw.countrylanguage"
  ],
  "staging_models": [
    "stg_city",
    "stg_countrylanguage"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_english_city_population",
    "type": "report",
    "grain": "1 row per city"
  },
  "ctes": [
    "stg_city",
    "stg_countrylanguage"
  ],
  "joins": [
    {
      "left": "stg_city",
      "right": "stg_countrylanguage",
      "on": "city.CountryCode = countrylanguage.CountryCode"
    }
  ],
  "tests": {
    "Name": [
      "not_null"
    ],
    "Population": [
      "not_null"
    ]
  }
}