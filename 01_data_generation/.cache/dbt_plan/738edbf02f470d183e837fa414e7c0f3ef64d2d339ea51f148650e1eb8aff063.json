{
  "sources": [
    "raw.customers",
    "raw.customer_orders",
    "raw.order_items"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_rodrick_heaney_orders",
    "type": "fact",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customer_orders",
      "on": "customer_id = customer_id"
    },
    {
      "left": "stg_customer_orders",
      "right": "stg_order_items",
      "on": "order_id = order_id"
    }
  ],
  "tests": {
    "customer_id": [
      "not_null"
    ],
    "order_quantity_sum": [
      "not_null"
    ]
  }
}