{
  "sources": [
    "raw.countries",
    "raw.car_makers"
  ],
  "staging_models": [
    "stg_countries",
    "stg_car_makers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_countries_with_car_makers",
    "type": "dimension",
    "grain": "1 row per CountryId"
  },
  "ctes": [
    "stg_countries",
    "stg_car_makers"
  ],
  "joins": [
    {
      "left": "stg_countries",
      "right": "stg_car_makers",
      "on": "stg_countries.CountryId = stg_car_makers.Country"
    }
  ],
  "tests": {
    "CountryName": [
      "not_null"
    ],
    "CountryId": [
      "not_null",
      "unique"
    ]
  }
}