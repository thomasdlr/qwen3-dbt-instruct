{
  "sources": [
    "raw.class",
    "raw.course",
    "raw.department"
  ],
  "staging_models": [
    "stg_class",
    "stg_course",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_class_count_by_school",
    "type": "report",
    "grain": "1 row per school_code"
  },
  "ctes": [
    "stg_class",
    "stg_course",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_class",
      "right": "stg_course",
      "on": "crs_code = crs_code"
    },
    {
      "left": "stg_course",
      "right": "stg_department",
      "on": "dept_code = dept_code"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ],
    "school_code": [
      "not_null",
      "unique"
    ]
  }
}