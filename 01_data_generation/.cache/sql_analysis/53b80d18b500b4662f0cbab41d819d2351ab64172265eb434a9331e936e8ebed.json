{
  "tables": [
    "customers",
    "customers_policies",
    "available_policies"
  ],
  "joins": [
    {
      "left_table": "t1",
      "right_table": "t2",
      "condition": "t1.customer_id = t2.customer_id"
    },
    {
      "left_table": "t2",
      "right_table": "t3",
      "condition": "t2.policy_id = t3.policy_id"
    }
  ],
  "filters": [
    "t1.customer_name = (SELECT t1.customer_name FROM customers AS t1 JOIN customers_policies AS t2 ON t1.customer_id = t2.customer_id GROUP BY t1.customer_name ORDER BY COUNT(*) DESC LIMIT 1)"
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "t3.policy_type_code"
  ],
  "set_operations": [],
  "has_distinct": true,
  "has_subquery": true,
  "has_window_fn": false,
  "grain": "t3.policy_type_code",
  "model_type": "report"
}