{
  "sources": [
    "raw.Degree_Programs",
    "raw.Student_Enrolment"
  ],
  "staging_models": [
    "stg_Degree_Programs",
    "stg_Student_Enrolment"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_degree_program_enrolment_counts",
    "type": "report",
    "grain": "1 row per degree_summary_name"
  },
  "ctes": [
    "stg_Degree_Programs",
    "stg_Student_Enrolment"
  ],
  "joins": [
    {
      "left": "stg_Degree_Programs",
      "right": "stg_Student_Enrolment",
      "on": "degree_program_id = degree_program_id"
    }
  ],
  "tests": {
    "degree_summary_name": [
      "not_null"
    ]
  }
}