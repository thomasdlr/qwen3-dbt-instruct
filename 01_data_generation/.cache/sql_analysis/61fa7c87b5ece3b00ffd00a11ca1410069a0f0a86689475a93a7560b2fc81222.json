{
  "tables": [
    "assignedto",
    "projects",
    "scientists"
  ],
  "joins": [
    {
      "left_table": "assignedto",
      "right_table": "projects",
      "condition": "T1.project = T2.code"
    },
    {
      "left_table": "assignedto",
      "right_table": "scientists",
      "condition": "T1.scientist = T3.SSN"
    }
  ],
  "filters": [
    "T3.name LIKE '%Smith%'"
  ],
  "select_columns": [
    "T2.name"
  ],
  "grain": "projects.code",
  "model_type": "report"
}