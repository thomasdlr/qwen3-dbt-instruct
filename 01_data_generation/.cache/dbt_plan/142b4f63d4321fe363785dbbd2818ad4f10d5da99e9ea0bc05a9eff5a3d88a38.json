{
  "sources": [
    "raw.products",
    "raw.Manufacturers"
  ],
  "staging_models": [
    "stg_products",
    "stg_manufacturers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_max_price_by_manufacturer",
    "type": "report",
    "grain": "1 row per manufacturer"
  },
  "ctes": [
    "stg_products",
    "stg_manufacturers"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_manufacturers",
      "on": "stg_products.manufacturer = stg_manufacturers.code"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "price_max": [
      "not_null"
    ],
    "manufacturer_name": [
      "not_null"
    ]
  }
}