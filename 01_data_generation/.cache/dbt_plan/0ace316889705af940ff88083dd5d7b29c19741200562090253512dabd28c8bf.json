{
  "sources": [
    "raw.institution",
    "raw.protein"
  ],
  "staging_models": [
    "stg_institution",
    "stg_protein"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_institution_protein_count",
    "type": "fact",
    "grain": "1 row per institution_id"
  },
  "ctes": [
    "stg_institution",
    "stg_protein"
  ],
  "joins": [
    {
      "left": "stg_institution",
      "right": "stg_protein",
      "on": "stg_institution.institution_id = stg_protein.institution_id"
    }
  ],
  "tests": {
    "institution": [
      "not_null"
    ],
    "count_star": [
      "not_null"
    ]
  }
}