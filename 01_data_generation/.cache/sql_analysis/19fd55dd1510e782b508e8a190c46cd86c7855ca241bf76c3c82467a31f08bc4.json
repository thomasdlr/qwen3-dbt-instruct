{
  "tables": [
    "Employee",
    "Certificate",
    "Aircraft"
  ],
  "joins": [
    {
      "left_table": "Employee AS T1",
      "right_table": "Certificate AS T2",
      "condition": "T1.eid = T2.eid"
    },
    {
      "left_table": "Aircraft AS T3",
      "right_table": "Certificate AS T2",
      "condition": "T3.aid = T2.aid"
    }
  ],
  "filters": [
    "T3.name = \"Boeing 737-800\""
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T1.name"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "Employee.name",
  "model_type": "report"
}