{
  "sources": [
    "raw.continents",
    "raw.countries",
    "raw.car_makers"
  ],
  "staging_models": [
    "stg_continents",
    "stg_countries",
    "stg_car_makers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_car_makers_by_continent",
    "type": "fact",
    "grain": "1 row per Continent"
  },
  "ctes": [
    "stg_continents",
    "stg_countries",
    "stg_car_makers"
  ],
  "joins": [
    {
      "left": "stg_continents",
      "right": "stg_countries",
      "on": "stg_continents.ContId = stg_countries.continent"
    },
    {
      "left": "stg_countries",
      "right": "stg_car_makers",
      "on": "stg_countries.CountryId = stg_car_makers.Country"
    }
  ],
  "tests": {
    "Continent": [
      "not_null"
    ],
    "COUNT(*)": [
      "not_null"
    ]
  }
}