{
  "sources": [
    "raw.individuals",
    "raw.organization_contact_individuals"
  ],
  "staging_models": [
    "stg_individuals",
    "stg_organization_contact_individuals"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_individual_last_name",
    "type": "dimension",
    "grain": "1 row per individual_last_name"
  },
  "ctes": [
    "stg_individuals",
    "stg_organization_contact_individuals"
  ],
  "joins": [
    {
      "left": "stg_individuals",
      "right": "stg_organization_contact_individuals",
      "on": "t1.individual_id = t2.individual_id"
    }
  ],
  "tests": {
    "individual_last_name": [
      "not_null",
      "unique"
    ]
  }
}