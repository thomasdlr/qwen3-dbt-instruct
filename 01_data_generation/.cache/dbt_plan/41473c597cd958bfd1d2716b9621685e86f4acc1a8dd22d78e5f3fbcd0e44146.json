{
  "sources": [
    "raw.genres",
    "raw.tracks",
    "raw.media_types"
  ],
  "staging_models": [
    "stg_genres",
    "stg_tracks",
    "stg_media_types"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_rock_mpeg_tracks",
    "type": "report",
    "grain": "1 row per track"
  },
  "ctes": [
    "stg_genres",
    "stg_tracks",
    "stg_media_types"
  ],
  "joins": [
    {
      "left": "stg_genres",
      "right": "stg_tracks",
      "on": "stg_genres.id = stg_tracks.genre_id"
    },
    {
      "left": "stg_tracks",
      "right": "stg_media_types",
      "on": "stg_media_types.id = stg_tracks.media_type_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}