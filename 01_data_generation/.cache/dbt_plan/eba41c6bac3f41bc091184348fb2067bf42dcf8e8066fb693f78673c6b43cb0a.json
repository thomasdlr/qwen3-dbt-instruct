{
  "sources": [
    "raw.accelerator_compatible_browser",
    "raw.browser",
    "raw.web_client_accelerator"
  ],
  "staging_models": [
    "stg_accelerator_compatible_browser",
    "stg_browser",
    "stg_web_client_accelerator"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_browser_accelerator_pairs",
    "type": "report",
    "grain": "1 row per browser_id, accelerator_id"
  },
  "ctes": [
    "stg_accelerator_compatible_browser",
    "stg_browser",
    "stg_web_client_accelerator"
  ],
  "joins": [
    {
      "left": "stg_accelerator_compatible_browser",
      "right": "stg_browser",
      "on": "stg_accelerator_compatible_browser.browser_id = stg_browser.id"
    },
    {
      "left": "stg_accelerator_compatible_browser",
      "right": "stg_web_client_accelerator",
      "on": "stg_accelerator_compatible_browser.accelerator_id = stg_web_client_accelerator.id"
    }
  ],
  "tests": {
    "browser_name": [
      "not_null"
    ],
    "accelerator_name": [
      "not_null"
    ]
  }
}