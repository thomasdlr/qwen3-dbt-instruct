{
  "sources": [
    "raw.course",
    "raw.class"
  ],
  "staging_models": [
    "stg_course",
    "stg_class"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_dept_credits",
    "type": "fact",
    "grain": "1 row per dept_code"
  },
  "ctes": [
    "stg_course",
    "stg_class"
  ],
  "joins": [
    {
      "left": "stg_course",
      "right": "stg_class",
      "on": "stg_course.crs_code = stg_class.crs_code"
    }
  ],
  "tests": {
    "sum_crs_credit": [
      "not_null"
    ],
    "dept_code": [
      "not_null",
      "unique"
    ]
  }
}