{
  "sources": [
    "raw.student",
    "raw.department"
  ],
  "staging_models": [
    "stg_student",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_avg_gpa_by_department",
    "type": "report",
    "grain": "1 row per department"
  },
  "ctes": [
    "stg_student",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_student",
      "right": "stg_department",
      "on": "stg_student.dept_code = stg_department.dept_code"
    }
  ],
  "tests": {
    "dept_name": [
      "not_null"
    ],
    "avg_gpa": [
      "not_null"
    ]
  }
}