{
  "sources": [
    "raw.customers",
    "raw.customer_orders",
    "raw.order_items"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_rodrick_heaney_products",
    "type": "report",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_customers",
    "stg_customer_orders",
    "stg_order_items"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customer_orders",
      "on": "customer_id"
    },
    {
      "left": "stg_customer_orders",
      "right": "stg_order_items",
      "on": "order_id"
    }
  ],
  "tests": {
    "customer_id": [
      "not_null",
      "unique"
    ],
    "distinct_product_count": [
      "not_null"
    ]
  }
}