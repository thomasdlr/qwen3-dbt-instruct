{
  "sources": [
    "raw.campuses",
    "raw.faculty"
  ],
  "staging_models": [
    "stg_campuses",
    "stg_faculty"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_campus_faculty_2002",
    "type": "report",
    "grain": "1 row per campus"
  },
  "ctes": [
    "stg_campuses",
    "stg_faculty"
  ],
  "joins": [
    {
      "left": "stg_campuses",
      "right": "stg_faculty",
      "on": "stg_campuses.id = stg_faculty.campus"
    }
  ],
  "tests": {
    "campus": [
      "not_null"
    ]
  }
}