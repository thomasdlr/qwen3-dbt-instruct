{
  "tables": [
    "Reservations",
    "Rooms"
  ],
  "joins": [
    {
      "left_table": "T1",
      "right_table": "T2",
      "condition": "T1.Room = T2.RoomId"
    }
  ],
  "filters": [
    "T1.Rate - T2.basePrice > 0"
  ],
  "select_columns": [
    "T1.firstname",
    "T1.lastname"
  ],
  "grain": "Reservations.firstname, Reservations.lastname",
  "model_type": "report"
}