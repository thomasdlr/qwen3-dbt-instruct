{
  "sources": [
    "raw.submission",
    "raw.acceptance"
  ],
  "staging_models": [
    "stg_submission",
    "stg_acceptance"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_author_workshop_count",
    "type": "report",
    "grain": "1 row per Author"
  },
  "ctes": [
    "stg_submission",
    "stg_acceptance"
  ],
  "joins": [
    {
      "left": "stg_acceptance",
      "right": "stg_submission",
      "on": "T1.Submission_ID = T2.Submission_ID"
    }
  ],
  "tests": {
    "Author": [
      "not_null"
    ]
  }
}