{
  "sources": [
    "raw.Third_Party_Companies",
    "raw.Maintenance_Engineers",
    "raw.Maintenance_Contracts"
  ],
  "staging_models": [
    "stg_Third_Party_Companies",
    "stg_Maintenance_Engineers",
    "stg_Maintenance_Contracts"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_company_maintenance_aggregation",
    "type": "report",
    "grain": "1 row per company_id"
  },
  "ctes": [
    "stg_Third_Party_Companies",
    "stg_Maintenance_Engineers",
    "stg_Maintenance_Contracts"
  ],
  "joins": [
    {
      "left": "stg_Third_Party_Companies",
      "right": "stg_Maintenance_Engineers",
      "on": "company_id = company_id"
    },
    {
      "left": "stg_Third_Party_Companies",
      "right": "stg_Maintenance_Contracts",
      "on": "company_id = maintenance_contract_company_id"
    }
  ],
  "tests": {
    "company_id": [
      "not_null"
    ],
    "company_name": [
      "not_null"
    ]
  }
}