{
  "sources": [
    "raw.problems",
    "raw.staff"
  ],
  "staging_models": [
    "stg_problems",
    "stg_staff"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_intersection",
    "type": "report",
    "grain": "1 row per product_id"
  },
  "ctes": [
    "stg_problems",
    "stg_staff"
  ],
  "joins": [
    {
      "left": "stg_problems",
      "right": "stg_staff",
      "on": "reported_by_staff_id = staff_id"
    },
    {
      "left": "stg_problems",
      "right": "stg_staff",
      "on": "closure_authorised_by_staff_id = staff_id"
    }
  ],
  "tests": {
    "product_id": [
      "not_null"
    ]
  }
}