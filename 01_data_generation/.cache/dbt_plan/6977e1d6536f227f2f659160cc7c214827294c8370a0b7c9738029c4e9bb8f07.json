{
  "sources": [
    "raw.staff",
    "raw.complaints"
  ],
  "staging_models": [
    "stg_staff",
    "stg_complaints"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_staff_complaint_counts",
    "type": "report",
    "grain": "1 row per staff_id"
  },
  "ctes": [
    "stg_staff",
    "stg_complaints"
  ],
  "joins": [
    {
      "left": "stg_staff",
      "right": "stg_complaints",
      "on": "stg_staff.staff_id = stg_complaints.staff_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "staff_id": [
      "not_null"
    ]
  }
}