{
  "sources": [
    "raw.Products",
    "raw.Products_in_Events"
  ],
  "staging_models": [
    "stg_Products",
    "stg_Products_in_Events"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_Product_Events",
    "type": "fact",
    "grain": "1 row per Product_Name"
  },
  "ctes": [
    "stg_Products",
    "stg_Products_in_Events"
  ],
  "joins": [
    {
      "left": "stg_Products",
      "right": "stg_Products_in_Events",
      "on": "Product_ID = Product_ID"
    }
  ],
  "tests": {
    "Product_Name": [
      "not_null"
    ],
    "COUNT(*)": [
      "not_null"
    ]
  }
}