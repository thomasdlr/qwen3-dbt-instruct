{
  "sources": [
    "raw.continents",
    "raw.countries"
  ],
  "staging_models": [
    "stg_continents",
    "stg_countries"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_continent_country_count",
    "type": "fact",
    "grain": "1 row per continent"
  },
  "ctes": [
    "stg_continents",
    "stg_countries"
  ],
  "joins": [
    {
      "left": "stg_continents",
      "right": "stg_countries",
      "on": "stg_continents.ContId = stg_countries.Continent"
    }
  ],
  "tests": {
    "ContId": [
      "not_null",
      "unique"
    ],
    "Continent": [
      "not_null"
    ],
    "COUNT(*)": [
      "not_null"
    ]
  }
}