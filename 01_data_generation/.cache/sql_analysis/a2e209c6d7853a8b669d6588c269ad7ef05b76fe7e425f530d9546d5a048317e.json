{
  "tables": [
    "FLIGHTS",
    "AIRPORTS",
    "AIRLINES"
  ],
  "joins": [
    {
      "left_table": "FLIGHTS",
      "right_table": "AIRPORTS",
      "condition": "T1.DestAirport = T2.AirportCode"
    },
    {
      "left_table": "AIRLINES",
      "right_table": "FLIGHTS",
      "condition": "T3.uid = T1.Airline"
    }
  ],
  "filters": [
    "T2.City = \"Aberdeen\"",
    "T3.Airline = \"United Airlines\""
  ]
}