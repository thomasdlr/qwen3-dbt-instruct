{
  "sources": [
    "raw.professor",
    "raw.department"
  ],
  "staging_models": [
    "stg_professor",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_professor_dept_summary",
    "type": "fact",
    "grain": "1 row per dept_code"
  },
  "ctes": [
    "stg_professor",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_professor",
      "right": "stg_department",
      "on": "stg_professor.dept_code = stg_department.dept_code"
    }
  ],
  "tests": {
    "dept_name": [
      "not_null"
    ],
    "dept_code": [
      "not_null"
    ]
  }
}