{
  "sources": [
    "raw.Student_Course_Enrolment",
    "raw.Students"
  ],
  "staging_models": [
    "stg_Student_Course_Enrolment",
    "stg_Students"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_course_counts",
    "type": "report",
    "grain": "1 row per student_id"
  },
  "ctes": [
    "stg_Student_Course_Enrolment",
    "stg_Students"
  ],
  "joins": [
    {
      "left": "stg_Student_Course_Enrolment",
      "right": "stg_Students",
      "on": "stg_Student_Course_Enrolment.student_id = stg_Students.student_id"
    }
  ],
  "tests": {
    "student_id": [
      "not_null",
      "unique"
    ],
    "login_name": [
      "not_null"
    ]
  }
}