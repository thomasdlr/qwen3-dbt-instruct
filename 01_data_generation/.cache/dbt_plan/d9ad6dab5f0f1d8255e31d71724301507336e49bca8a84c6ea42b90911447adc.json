{
  "sources": [
    "raw.CLASS",
    "raw.employee",
    "raw.course",
    "raw.professor",
    "raw.department"
  ],
  "staging_models": [
    "stg_CLASS",
    "stg_employee",
    "stg_course",
    "stg_professor",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_class",
    "type": "dimension",
    "grain": "1 row per class offering (prof_num, crs_code)"
  },
  "ctes": [
    "stg_CLASS",
    "stg_employee",
    "stg_professor",
    "stg_course",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_CLASS",
      "right": "stg_employee",
      "on": "T1.prof_num = T2.emp_num"
    },
    {
      "left": "stg_CLASS",
      "right": "stg_course",
      "on": "T1.crs_code = T3.crs_code"
    },
    {
      "left": "stg_employee",
      "right": "stg_professor",
      "on": "T2.emp_num = T4.emp_num"
    },
    {
      "left": "stg_professor",
      "right": "stg_department",
      "on": "T4.dept_code = T5.dept_code"
    }
  ],
  "tests": {
    "emp_fname": [
      "not_null"
    ],
    "prof_office": [
      "not_null"
    ],
    "crs_description": [
      "not_null"
    ],
    "dept_name": [
      "not_null"
    ]
  }
}