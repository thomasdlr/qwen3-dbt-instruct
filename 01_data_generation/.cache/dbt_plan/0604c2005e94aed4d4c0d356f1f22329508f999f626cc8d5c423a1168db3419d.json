{
  "sources": [
    "raw.orders",
    "raw.order_items",
    "raw.products"
  ],
  "staging_models": [
    "stg_orders",
    "stg_order_items",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_product_order_counts",
    "type": "fact",
    "grain": "1 row per product"
  },
  "ctes": [
    "stg_orders",
    "stg_order_items",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_orders",
      "right": "stg_order_items",
      "on": "orders.order_id = order_items.order_id"
    },
    {
      "left": "stg_order_items",
      "right": "stg_products",
      "on": "order_items.product_id = products.product_id"
    }
  ],
  "tests": {
    "product_order_count": [
      "not_null"
    ],
    "product_id": [
      "not_null",
      "unique"
    ]
  }
}