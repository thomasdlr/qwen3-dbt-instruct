{
  "sources": [
    "raw.dorm",
    "raw.has_amenity",
    "raw.dorm_amenity"
  ],
  "staging_models": [
    "stg_dorm",
    "stg_has_amenity",
    "stg_dorm_amenity"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_dorms_with_tv_lounge_and_study_room",
    "type": "report",
    "grain": "1 row per dorm_name"
  },
  "ctes": [
    "stg_dorm",
    "stg_has_amenity",
    "stg_dorm_amenity"
  ],
  "joins": [
    {
      "left": "stg_dorm",
      "right": "stg_has_amenity",
      "on": "dorm.dormid = has_amenity.dormid"
    },
    {
      "left": "stg_has_amenity",
      "right": "stg_dorm_amenity",
      "on": "has_amenity.amenid = dorm_amenity.amenid"
    }
  ],
  "tests": {
    "dorm_name": [
      "not_null"
    ]
  }
}