{
  "sources": [
    "raw.election",
    "raw.representative"
  ],
  "staging_models": [
    "stg_election",
    "stg_representative"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_representative_lifespan",
    "type": "dimension",
    "grain": "1 row per representative.Representative_ID"
  },
  "ctes": [
    "stg_election",
    "stg_representative"
  ],
  "joins": [
    {
      "left": "stg_election",
      "right": "stg_representative",
      "on": "T1.Representative_ID = T2.Representative_ID"
    }
  ],
  "tests": {
    "Lifespan": [
      "not_null"
    ]
  }
}