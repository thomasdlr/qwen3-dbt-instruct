{
  "sources": [
    "raw.customers",
    "raw.first_notification_of_loss",
    "raw.services"
  ],
  "staging_models": [
    "stg_customers",
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_customer_policy_changes",
    "type": "report",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_customers",
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_first_notification_of_loss",
      "on": "t1.customer_id = t2.customer_id"
    },
    {
      "left": "stg_first_notification_of_loss",
      "right": "stg_services",
      "on": "t2.service_id = t3.service_id"
    }
  ],
  "tests": {
    "customer_name": [
      "not_null"
    ]
  }
}