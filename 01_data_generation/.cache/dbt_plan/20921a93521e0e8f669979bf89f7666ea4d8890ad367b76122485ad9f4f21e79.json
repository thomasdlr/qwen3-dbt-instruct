{
  "sources": [
    "raw.Activity",
    "raw.Participates_in"
  ],
  "staging_models": [
    "stg_Activity",
    "stg_Participates_in"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_activity_participation",
    "type": "report",
    "grain": "1 row per Activity"
  },
  "ctes": [
    "stg_Activity",
    "stg_Participates_in"
  ],
  "joins": [
    {
      "left": "stg_Activity",
      "right": "stg_Participates_in",
      "on": "stg_Activity.actID = stg_Participates_in.actID"
    }
  ],
  "tests": {
    "activity_name": [
      "not_null"
    ],
    "actID": [
      "not_null"
    ]
  }
}