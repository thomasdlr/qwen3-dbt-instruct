{
  "tables": [
    "CLASS",
    "employee",
    "professor",
    "department"
  ],
  "joins": [
    {
      "left_table": "T1 (CLASS)",
      "right_table": "T2 (employee)",
      "condition": "T1.prof_num = T2.emp_num"
    },
    {
      "left_table": "T2 (employee)",
      "right_table": "T3 (professor)",
      "condition": "T2.emp_num = T3.emp_num"
    },
    {
      "left_table": "T4 (department)",
      "right_table": "T3 (professor)",
      "condition": "T4.dept_code = T3.emp_num"
    }
  ],
  "filters": [
    "T4.dept_name = 'Accounting'"
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T2.emp_fname",
    "T1.class_room"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T2.emp_num, T1.class_room",
  "model_type": "report"
}