{
  "tables": [
    "customers",
    "orders",
    "order_items",
    "products"
  ],
  "joins": [
    {
      "left_table": "customers",
      "right_table": "orders",
      "condition": "T1.customer_id = T2.customer_id"
    },
    {
      "left_table": "orders",
      "right_table": "order_items",
      "condition": "T2.order_id = T3.order_id"
    },
    {
      "left_table": "order_items",
      "right_table": "products",
      "condition": "T3.product_id = T4.product_id"
    }
  ],
  "filters": [
    "T3.order_item_status = \"Cancel\"",
    "T4.product_name = \"food\""
  ]
}