{
  "tables": [
    "assignedto",
    "projects",
    "scientists"
  ],
  "joins": [
    {
      "left_table": "assignedto",
      "right_table": "projects",
      "condition": "T1.project = T2.code"
    },
    {
      "left_table": "assignedto",
      "right_table": "scientists",
      "condition": "T1.scientist = T3.SSN"
    }
  ],
  "filters": [
    "T2.name = 'Matter of Time'",
    "T2.name = 'A Puzzling Parallax'"
  ],
  "select_columns": [
    "T3.name",
    "T3.name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T3.name",
  "model_type": "report"
}