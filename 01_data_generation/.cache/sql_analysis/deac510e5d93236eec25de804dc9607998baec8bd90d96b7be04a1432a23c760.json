{
  "tables": [
    "problems",
    "product",
    "staff"
  ],
  "joins": [
    {
      "left_table": "problems",
      "right_table": "product",
      "condition": "T1.product_id = T2.product_id"
    },
    {
      "left_table": "problems",
      "right_table": "staff",
      "condition": "T1.reported_by_staff_id = T3.staff_id"
    }
  ],
  "filters": [
    "T2.product_name = \"rem\"",
    "T2.product_name = \"aut\""
  ],
  "select_columns": [
    "T3.staff_first_name",
    "T3.staff_last_name"
  ],
  "set_operations": [
    "EXCEPT"
  ],
  "has_subquery": true,
  "grain": "T3.staff_first_name, T3.staff_last_name",
  "model_type": "report"
}