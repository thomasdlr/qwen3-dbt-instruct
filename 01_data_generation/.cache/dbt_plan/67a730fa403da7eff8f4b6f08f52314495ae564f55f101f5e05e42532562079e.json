{
  "sources": [
    "raw.performance",
    "raw.band",
    "raw.songs"
  ],
  "staging_models": [
    "stg_performance",
    "stg_band",
    "stg_songs"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_flash_performance_count",
    "type": "report",
    "grain": ""
  },
  "ctes": [
    "stg_performance",
    "stg_band",
    "stg_songs"
  ],
  "joins": [
    {
      "left": "stg_performance",
      "right": "stg_band",
      "on": "bandmate = id"
    },
    {
      "left": "songs",
      "right": "performance",
      "on": "songid = songid"
    }
  ],
  "tests": {
    "COUNT(*)": [
      "not_null"
    ]
  }
}