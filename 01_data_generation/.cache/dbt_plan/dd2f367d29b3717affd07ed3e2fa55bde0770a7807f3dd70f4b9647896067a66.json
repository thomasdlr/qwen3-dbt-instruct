{
  "sources": [
    "raw.Course_Authors_and_Tutors",
    "raw.Courses"
  ],
  "staging_models": [
    "stg_Course_Authors_and_Tutors",
    "stg_Courses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_advanced_database_authors",
    "type": "report",
    "grain": "1 row per login_name"
  },
  "ctes": [
    "stg_Course_Authors_and_Tutors",
    "stg_Courses"
  ],
  "joins": [
    {
      "left": "stg_Course_Authors_and_Tutors",
      "right": "stg_Courses",
      "on": "T1.author_id = T2.author_id"
    }
  ],
  "tests": {
    "login_name": [
      "not_null"
    ]
  }
}