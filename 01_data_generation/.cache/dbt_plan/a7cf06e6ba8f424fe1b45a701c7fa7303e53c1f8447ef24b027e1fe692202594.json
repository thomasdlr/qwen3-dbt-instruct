{
  "sources": [
    "raw.railway",
    "raw.train"
  ],
  "staging_models": [
    "stg_railway",
    "stg_train"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_train_railway",
    "type": "dimension",
    "grain": "1 row per train"
  },
  "ctes": [
