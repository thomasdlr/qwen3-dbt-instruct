{
  "sources": [
    "raw.visitor",
    "raw.visit"
  ],
  "staging_models": [
    "stg_visitor",
    "stg_visit"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_visitor_spend",
    "type": "dimension",
    "grain": "1 row per visitor_id"
  },
  "ctes": [
    "stg_visitor",
    "stg_visit"
  ],
  "joins": [
    {
      "left": "stg_visitor",
      "right": "stg_visit",
      "on": "stg_visit.visitor_id = stg_visitor.id"
    }
  ],
  "tests": {
    "visitor_id": [
      "not_null"
    ],
    "name": [
      "not_null"
    ],
    "Level_of_membership": [
      "not_null"
    ]
  }
}