{
  "sources": [
    "raw.physician",
    "raw.trained_in",
    "raw.procedures"
  ],
  "staging_models": [
    "stg_physician",
    "stg_trained_in",
    "stg_procedures"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_physician",
    "type": "dimension",
    "grain": "1 row per physician.name"
  },
  "ctes": [
    "stg_physician",
    "stg_trained_in",
    "stg_procedures"
  ],
  "joins": [
    {
      "left": "physician_cte",
      "right": "trained_in_cte",
      "on": "physician_cte.employeeid = trained_in_cte.physician"
    },
    {
      "left": "procedures_cte",
      "right": "trained_in_cte",
      "on": "procedures_cte.code = trained_in_cte.treatment"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}