{
  "sources": [
    "raw.accounts",
    "raw.customers"
  ],
  "staging_models": [
    "stg_accounts",
    "stg_customers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_customer_accounts",
    "type": "fact",
    "grain": "1 row per customer_id"
  },
  "ctes": [
    "stg_accounts",
    "stg_customers"
  ],
  "joins": [
    {
      "left": "stg_accounts",
      "right": "stg_customers",
      "on": "stg_accounts.customer_id = stg_customers.customer_id"
    }
  ],
  "tests": {
    "customer_first_name": [
      "not_null"
    ],
    "customer_id": [
      "not_null"
    ]
  }
}