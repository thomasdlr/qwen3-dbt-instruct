{
  "sources": [
    "raw.staff",
    "raw.rental",
    "raw.customer"
  ],
  "staging_models": [
    "stg_staff",
    "stg_rental",
    "stg_customer"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_staff_rental_customer_april_burns",
    "type": "report",
    "grain": "1 row per staff.staff_id"
  },
  "ctes": [
    "stg_staff",
    "stg_rental",
    "stg_customer"
  ],
  "joins": [
    {
      "left": "stg_staff",
      "right": "stg_rental",
      "on": "stg_staff.staff_id = stg_rental.staff_id"
    },
    {
      "left": "stg_rental",
      "right": "stg_customer",
      "on": "stg_rental.customer_id = stg_customer.customer_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ]
  }
}