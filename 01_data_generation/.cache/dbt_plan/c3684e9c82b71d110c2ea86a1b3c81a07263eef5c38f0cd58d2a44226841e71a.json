{
  "sources": [
    "raw.list",
    "raw.teachers"
  ],
  "staging_models": [
    "stg_list",
    "stg_teachers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_grade5_teachers",
    "type": "report",
    "grain": "1 row per T2.lastname"
  },
  "ctes": [
    "stg_list",
    "stg_teachers"
  ],
  "joins": [
    {
      "left": "stg_list",
      "right": "stg_teachers",
      "on": "T1.classroom = T2.classroom"
    }
  ],
  "tests": {
    "lastname": [
      "not_null",
      "unique"
    ]
  }
}