{
  "tables": [
    "Rating",
    "Movie"
  ],
  "joins": [
    {
      "left_table": "T1",
      "right_table": "T2",
      "condition": "T1.mID = T2.mID"
    }
  ],
  "filters": [
    "director <> \"null\""
  ],
  "aggregations": [
    {
      "function": "MAX",
      "column": "T1.stars",
      "alias": ""
    }
  ],
  "group_by": [
    "director"
  ],
  "select_columns": [
    "T2.title",
    "T1.stars",
    "T2.director",
    "MAX(T1.stars)"
  ],
  "grain": "director",
  "model_type": "report"
}