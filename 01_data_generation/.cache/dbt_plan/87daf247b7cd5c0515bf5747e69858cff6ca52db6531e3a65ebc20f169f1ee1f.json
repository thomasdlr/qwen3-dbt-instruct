{
  "sources": [
    "raw.Performance",
    "raw.Band",
    "raw.Songs"
  ],
  "staging_models": [
    "stg_Performance",
    "stg_Band",
    "stg_Songs"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_band_songs_by_marianne",
    "type": "report",
    "grain": "1 row per Band.id, Songs.SongId"
  },
  "ctes": [
    "stg_Performance",
    "stg_Band",
    "stg_Songs"
  ],
  "joins": [
    {
      "left": "stg_Performance",
      "right": "stg_Band",
      "on": "Performance.bandmate = Band.id"
    },
    {
      "left": "stg_Band",
      "right": "stg_Songs",
      "on": "Songs.SongId = Performance.SongId"
    }
  ],
  "tests": {
    "Title": [
      "not_null"
    ]
  }
}