{
  "sources": [
    "raw.customer",
    "raw.employee"
  ],
  "staging_models": [
    "stg_customer",
    "stg_employee"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_support_rep_customer_count",
    "type": "report",
    "grain": "1 row per SupportRepId"
  },
  "ctes": [
    "stg_customer",
    "stg_employee"
  ],
  "joins": [
    {
      "left": "stg_customer",
      "right": "stg_employee",
      "on": "stg_customer.SupportRepId = stg_employee.EmployeeId"
    }
  ],
  "tests": {
    "FirstName": [
      "not_null"
    ],
    "SupportRepId": [
      "not_null"
    ]
  }
}