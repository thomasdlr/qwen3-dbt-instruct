{
  "tables": [
    "aircraft",
    "airport_aircraft",
    "airport"
  ],
  "joins": [
    {
      "left_table": "aircraft",
      "right_table": "airport_aircraft",
      "condition": "T1.Aircraft_ID = T2.Aircraft_ID"
    },
    {
      "left_table": "airport_aircraft",
      "right_table": "airport",
      "condition": "T2.Airport_ID = T3.Airport_ID"
    }
  ],
  "filters": [
    "T3.Airport_Name = \"London Heathrow\"",
    "T3.Airport_Name = \"London Gatwick\""
  ]
}