{
  "sources": [
    "raw.visitor",
    "raw.visit",
    "raw.museum"
  ],
  "staging_models": [
    "stg_visitor",
    "stg_visit",
    "stg_museum"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_visitor_museum_intersection",
    "type": "report",
    "grain": "1 row per visitor.name"
  },
  "ctes": [
    "stg_visitor",
    "stg_visit",
    "stg_museum"
  ],
  "joins": [
    {
      "left": "stg_visitor",
      "right": "stg_visit",
      "on": "stg_visitor.id = stg_visit.visitor_id"
    },
    {
      "left": "stg_museum",
      "right": "stg_visit",
      "on": "stg_museum.Museum_ID = stg_visit.Museum_ID"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}