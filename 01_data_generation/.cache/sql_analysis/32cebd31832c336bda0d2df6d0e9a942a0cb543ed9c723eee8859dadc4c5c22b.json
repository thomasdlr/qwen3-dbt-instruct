  "filters": [
    "T1.name = \"John Wen\""
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T3.name"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "physician.employeeid, trained_in.treatment",
