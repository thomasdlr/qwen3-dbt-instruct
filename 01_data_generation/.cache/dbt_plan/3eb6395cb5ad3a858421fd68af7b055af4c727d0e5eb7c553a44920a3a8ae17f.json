{
  "sources": [
    "raw.album",
    "raw.track",
    "raw.genre"
  ],
  "staging_models": [
    "stg_album",
    "stg_track",
    "stg_genre"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_reggae_albums",
    "type": "report",
    "grain": "1 row per album title"
  },
  "ctes": [
    "stg_album",
    "stg_track",
    "stg_genre"
  ],
  "joins": [
    {
      "left": "stg_album",
      "right": "stg_track",
      "on": "AlbumId = Track.AlbumId"
    },
    {
      "left": "stg_track",
      "right": "stg_genre",
      "on": "Track.GenreID = Genre.GenreID"
    }
  ],
  "tests": {
    "Title": [
      "not_null"
    ]
  }
}