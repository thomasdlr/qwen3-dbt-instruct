{
  "sources": [
    "raw.Professionals",
    "raw.Treatments"
  ],
  "staging_models": [
    "stg_Professionals",
    "stg_Treatments"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_ProfessionalTreatmentsExcept",
    "type": "report",
    "grain": "1 row per professional_id"
  },
  "ctes": [
    "stg_Professionals",
    "stg_Treatments"
  ],
  "joins": [
    {
      "left": "stg_Professionals",
      "right": "stg_Treatments",
      "on": "T1.professional_id = T2.professional_id"
    }
  ],
  "tests": {
    "professional_id": [
      "not_null",
      "unique"
    ],
    "role_code": [
      "not_null"
    ],
    "email_address": [
      "not_null"
    ]
  }
}