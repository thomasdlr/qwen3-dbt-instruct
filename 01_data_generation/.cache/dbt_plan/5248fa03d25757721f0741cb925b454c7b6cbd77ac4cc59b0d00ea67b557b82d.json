{
  "sources": [
    "raw.store",
    "raw.address"
  ],
  "staging_models": [
    "stg_store",
    "stg_address"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_store_address",
    "type": "dimension",
    "grain": "1 row per address.address_id"
  },
  "ctes": [
    "stg_store",
    "stg_address"
  ],
  "joins": [
    {
      "left": "stg_store",
      "right": "stg_address",
      "on": "T1.address_id = T2.address_id"
    }
  ],
  "tests": {
    "address": [
      "not_null"
    ]
  }
}