{
  "sources": [
    "raw.train",
    "raw.route"
  ],
  "staging_models": [
    "stg_train",
    "stg_route"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_train_routes",
    "type": "report",
    "grain": "1 row per train_id"
  },
  "ctes": [
    "stg_train",
    "stg_route"
  ],
  "joins": [
    {
      "left": "stg_train",
      "right": "stg_route",
      "on": "train.id = route.train_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "train_id": [
      "not_null",
      "unique"
    ]
  }
}