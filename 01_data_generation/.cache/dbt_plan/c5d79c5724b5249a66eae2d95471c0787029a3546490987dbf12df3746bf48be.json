{
  "sources": [
    "raw.office_locations",
    "raw.buildings",
    "raw.companies"
  ],
  "staging_models": [
    "stg_office_locations",
    "stg_buildings",
    "stg_companies"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_building_office_counts",
    "type": "report",
    "grain": "1 row per building_id"
  },
  "ctes": [
    "stg_buildings",
    "stg_companies"
  ],
  "joins": [
    {
      "left": "stg_office_locations",
      "right": "stg_buildings",
      "on": "building_id = id"
    },
    {
      "left": "stg_office_locations",
      "right": "stg_companies",
      "on": "company_id = id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "building_id": [
      "not_null",
      "unique"
    ]
  }
}