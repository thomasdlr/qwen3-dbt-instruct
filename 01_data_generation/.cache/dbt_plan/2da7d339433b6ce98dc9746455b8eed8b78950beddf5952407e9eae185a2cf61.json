{
  "sources": [
    "raw.statements",
    "raw.documents"
  ],
  "staging_models": [
    "stg_statements",
    "stg_documents"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_private_project_documents",
    "type": "report",
    "grain": "1 row per statement_id and document_name"
  },
  "ctes": [
    "stg_statements",
    "stg_documents"
  ],
  "joins": [
    {
      "left": "stg_statements",
      "right": "stg_documents",
      "on": "stg_statements.statement_id = stg_documents.document_id"
    }
  ],
  "tests": {
    "statement_details": [
      "not_null"
    ],
    "document_name": [
      "not_null"
    ]
  }
}