{
  "sources": [
    "raw.customers",
    "raw.first_notification_of_loss",
    "raw.services"
  ],
  "staging_models": [
    "stg_customers",
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "intermediate_models": [
    "int_customer_service_report"
  ],
  "mart_model": {
    "name": "rpt_customer_policy_intersection",
    "type": "report",
    "grain": "1 row per customer_name"
  },
  "ctes": [
    "stg_customers",
    "stg_first_notification_of_loss",
    "stg_services"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_first_notification_of_loss",
      "on": "customer_id = customer_id"
    },
    {
      "left": "stg_first_notification_of_loss",
      "right": "stg_services",
      "on": "service_id = service_id"
    }
  ],
  "tests": {
    "customer_name": [
      "not_null",
      "unique"
    ]
  }
}