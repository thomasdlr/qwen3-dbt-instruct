{
  "sources": [
    "raw.employment",
    "raw.people",
    "raw.company"
  ],
  "staging_models": [
    "stg_employment",
    "stg_people",
    "stg_company"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_people_in_large_companies",
    "type": "report",
    "grain": "1 row per People_ID"
  },
  "ctes": [
    "stg_employment",
    "stg_people",
    "stg_company"
  ],
  "joins": [
    {
      "left": "stg_employment",
      "right": "stg_people",
      "on": "People_ID = People_ID"
    },
    {
      "left": "stg_employment",
      "right": "stg_company",
      "on": "Company_ID = Company_ID"
    }
  ],
  "tests": {
    "Name": [
      "not_null"
    ]
  }
}