{
  "tables": [
    "game",
    "stadium",
    "injury_accident"
  ],
  "joins": [
    {
      "left_table": "game",
      "right_table": "stadium",
      "condition": "T1.stadium_id = T2.id"
    },
    {
      "left_table": "game",
      "right_table": "injury_accident",
      "condition": "T1.id = T3.game_id"
    }
  ],
  "filters": [
    "T3.player = 'Walter Samuel'",
    "T3.player = 'Thiago Motta'"
  ],
  "select_columns": [
    "T2.name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "stadium.name",
  "model_type": "report"
}