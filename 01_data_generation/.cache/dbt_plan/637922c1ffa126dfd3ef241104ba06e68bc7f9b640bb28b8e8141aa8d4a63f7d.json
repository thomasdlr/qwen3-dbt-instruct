{
  "sources": [
    "raw.parts",
    "raw.part_faults"
  ],
  "staging_models": [
    "stg_parts",
    "stg_part_faults"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_parts_faults_summary",
    "type": "report",
    "grain": "1 row per part_name"
  },
  "ctes": [
    "stg_parts",
    "stg_part_faults"
  ],
  "joins": [
    {
      "left": "stg_parts",
      "right": "stg_part_faults",
      "on": "stg_parts.part_id = stg_part_faults.part_id"
    }
  ],
  "tests": {
    "part_name": [
      "not_null"
    ]
  }
}