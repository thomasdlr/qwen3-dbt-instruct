{
  "sources": [
    "raw.artist",
    "raw.volume"
  ],
  "staging_models": [
    "stg_artist",
    "stg_volume"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_famous_titles_intersect",
    "type": "report",
    "grain": "1 row per Famous_Title"
  },
  "ctes": [
    "stg_artist",
    "stg_volume"
  ],
  "joins": [
    {
      "left": "stg_artist",
      "right": "stg_volume",
      "on": "Artist_ID = Artist_ID"
    }
  ],
  "tests": {
    "Famous_Title": [
      "not_null",
      "unique"
    ]
  }
}