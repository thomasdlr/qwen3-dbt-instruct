{
  "sources": [
    "raw.products",
    "raw.product_characteristics"
  ],
  "staging_models": [
    "stg_products",
    "stg_product_characteristics",
    "stg_characteristics"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_product_characteristic_counts",
    "type": "report",
    "grain": "1 row per characteristic_name"
  },
  "ctes": [
    "stg_products",
    "stg_product_characteristics",
    "stg_characteristics"
  ],
  "joins": [
    {
      "left": "t1",
      "right": "t2",
      "on": "t1.product_id = t2.product_id"
    },
    {
      "left": "t2",
      "right": "t3",
      "on": "t2.characteristic_id = t3.characteristic_id"
    }
  ],
  "tests": {
    "characteristic_name": [
      "not_null"
    ]
  }
}