{
  "sources": [
    "raw.customers",
    "raw.customer_orders"
  ],
  "staging_models": [
    "stg_customers",
    "stg_customer_orders"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_pending_orders_by_customer",
    "type": "report",
    "grain": "1 row per customer_name"
  },
  "ctes": [
    "stg_customers",
    "stg_customer_orders"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_customer_orders",
      "on": "customer_id"
    }
  ],
  "tests": {
    "customer_name": [
      "not_null",
      "unique"
    ]
  }
}