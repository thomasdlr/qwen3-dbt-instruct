{
  "tables": [
    "Tourist_Attractions",
    "Tourist_Attraction_Features",
    "Features"
  ],
  "joins": [
    {
      "left_table": "Tourist_Attractions",
      "right_table": "Tourist_Attraction_Features",
      "condition": "T1.tourist_attraction_id = T2.tourist_attraction_id"
    },
    {
      "left_table": "Tourist_Attraction_Features",
      "right_table": "Features",
      "condition": "T2.Feature_ID = T3.Feature_ID"
    }
  ],
  "filters": [
    "T3.feature_Details = 'park'",
    "T3.feature_Details = 'shopping'"
  ],
  "select_columns": [
    "T1.Name",
    "T1.Name"
  ],
  "set_operations": [
    "UNION"
  ],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T1.Name",
  "model_type": "report"
}