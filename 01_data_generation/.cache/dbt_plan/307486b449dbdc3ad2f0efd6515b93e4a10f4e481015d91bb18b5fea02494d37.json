{
  "sources": [
    "raw.acceptance",
    "raw.submission"
  ],
  "staging_models": [
    "stg_acceptance",
    "stg_submission"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_author_workshop_counts",
    "type": "fact",
    "grain": "1 row per Author"
  },
  "ctes": [
    "stg_acceptance",
    "stg_submission"
  ],
  "joins": [
    {
      "left": "stg_acceptance",
      "right": "stg_submission",
      "on": "Submission_ID = Submission_ID"
    }
  ],
  "tests": {
    "Author": [
      "not_null",
      "unique"
    ],
    "workshop_count": [
      "not_null"
    ]
  }
}