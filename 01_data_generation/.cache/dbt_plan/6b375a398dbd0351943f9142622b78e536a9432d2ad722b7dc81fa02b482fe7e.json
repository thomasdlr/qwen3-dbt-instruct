{
  "sources": [
    "raw.contestants",
    "raw.votes",
    "raw.area_code_state"
  ],
  "staging_models": [
    "stg_contestants",
    "stg_votes",
    "stg_area_code_state"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_contestant_area_codes",
    "type": "report",
    "grain": "1 row per area_code"
  },
  "ctes": [
    "stg_contestants",
    "stg_votes",
    "stg_area_code_state"
  ],
  "joins": [
    {
      "left": "stg_contestants",
      "right": "stg_votes",
      "on": "contestant_number = contestant_number"
    },
    {
      "left": "stg_votes",
      "right": "stg_area_code_state",
      "on": "state = state"
    }
  ],
  "tests": {
    "area_code": [
      "not_null"
    ]
  }
}