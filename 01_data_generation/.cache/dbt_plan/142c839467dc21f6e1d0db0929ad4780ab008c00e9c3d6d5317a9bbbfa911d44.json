{
  "sources": [
    "raw.bank",
    "raw.loan"
  ],
  "staging_models": [
    "stg_bank",
    "stg_loan"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_bank_name",
    "type": "dimension",
    "grain": "1 row per bank name"
  },
  "ctes": [
    "stg_bank",
    "stg_loan"
  ],
  "joins": [
    {
      "left": "stg_bank",
      "right": "stg_loan",
      "on": "branch_id = branch_id"
    }
  ],
  "tests": {
    "bname": [
      "not_null"
    ]
  }
}