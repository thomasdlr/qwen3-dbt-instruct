{
  "tables": [
    "student",
    "takes",
    "course"
  ],
  "joins": [
    {
      "left_table": "T1 (takes)",
      "right_table": "course",
      "condition": "T1.course_id = T2.course_id"
    }
  ],
  "filters": [
    "NOT id IN (SELECT T1.id FROM takes AS T1 JOIN course AS T2 ON T1.course_id = T2.course_id WHERE T2.dept_name = 'Biology')"
  ],
  "select_columns": [
    "name"
  ],
  "has_subquery": true,
  "grain": "student.name",
  "model_type": "report"
}