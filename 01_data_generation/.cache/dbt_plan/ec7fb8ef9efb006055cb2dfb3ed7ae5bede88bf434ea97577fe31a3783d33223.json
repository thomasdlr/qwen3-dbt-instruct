{
  "sources": [
    "raw.ALBUM",
    "raw.ARTIST"
  ],
  "staging_models": [
    "stg_ALBUM",
    "stg_ARTIST"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_metallica_album_count",
    "type": "report",
    "grain": "1 row per Metallica"
  },
  "ctes": [
    "stg_ALBUM",
    "stg_ARTIST"
  ],
  "joins": [
    {
      "left": "stg_ALBUM",
      "right": "stg_ARTIST",
      "on": "stg_ALBUM.ArtistId = stg_ARTIST.ArtistId"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ]
  }
}