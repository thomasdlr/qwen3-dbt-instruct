    "raw.tweets"
  ],
  "staging_models": [
    "stg_user_profiles",
    "stg_tweets"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_tweets_per_user_count",
    "type": "fact",
    "grain": "1 row per tweets.uid"
  },
  "ctes": [
    "stg_user_profiles",
    "stg_tweets"
  ],
  "joins": [
    {
      "left": "stg_user_profiles",
      "right": "stg_tweets",
      "on": "stg_user_profiles.uid = stg_tweets.uid"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "partitionid": [
      "not_null"
    ]
  }
}