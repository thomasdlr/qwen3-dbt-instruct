{
  "sources": [
    "raw.staff",
    "raw.payment"
  ],
  "staging_models": [
    "stg_staff",
    "stg_payment"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_staff",
    "type": "dimension",
    "grain": "1 row per staff_id"
  },
  "ctes": [
    "stg_staff",
    "stg_payment"
  ],
  "joins": [
    {
      "left": "stg_staff",
      "right": "stg_payment",
      "on": "stg_staff.staff_id = stg_payment.staff_id"
    }
  ],
  "tests": {
    "first_name": [
      "not_null"
    ],
    "last_name": [
      "not_null"
    ],
    "staff_id": [
      "not_null",
      "unique"
    ]
  }
}