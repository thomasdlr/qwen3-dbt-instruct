{
  "tables": [
    "battle",
    "ship"
  ],
  "joins": [
    {
      "left_table": "T1 (battle)",
      "right_table": "T2 (ship)",
      "condition": "T1.id = T2.lost_in_battle"
    }
  ],
  "filters": [
    "T2.name = 'Lettice'",
    "T2.name = 'HMS Atalanta'"
  ],
  "select_columns": [
    "T1.name",
    "T1.date"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_subquery": false,
  "grain": "battle.name, battle.date",
  "model_type": "report"
}