{
  "tables": [
    "Accounts",
    "Customers"
  ],
  "joins": [
    {
      "left_table": "Accounts",
      "right_table": "Customers",
      "condition": "T1.customer_id = T2.customer_id"
    }
  ],
  "filters": [
    "T2.customer_first_name = \"Art\"",
    "T2.customer_last_name = \"Turcotte\""
  ]
}