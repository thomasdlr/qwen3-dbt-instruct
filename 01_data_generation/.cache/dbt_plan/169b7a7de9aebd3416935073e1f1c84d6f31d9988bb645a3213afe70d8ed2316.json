{
  "sources": [
    "raw.organizations",
    "raw.organization_contact_individuals"
  ],
  "staging_models": [
    "stg_organizations",
    "stg_organization_contact_individuals"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_organization_contact_counts",
    "type": "fact",
    "grain": "1 row per organization_name"
  },
  "ctes": [
    "stg_organizations",
    "stg_organization_contact_individuals"
  ],
  "joins": [
    {
      "left": "stg_organizations",
      "right": "stg_organization_contact_individuals",
      "on": "stg_organizations.organization_id = stg_organization_contact_individuals.organization_id"
    }
  ],
  "tests": {
    "organization_name": [
      "not_null"
    ]
  }
}