{
  "tables": [
    "student",
    "lives_in",
    "dorm",
    "has_amenity",
    "dorm_amenity"
  ],
  "joins": [
    {
      "left_table": "student",
      "right_table": "lives_in",
      "condition": "T1.stuid = T2.stuid"
    },
    {
      "left_table": "dorm",
      "right_table": "has_amenity",
      "condition": "T3.dormid = T4.dormid"
    },
    {
      "left_table": "has_amenity",
      "right_table": "dorm_amenity",
      "condition": "T4.amenid = T5.amenid"
    }
  ],
  "filters": [
    "T2.dormid IN (SELECT T2.dormid FROM dorm AS T3 JOIN has_amenity AS T4 ON T3.dormid = T4.dormid JOIN dorm_amenity AS T5 ON T4.amenid = T5.amenid GROUP BY T3.dormid ORDER BY COUNT(*) DESC LIMIT 1)"
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T1.fname"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": true,
  "has_window_fn": false,
  "grain": "T1.fname",
  "model_type": "report"
}