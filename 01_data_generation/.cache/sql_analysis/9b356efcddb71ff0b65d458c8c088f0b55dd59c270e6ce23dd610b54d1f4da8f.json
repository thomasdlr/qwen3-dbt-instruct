{
  "tables": [
    "countries",
    "car_makers"
  ],
  "joins": [
    {
      "left_table": "t1",
      "right_table": "t2",
      "condition": "t1.countryid = t2.country"
    }
  ],
  "filters": [
    "COUNT(*) > 3",
    "t3.model = 'fiat'"
  ],
  "aggregations": [
    {
      "function": "COUNT",
      "column": "*",
      "alias": ""
    }
  ],
  "group_by": [
    "t1.countryid"
  ],
  "having": [
    "COUNT(*) > 3"
  ],
  "select_columns": [
    "t1.countryid",
    "t1.countryname"
  ],
  "set_operations": [
    "UNION"
  ],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "t1.countryid",
  "model_type": "report"
}