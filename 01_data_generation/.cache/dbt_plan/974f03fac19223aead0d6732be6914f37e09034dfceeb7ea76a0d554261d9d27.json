{
  "sources": [
    "raw.dorm",
    "raw.has_amenity",
    "raw.dorm_amenity",
    "raw.lives_in",
    "raw.student"
  ],
  "staging_models": [
    "stg_dorm",
    "stg_has_amenity",
    "stg_dorm_amenity",
    "stg_lives_in",
    "stg_student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_dorm_amenities_for_smiths",
    "type": "report",
    "grain": "1 row per dorm_amenity.amenid"
  },
  "ctes": [
    "stg_dorm",
    "stg_has_amenity",
    "stg_dorm_amenity",
    "stg_lives_in",
    "stg_student"
  ],
  "joins": [
    {
      "left": "stg_dorm",
      "right": "stg_has_amenity",
      "on": "dorm.dormid = has_amenity.dormid"
    },
    {
      "left": "stg_has_amenity",
      "right": "stg_dorm_amenity",
      "on": "has_amenity.amenid = dorm_amenity.amenid"
    },
    {
      "left": "stg_dorm",
      "right": "stg_lives_in",
      "on": "dorm.dormid = lives_in.dormid"
    },
    {
      "left": "stg_lives_in",
      "right": "stg_student",
      "on": "lives_in.stuid = student.stuid"
    }
  ],
  "tests": {
    "amenity_name": [
      "not_null"
    ]
  }
}