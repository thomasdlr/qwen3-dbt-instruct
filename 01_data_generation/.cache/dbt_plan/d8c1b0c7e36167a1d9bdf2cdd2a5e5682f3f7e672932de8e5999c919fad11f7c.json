{
  "sources": [
    "raw.visitor",
    "raw.museum",
    "raw.visit"
  ],
  "staging_models": [
    "stg_visitor",
    "stg_museum",
    "stg_visit"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_visitors_excluding_recent_museums",
    "type": "report",
    "grain": "1 row per visitor"
  },
  "ctes": [
    "stg_museum",
    "stg_visit"
  ],
  "joins": [
    {
      "left": "stg_museum",
      "right": "stg_visit",
      "on": "t1.Museum_ID = t2.Museum_ID"
    }
  ],
  "tests": {
    "COUNT(*)": [
      "not_null"
    ]
  }
}