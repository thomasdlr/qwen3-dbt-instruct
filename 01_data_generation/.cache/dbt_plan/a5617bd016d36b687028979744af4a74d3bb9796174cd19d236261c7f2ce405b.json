{
  "sources": [
    "raw.advisor",
    "raw.instructor",
    "raw.student"
  ],
  "staging_models": [
    "stg_advisor",
    "stg_instructor",
    "stg_student"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_student_advisor_instructor",
    "type": "report",
    "grain": "1 row per student.tot_cred"
  },
  "ctes": [
    "stg_instructor",
    "stg_student"
  ],
  "joins": [
    {
      "left": "stg_instructor",
      "right": "stg_student",
      "on": "stg_instructor.id = stg_student.i_id"
    },
    {
      "left": "stg_instructor",
      "right": "stg_student",
      "on": "stg_instructor.id = stg_student.s_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}