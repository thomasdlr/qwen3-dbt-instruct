{
  "sources": [
    "raw.customers",
    "raw.orders",
    "raw.order_items",
    "raw.products"
  ],
  "staging_models": [
    "stg_customers",
    "stg_orders",
    "stg_order_items",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_cancelled_food_orders",
    "type": "fact",
    "grain": "1 row per order_item"
  },
  "ctes": [
    "stg_customers",
    "stg_orders",
    "stg_order_items",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_orders",
      "on": "customer_id"
    },
    {
      "left": "stg_orders",
      "right": "stg_order_items",
      "on": "order_id"
    },
    {
      "left": "stg_order_items",
      "right": "stg_products",
      "on": "product_id"
    }
  ],
  "tests": {
    "<all_columns>": [
      "not_null"
    ]
  }
}