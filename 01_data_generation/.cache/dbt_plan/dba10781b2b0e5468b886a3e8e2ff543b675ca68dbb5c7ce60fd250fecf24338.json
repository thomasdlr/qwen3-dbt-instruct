{
  "sources": [
    "raw.products",
    "raw.ref_colors"
  ],
  "staging_models": [
    "stg_products",
    "stg_ref_colors"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_chervil_color_mapping",
    "type": "report",
    "grain": "1 row per color_code"
  },
  "ctes": [
    "stg_products",
    "stg_ref_colors"
  ],
  "joins": [
    {
      "left": "stg_products",
      "right": "stg_ref_colors",
      "on": "stg_products.color_code = stg_ref_colors.color_code"
    }
  ],
  "tests": {
    "color_code": [
      "not_null"
    ],
    "color_description": [
      "not_null"
    ]
  }
}