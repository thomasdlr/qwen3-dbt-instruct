{
  "sources": [
    "raw.documents",
    "raw.document_sections"
  ],
  "staging_models": [
    "stg_documents",
    "stg_document_sections"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_david_cv_sections",
    "type": "report",
    "grain": "1 row per document_code, section_title"
  },
  "ctes": [
    "stg_documents",
    "stg_document_sections"
  ],
  "joins": [
    {
      "left": "stg_documents",
      "right": "stg_document_sections",
      "on": "document_code = document_code"
    }
  ],
  "tests": {
    "section_title": [
      "not_null"
    ]
  }
}