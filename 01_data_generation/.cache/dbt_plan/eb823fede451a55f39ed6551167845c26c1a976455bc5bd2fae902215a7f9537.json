{
  "sources": [
    "raw.authors",
    "raw.authorship",
    "raw.papers"
  ],
  "staging_models": [
    "stg_authors",
    "stg_authorship",
    "stg_papers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_authors_by_paper",
    "type": "dimension",
    "grain": "1 row per authors.authid"
  },
  "ctes": [
    "stg_authors",
    "stg_authorship",
    "stg_papers"
  ],
  "joins": [
    {
      "left": "stg_authors",
      "right": "stg_authorship",
      "on": "authid = authid"
    },
    {
      "left": "stg_authorship",
      "right": "stg_papers",
      "on": "paperid = paperid"
    }
  ],
  "tests": {
    "lname": [
      "not_null"
    ]
  }
}