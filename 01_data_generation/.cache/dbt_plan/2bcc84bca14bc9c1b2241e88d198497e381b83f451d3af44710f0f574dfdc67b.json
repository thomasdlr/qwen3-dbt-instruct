{
  "sources": [
    "raw.student",
    "raw.takes",
    "raw.course",
    "raw.prereq"
  ],
  "staging_models": [
    "stg_student",
    "stg_takes",
    "stg_course",
    "stg_prereq"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_international_finance_students",
    "type": "report",
    "grain": "1 row per student"
  },
  "ctes": [
    "stg_student",
    "stg_takes",
    "stg_course"
  ],
  "joins": [
    {
      "left": "stg_student",
      "right": "stg_takes",
      "on": "stg_student.id = stg_takes.student_id"
    },
    {
      "left": "stg_takes",
      "right": "stg_course",
      "on": "stg_takes.course_id = stg_course.id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}