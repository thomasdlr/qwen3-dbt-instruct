{
  "sources": [
    "raw.authors",
    "raw.authorship",
    "raw.papers"
  ],
  "staging_models": [
    "stg_authors",
    "stg_authorship",
    "stg_papers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_atsushi_ohori_papers",
    "type": "report",
    "grain": "1 row per authorship record filtered by Atsushi Ohori"
  },
  "ctes": [
    "stg_authors",
    "stg_authorship",
    "stg_papers"
  ],
  "joins": [
    {
      "left": "stg_authors",
      "right": "stg_authorship",
      "on": "stg_authors.authid = stg_authorship.authid"
    },
    {
      "left": "stg_authorship",
      "right": "stg_papers",
      "on": "stg_authorship.paperid = stg_papers.paperid"
    }
  ],
  "tests": {
    "*": [
      "not_null"
    ]
  }
}