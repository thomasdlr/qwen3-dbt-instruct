{
  "sources": [
    "raw.Templates",
    "raw.Documents"
  ],
  "staging_models": [
    "stg_Templates",
    "stg_Documents"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_document_by_template",
    "type": "dimension",
    "grain": "1 row per document_name"
  },
  "ctes": [
    "stg_Templates",
    "stg_Documents"
  ],
  "joins": [
    {
      "left": "stg_Templates",
      "right": "stg_Documents",
      "on": "T1.template_id = T2.template_id"
    }
  ],
  "tests": {
    "document_name": [
      "not_null"
    ]
  }
}