{
  "sources": [
    "raw.customers",
    "raw.complaints"
  ],
  "staging_models": [
    "stg_customers",
    "stg_complaints"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_latest_complaint_dates",
    "type": "report",
    "grain": "1 row per complaint date"
  },
  "ctes": [
    "stg_customers",
    "stg_complaints"
  ],
  "joins": [
    {
      "left": "stg_customers",
      "right": "stg_complaints",
      "on": "stg_customers.customer_id = stg_complaints.customer_id"
    }
  ],
  "tests": {
    "phone_number": [
      "not_null"
    ]
  }
}