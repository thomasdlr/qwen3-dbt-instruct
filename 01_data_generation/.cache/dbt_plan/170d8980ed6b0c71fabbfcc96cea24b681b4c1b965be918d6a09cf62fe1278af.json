{
  "sources": [
    "raw.Employees",
    "raw.Circulation_History"
  ],
  "staging_models": [
    "stg_Employees",
    "stg_Circulation_History"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_document_1_circulation",
    "type": "report",
    "grain": "1 row per employee_name"
  },
  "ctes": [
    "stg_Circulation_History",
    "stg_Employees"
  ],
  "joins": [
    {
      "left": "stg_Circulation_History",
      "right": "stg_Employees",
      "on": "Circulation_History.employee_id = Employees.employee_id"
    }
  ],
  "tests": {
    "employee_name": [
      "not_null"
    ]
  }
}