{
  "sources": [
    "raw.organizations",
    "raw.organization_contact_individuals",
    "raw.individuals"
  ],
  "staging_models": [
    "stg_organizations",
    "stg_organization_contact_individuals",
    "stg_individuals"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_labour_party_contacts",
    "type": "report",
    "grain": "1 row per organization_contact_individuals record"
  },
  "ctes": [
    "stg_organizations",
    "stg_organization_contact_individuals",
    "stg_individuals"
  ],
  "joins": [
    {
      "left": "stg_organizations",
      "right": "stg_organization_contact_individuals",
      "on": "t1.organization_id = t2.organization_id"
    },
    {
      "left": "stg_organization_contact_individuals",
      "right": "stg_individuals",
      "on": "t2.individual_id = t3.individual_id"
    }
  ],
  "tests": {
    "individual_last_name": [
      "not_null"
    ]
  }
}