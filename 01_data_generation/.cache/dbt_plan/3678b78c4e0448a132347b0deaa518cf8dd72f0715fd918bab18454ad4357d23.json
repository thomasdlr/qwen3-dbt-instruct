{
  "sources": [
    "raw.employee",
    "raw.evaluation"
  ],
  "staging_models": [
    "stg_employee",
    "stg_evaluation"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_employee_evaluation_counts",
    "type": "report",
    "grain": "1 row per Employee_ID"
  },
  "ctes": [
    "stg_employee",
    "stg_evaluation"
  ],
  "joins": [
    {
      "left": "stg_employee",
      "right": "stg_evaluation",
      "on": "Employee_ID = Employee_ID"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ],
    "Employee_ID": [
      "not_null"
    ]
  }
}