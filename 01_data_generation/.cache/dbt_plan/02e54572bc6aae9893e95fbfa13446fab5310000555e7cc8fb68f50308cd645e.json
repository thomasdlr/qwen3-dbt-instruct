{
  "sources": [
    "raw.orchestra",
    "raw.performance"
  ],
  "staging_models": [
    "stg_orchestra",
    "stg_performance"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_orchestra_performances",
    "type": "fact",
    "grain": "1 row per Orchestra_ID"
  },
  "ctes": [
    "stg_orchestra",
    "stg_performance"
  ],
  "joins": [
    {
      "left": "stg_orchestra",
      "right": "stg_performance",
      "on": "stg_orchestra.Orchestra_ID = stg_performance.Orchestra_ID"
    }
  ],
  "tests": {
    "Year_of_Founded": [
      "not_null"
    ]
  }
}