{
  "tables": [
    "party_host",
    "HOST",
    "party"
  ],
  "joins": [
    {
      "left_table": "T1",
      "right_table": "T2",
      "condition": "T1.Host_ID = T2.Host_ID"
    },
    {
      "left_table": "T1",
      "right_table": "T3",
      "condition": "T1.Party_ID = T3.Party_ID"
    }
  ],
  "filters": [
    "T3.Number_of_hosts > 20"
  ],
  "select_columns": [
    "T2.Name"
  ],
  "grain": "party_host.Party_ID",
  "model_type": "report"
}