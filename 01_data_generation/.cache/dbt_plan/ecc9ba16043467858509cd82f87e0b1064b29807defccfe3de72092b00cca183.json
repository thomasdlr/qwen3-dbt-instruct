{
  "sources": [
    "raw.photos",
    "raw.camera_lens"
  ],
  "staging_models": [
    "stg_photos",
    "stg_camera_lens"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_camera_lens_photos",
    "type": "report",
    "grain": "1 row per camera_lens"
  },
  "ctes": [
    "stg_camera_lens"
  ],
  "joins": [
    {
      "left": "stg_photos",
      "right": "stg_camera_lens",
      "on": "stg_photos.camera_lens_id = stg_camera_lens.id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}