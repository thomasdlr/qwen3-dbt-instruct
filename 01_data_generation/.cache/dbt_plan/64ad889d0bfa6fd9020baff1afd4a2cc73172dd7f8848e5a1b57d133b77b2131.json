{
  "sources": [
    "raw.people",
    "raw.poker_player"
  ],
  "staging_models": [
    "stg_people",
    "stg_poker_player"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_people",
    "type": "dimension",
    "grain": "1 row per People_ID"
  },
  "ctes": [
    "stg_people",
    "stg_poker_player"
  ],
  "joins": [
    {
      "left": "stg_people",
      "right": "stg_poker_player",
      "on": "stg_people.People_ID = stg_poker_player.People_ID"
    }
  ],
  "tests": {
    "Birth_Date": [
      "not_null"
    ]
  }
}