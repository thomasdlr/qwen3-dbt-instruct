{
  "sources": [
    "raw.professor",
    "raw.department"
  ],
  "staging_models": [
    "stg_professor",
    "stg_department"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_accounting_biology_professors",
    "type": "fact",
    "grain": "1 row per dept_code"
  },
  "ctes": [
    "stg_professor",
    "stg_department"
  ],
  "joins": [
    {
      "left": "stg_professor",
      "right": "stg_department",
      "on": "stg_professor.dept_code = stg_department.dept_code"
    }
  ],
  "tests": {
    "count_star": [
      "not_null"
    ]
  }
}