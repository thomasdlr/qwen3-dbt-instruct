{
  "sources": [
    "raw.Addresses",
    "raw.Staff"
  ],
  "staging_models": [
    "stg_Addresses",
    "stg_Staff"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_staff_by_geography",
    "type": "report",
    "grain": "1 row per state_province_county"
  },
  "ctes": [
    "stg_Addresses",
    "stg_Staff"
  ],
  "joins": [
    {
      "left": "stg_Addresses",
      "right": "stg_Staff",
      "on": "address_id = staff_address_id"
    }
  ],
  "tests": {
    "state_province_county": [
      "not_null"
    ]
  }
}