{
  "sources": [
    "raw.CLASS",
    "raw.employee",
    "raw.course",
    "raw.professor"
  ],
  "staging_models": [
    "stg_CLASS",
    "stg_employee",
    "stg_course",
    "stg_professor"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_class_professor_course",
    "type": "report",
    "grain": "1 row per (crs_code, prof_num)"
  },
  "ctes": [
    "stg_CLASS",
    "stg_employee",
    "stg_course",
    "stg_professor"
  ],
  "joins": [
    {
      "left": "stg_CLASS",
      "right": "stg_employee",
      "on": "T1.prof_num = T2.emp_num"
    },
    {
      "left": "stg_CLASS",
      "right": "stg_course",
      "on": "T1.crs_code = T3.crs_code"
    },
    {
      "left": "stg_employee",
      "right": "stg_professor",
      "on": "T2.emp_num = T4.emp_num"
    }
  ],
  "tests": {
    "emp_fname": [
      "not_null"
    ],
    "prof_office": [
      "not_null"
    ],
    "crs_description": [
      "not_null"
    ]
  }
}