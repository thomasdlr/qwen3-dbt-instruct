{
  "sources": [
    "raw.Detention",
    "raw.Teachers"
  ],
  "staging_models": [
    "stg_Detention",
    "stg_Teachers"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_detention_schultz",
    "type": "report",
    "grain": "1 row per detention start and end datetime for Schultz"
  },
  "ctes": [
    "stg_Detention",
    "stg_Teachers"
  ],
  "joins": [
    {
      "left": "stg_Detention",
      "right": "stg_Teachers",
      "on": "T1.teacher_id = T2.teacher_id"
    }
  ],
  "tests": {
    "datetime_detention_start": [
      "not_null"
    ],
    "datetime_detention_end": [
      "not_null"
    ]
  }
}