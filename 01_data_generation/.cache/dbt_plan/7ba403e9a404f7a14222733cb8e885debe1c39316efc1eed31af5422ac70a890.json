{
  "sources": [
    "raw.county",
    "raw.election"
  ],
  "staging_models": [
    "stg_county",
    "stg_election"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_county_election_stats",
    "type": "fact",
    "grain": "1 row per County_id"
  },
  "ctes": [
    "stg_county",
    "stg_election"
  ],
  "joins": [
    {
      "left": "stg_county",
      "right": "stg_election",
      "on": "county.county_id = election.district"
    }
  ],
  "tests": {
    "county_name": [
      "not_null"
    ],
    "county_id": [
      "not_null"
    ]
  }
}