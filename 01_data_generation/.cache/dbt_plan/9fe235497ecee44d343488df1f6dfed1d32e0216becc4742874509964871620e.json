{
  "sources": [
    "raw.product_categories",
    "raw.products"
  ],
  "staging_models": [
    "stg_product_categories",
    "stg_products"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_product_categories",
    "type": "dimension",
    "grain": "1 row per product_category_description"
  },
  "ctes": [
    "stg_product_categories",
    "stg_products"
  ],
  "joins": [
    {
      "left": "stg_product_categories",
      "right": "stg_products",
      "on": "stg_product_categories.product_category_code = stg_products.product_category_code"
    }
  ],
  "tests": {
    "product_category_description": [
      "not_null"
    ]
  }
}