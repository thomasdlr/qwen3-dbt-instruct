{
  "tables": [
    "membership_register_branch",
    "branch",
    "member"
  ],
  "joins": [
    {
      "left_table": "membership_register_branch",
      "right_table": "branch",
      "condition": "T1.branch_id = T2.branch_id"
    },
    {
      "left_table": "membership_register_branch",
      "right_table": "member",
      "condition": "T1.member_id = T3.member_id"
    }
  ],
  "filters": [
    "T3.Hometown = 'Louisville ,  Kentucky'",
    "T3.Hometown = 'Hiram ,  Georgia'"
  ],
  "select_columns": [
    "T2.name",
    "T2.name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_subquery": false,
  "grain": "branch.name",
  "model_type": "report"
}