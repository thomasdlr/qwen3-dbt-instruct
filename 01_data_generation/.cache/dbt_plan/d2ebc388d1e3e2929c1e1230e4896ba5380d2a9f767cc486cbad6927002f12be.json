{
  "sources": [
    "raw.debate_people",
    "raw.debate",
    "raw.people"
  ],
  "staging_models": [
    "stg_debate_people",
    "stg_debate",
    "stg_people"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_debate_affirmatives",
    "type": "report",
    "grain": "1 row per debate_people link"
  },
  "ctes": [
    "stg_debate_people",
    "stg_debate",
    "stg_people"
  ],
  "joins": [
    {
      "left": "stg_debate_people",
      "right": "stg_debate",
      "on": "debate_id = debate.debate_id"
    },
    {
      "left": "stg_debate_people",
      "right": "stg_people",
      "on": "affirmative = people.people_id"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}