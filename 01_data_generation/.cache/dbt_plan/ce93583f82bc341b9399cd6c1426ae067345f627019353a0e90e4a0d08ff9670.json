{
  "sources": [
    "raw.performance",
    "raw.band",
    "raw.songs"
  ],
  "staging_models": [
    "stg_performance",
    "stg_band",
    "stg_songs"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_band_performance",
    "type": "report",
    "grain": "1 row per band.id"
  },
  "ctes": [
    "stg_performance",
    "stg_band",
    "stg_songs"
  ],
  "joins": [
    {
      "left": "stg_performance",
      "right": "stg_band",
      "on": "bandmate = id"
    },
    {
      "left": "stg_performance",
      "right": "stg_songs",
      "on": "songid = songid"
    }
  ],
  "tests": {
    "firstname": [
      "not_null"
    ],
    "lastname": [
      "not_null"
    ]
  }
}