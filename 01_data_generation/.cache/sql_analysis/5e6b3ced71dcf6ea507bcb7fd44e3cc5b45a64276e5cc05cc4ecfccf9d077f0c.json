{
  "tables": [
    "contestants",
    "votes",
    "area_code_state"
  ],
  "joins": [
    {
      "left_table": "contestants",
      "right_table": "votes",
      "condition": "T1.contestant_number = T2.contestant_number"
    },
    {
      "left_table": "votes",
      "right_table": "area_code_state",
      "condition": "T2.state = T3.state"
    }
  ],
  "filters": [
    "T1.contestant_name = 'Tabatha Gehling'",
    "T1.contestant_name = 'Kelly Clauss'"
  ],
  "select_columns": [
    "T3.area_code",
    "T3.area_code"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_subquery": false,
  "grain": "T3.area_code",
  "model_type": "report"
}