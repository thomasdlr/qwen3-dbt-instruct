{
  "sources": [
    "raw.election",
    "raw.representative"
  ],
  "staging_models": [
    "stg_election",
    "stg_representative"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_representative_election",
    "type": "report",
    "grain": "1 row per representative and election date"
  },
  "ctes": [
    "stg_election",
    "stg_representative"
  ],
  "joins": [
    {
      "left": "stg_election",
      "right": "stg_representative",
      "on": "stg_election.Representative_ID = stg_representative.Representative_ID"
    }
  ],
  "tests": {
    "Name": [
      "not_null"
    ],
    "Date": [
      "not_null"
    ]
  }
}