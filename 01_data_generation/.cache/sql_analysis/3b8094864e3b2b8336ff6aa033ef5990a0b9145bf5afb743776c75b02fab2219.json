{
  "tables": [
    "budget",
    "school",
    "endowment"
  ],
  "joins": [
    {
      "left_table": "budget",
      "right_table": "school",
      "condition": "T1.school_id = T2.school_id"
    },
    {
      "left_table": "school",
      "right_table": "endowment",
      "condition": "T2.school_id = T3.school_id"
    }
  ],
  "filters": [],
  "aggregations": [
    {
      "function": "SUM",
      "column": "T1.budgeted",
      "alias": ""
    },
    {
      "function": "SUM",
      "column": "T3.amount",
      "alias": ""
    }
  ],
  "group_by": [
    "T2.school_name"
  ],
  "having": [
    "SUM(T1.budgeted) > 100",
    "SUM(T3.amount) > 10"
  ],
  "select_columns": [
    "T2.school_name"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
