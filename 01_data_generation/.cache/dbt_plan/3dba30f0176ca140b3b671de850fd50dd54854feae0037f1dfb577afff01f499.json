{
  "sources": [
    "raw.patient",
    "raw.appointment"
  ],
  "staging_models": [
    "stg_patient",
    "stg_appointment"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_patient_appointments",
    "type": "report",
    "grain": "1 row per patient"
  },
  "ctes": [
    "stg_patient",
    "stg_appointment"
  ],
  "joins": [
    {
      "left": "stg_patient",
      "right": "stg_appointment",
      "on": "stg_patient.ssn = stg_appointment.patient"
    }
  ],
  "tests": {
    "name": [
      "not_null"
    ]
  }
}