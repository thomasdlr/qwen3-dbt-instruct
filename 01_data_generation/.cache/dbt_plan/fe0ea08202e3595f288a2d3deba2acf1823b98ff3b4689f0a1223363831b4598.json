      "left": "stg_sportsinfo",
      "right": "stg_student",
      "on": "stg_sportsinfo.stuid = stg_student.stuid"
    }
  ],
  "tests": {
    "fname": [
      "not_null"
    ],
    "lname": [
      "not_null"
    ]
  }
}