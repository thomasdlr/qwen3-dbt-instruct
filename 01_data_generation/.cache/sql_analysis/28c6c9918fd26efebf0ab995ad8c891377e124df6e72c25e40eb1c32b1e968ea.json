{
  "tables": [
    "Tourist_Attractions",
    "VISITORS",
    "VISITS"
  ],
  "joins": [
    {
      "left_table": "Tourist_Attractions",
      "right_table": "VISITS",
      "condition": "T1.Tourist_Attraction_ID = T3.Tourist_Attraction_ID"
    },
    {
      "left_table": "VISITORS",
      "right_table": "VISITS",
      "condition": "T2.Tourist_ID = T3.Tourist_ID"
    }
  ],
  "filters": [
    "T2.Tourist_Details = \"Vincent\"",
    "T2.Tourist_Details = \"Marcelle\""
  ],
  "select_columns": [
    "T1.Name",
    "T1.Name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "grain": "T1.Name",
  "model_type": "report"
}