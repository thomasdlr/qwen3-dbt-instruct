{
  "sources": [
    "raw.nomination",
    "raw.artwork",
    "raw.festival_detail"
  ],
  "staging_models": [
    "stg_nomination",
    "stg_artwork",
    "stg_festival_detail"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_artwork_type_by_festival_year",
    "type": "report",
    "grain": "1 row per artwork type in 2007 festivals"
  },
  "ctes": [
    "stg_nomination",
    "stg_artwork",
    "stg_festival_detail"
  ],
  "joins": [
    {
      "left": "stg_nomination",
      "right": "stg_artwork",
      "on": "nomination.Artwork_ID = artwork.Artwork_ID"
    },
    {
      "left": "stg_nomination",
      "right": "stg_festival_detail",
      "on": "nomination.Festival_ID = festival_detail.Festival_ID"
    }
  ],
  "tests": {
    "Type": [
      "not_null"
    ]
  }
}