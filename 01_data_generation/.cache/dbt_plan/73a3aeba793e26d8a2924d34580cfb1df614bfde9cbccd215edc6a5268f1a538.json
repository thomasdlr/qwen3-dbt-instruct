{
  "sources": [
    "raw.addresses",
    "raw.customer_addresses"
  ],
  "staging_models": [
    "stg_addresses",
    "stg_customer_addresses"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "dim_customer_address_details",
    "type": "dimension",
    "grain": "1 row per customer address details"
  },
  "ctes": [
    "stg_addresses",
    "stg_customer_addresses"
  ],
  "joins": [
    {
      "left": "stg_addresses",
      "right": "stg_customer_addresses",
      "on": "stg_addresses.address_id = stg_customer_addresses.address_id"
    }
  ],
  "tests": {
    "address_details": [
      "not_null"
    ]
  }
}