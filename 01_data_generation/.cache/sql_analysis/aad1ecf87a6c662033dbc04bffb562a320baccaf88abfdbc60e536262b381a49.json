{
  "tables": [
    "student",
    "enroll"
  ],
  "joins": [
    {
      "left_table": "student",
      "right_table": "enroll",
      "condition": "T1.stu_num = T2.stu_num"
    }
  ],
  "filters": [
    "T2.enroll_grade = 'A'",
    "T2.class_code = 10018"
  ],
  "select_columns": [
    "T1.stu_lname"
  ],
  "grain": "T1.stu_num",
  "model_type": "report"
}