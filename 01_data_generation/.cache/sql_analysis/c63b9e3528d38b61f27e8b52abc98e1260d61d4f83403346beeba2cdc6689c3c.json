{
  "tables": [
    "documents",
    "Grants",
    "Organisations",
    "organisation_Types"
  ],
  "joins": [
    {
      "left_table": "documents",
      "right_table": "Grants",
      "condition": "T1.grant_id = T2.grant_id"
    },
    {
      "left_table": "Grants",
      "right_table": "Organisations",
      "condition": "T2.organisation_id = T3.organisation_id"
    },
    {
      "left_table": "Organisations",
      "right_table": "organisation_Types",
      "condition": "T3.organisation_type = T4.organisation_type"
    }
  ],
  "filters": [
    "T2.grant_amount > 5000",
    "T4.organisation_type_description = 'Research'"
  ],
  "aggregations": [],
  "group_by": [],
  "having": [],
  "select_columns": [
    "T1.sent_date"
  ],
  "set_operations": [],
  "has_distinct": false,
  "has_subquery": false,
  "has_window_fn": false,
  "grain": "T1.sent_date",
  "model_type": "report"
}