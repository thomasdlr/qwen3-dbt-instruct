{
  "sources": [
    "raw.fault_log",
    "raw.fault_log_parts"
  ],
  "staging_models": [
    "stg_fault_log",
    "stg_fault_log_parts"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_fault_status",
    "type": "report",
    "grain": "1 row per fault_log_entry_id"
  },
  "ctes": [
    "stg_fault_log",
    "stg_fault_log_parts"
  ],
  "joins": [
    {
      "left": "stg_fault_log",
      "right": "stg_fault_log_parts",
      "on": "fault_log_entry_id = fault_log_entry_id"
    }
  ],
  "tests": {
    "fault_description": [
      "not_null"
    ],
    "fault_status": [
      "not_null"
    ]
  }
}