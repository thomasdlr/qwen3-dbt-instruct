{
  "tables": [
    "visitor",
    "visit",
    "museum"
  ],
  "joins": [
    {
      "left_table": "t1 (visitor)",
      "right_table": "t2 (visit)",
      "condition": "t1.id = t2.visitor_id"
    },
    {
      "left_table": "t3 (museum)",
      "right_table": "t2 (visit)",
      "condition": "t3.Museum_ID = t2.Museum_ID"
    }
  ],
  "filters": [
    "t3.open_year < 2009",
    "t3.open_year > 2011"
  ],
  "select_columns": [
    "t1.name",
    "t1.name"
  ],
  "set_operations": [
    "INTERSECT"
  ],
  "has_distinct": false,
  "has_subquery": true,
  "has_window_fn": false,
  "grain": "visitor.name",
  "model_type": "report"
}