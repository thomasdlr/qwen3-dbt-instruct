{
  "sources": [
    "raw.Third_Party_Companies",
    "raw.Maintenance_Contracts",
    "raw.Ref_Company_Types"
  ],
  "staging_models": [
    "stg_Third_Party_Companies",
    "stg_Maintenance_Contracts",
    "stg_Ref_Company_Types"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_company_list",
    "type": "report",
    "grain": "1 row per company_id"
  },
  "ctes": [
    "stg_Third_Party_Companies",
    "stg_Maintenance_Contracts",
    "stg_Ref_Company_Types"
  ],
  "joins": [
    {
      "left": "stg_Third_Party_Companies",
      "right": "stg_Maintenance_Contracts",
      "on": "T1.company_id = T2.maintenance_contract_company_id"
    },
    {
      "left": "stg_Third_Party_Companies",
      "right": "stg_Ref_Company_Types",
      "on": "T1.company_type_code = T3.company_type_code"
    }
  ],
  "tests": {
    "company_name": [
      "not_null"
    ]
  }
}