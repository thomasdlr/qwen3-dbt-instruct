{
  "sources": [
    "raw.enroll",
    "raw.student",
    "raw.CLASS"
  ],
  "staging_models": [
    "stg_enroll",
    "stg_student",
    "stg_CLASS"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "rpt_avgtu_gpa_per_course",
    "type": "report",
    "grain": "1 row per course"
  },
  "ctes": [
    "stg_enroll",
    "stg_student",
    "stg_CLASS"
  ],
  "joins": [
    {
      "left": "stg_enroll",
      "right": "stg_student",
      "on": "stg_enroll.stu_num = stg_student.stu_num"
    },
    {
      "left": "stg_enroll",
      "right": "stg_CLASS",
      "on": "stg_enroll.class_code = stg_CLASS.class_code"
    }
  ],
  "tests": {
    "avgtu_gpa": [
      "not_null"
    ]
  }
}