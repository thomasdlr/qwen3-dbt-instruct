{
  "sources": [
    "raw.airports",
    "raw.flights"
  ],
  "staging_models": [
    "stg_airports",
    "stg_flights"
  ],
  "intermediate_models": [],
  "mart_model": {
    "name": "fct_airport_flight_counts",
    "type": "fact",
    "grain": "1 row per airport"
  },
  "ctes": [
    "stg_airports",
    "stg_flights"
  ],
  "joins": [
    {
      "left": "stg_airports",
      "right": "stg_flights",
      "on": "T1.AirportCode = T2.DestAirport OR T1.AirportCode = T2.SourceAirport"
    }
  ],
  "tests": {
    "airport_code": [
      "not_null",
      "unique"
    ]
  }
}